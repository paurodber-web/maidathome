---
interface Props { currentPath?: string; legacy?: boolean; }
const { currentPath = '', legacy = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const modern = `<header class="site-header" id="siteHeader"><div class="nav shell" aria-label="Main navigation"><a class="brand" href="/" aria-label="Maid At Home, back to home"><span class="brand__mark brand-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 10.8 12 3.7l8.5 7.1"></path><path d="M5.7 9.4v9.4h12.6V9.4"></path><path d="M9.5 18.8v-5.2h5v5.2"></path><path d="m17.7 4 .5 1.2 1.2.5-1.2.5-.5 1.2-.5-1.2-1.2-.5 1.2-.5.5-1.2Z"></path></svg></span><span>Maid At Home</span></a><nav class="desktop-nav" aria-label="Desktop navigation"><div class="nav-item-dropdown"><a href="/services/" class="dropdown-trigger">Services</a><div class="dropdown-menu"><a href="/services/standard-clean">Standard clean</a><a href="/services/deep-clean">Deep clean</a><a href="/services/end-of-lease-clean">End of lease</a><a href="/services/move-in-clean">Move-in clean</a><a href="/services/hourly-clean">Hourly clean</a><a href="/services/carpet-clean">Carpet clean</a><a href="/services/oven-clean">Oven clean</a></div></div><a href="/about-us">About</a><a href="/pricing">Pricing</a><a href="/areas-we-serve">Areas</a><a href="/faqs">FAQs</a><a href="/blog/">Blog</a><a href="/contact" aria-current="page">Contact</a><a class="nav-cta" href="/booking">Book a clean <span aria-hidden="true"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></span></a></nav><button class="menu-btn menu-toggle" id="menuToggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu"><span></span><span></span><span></span></button></div></header>
  <div class="mobile-menu" id="mobileMenu" aria-hidden="true"><div class="mobile-inner mobile-menu__inner"><nav class="mobile-links mobile-menu__links" aria-label="Mobile navigation"><a href="/services/" class="mobile-primary">Services <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><div class="mobile-service-list"><a href="/services/standard-clean">Standard clean</a><a href="/services/deep-clean">Deep clean</a><a href="/services/end-of-lease-clean">End of lease</a><a href="/services/move-in-clean">Move-in clean</a><a href="/services/hourly-clean">Hourly clean</a><a href="/services/carpet-clean">Carpet clean</a><a href="/services/oven-clean">Oven clean</a></div><a href="/about-us">About us <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><a href="/pricing">Pricing <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><a href="/areas-we-serve">Areas <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><a href="/faqs">FAQs <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><a href="/blog/">Blog <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a><a href="/contact">Contact <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a></nav><div class="mobile-bottom mobile-menu__bottom"><p>Friendly home cleaning, thoughtfully organised across Melbourne.</p><a class="button blue button--blue button--primary" href="/booking">Book a clean <i class="button__icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></i></a></div></div></div>
  `;
const old = `<header class="site-header" id="header"><div class="nav shell" aria-label="Main navigation"><a class="brand" href="/" aria-label="Maid At Home, back to home"><span class="brand__mark brand-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 10.8 12 3.7l8.5 7.1"></path><path d="M5.7 9.4v9.4h12.6V9.4"></path><path d="M9.5 18.8v-5.2h5v5.2"></path><path d="m17.7 4 .5 1.2 1.2.5-1.2.5-.5 1.2-.5-1.2-1.2-.5 1.2-.5.5-1.2Z"></path></svg></span><span>Maid At Home</span></a><nav class="desktop-nav" aria-label="Desktop navigation"><div class="nav-item-dropdown"><a href="/services/" class="dropdown-trigger">Services</a><div class="dropdown-menu"><a href="/services/standard-clean">Standard clean</a><a href="/services/deep-clean">Deep clean</a><a href="/services/end-of-lease-clean">End of lease</a><a href="/services/move-in-clean">Move-in clean</a><a href="/services/hourly-clean">Hourly clean</a><a href="/services/carpet-clean">Carpet clean</a><a href="/services/oven-clean">Oven clean</a></div></div><a href="/about-us">About</a><a href="/pricing">Pricing</a><a href="/areas-we-serve">Areas</a><a href="/faqs">FAQs</a><a href="/blog/">Blog</a><a href="/contact">Contact</a><a class="nav-cta" href="/booking" aria-current="page">Book a clean <span aria-hidden="true"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></span></a></nav><button class="menu-btn menu-toggle" id="menuBtn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu"><span></span><span></span><span></span></button></div></header>
