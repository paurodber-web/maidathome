---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  widths?: number[];
  sizes?: string;
  width?: number;
  height?: number;
  loading?: "eager" | "lazy";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  class: className,
  widths,
  sizes,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  class={className}
  widths={widths}
  sizes={sizes}
  width={width}
  height={height}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
/>
