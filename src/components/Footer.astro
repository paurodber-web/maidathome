---
interface Props { currentPath?: string; yearId?: string; }
const { currentPath = '', yearId = 'year' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const markup = `<footer><div class="shell"><div class="footer-top"><div class="footer-brand"><a class="brand" href="/"><span class="brand__mark brand-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 10.8 12 3.7l8.5 7.1"></path><path d="M5.7 9.4v9.4h12.6V9.4"></path><path d="M9.5 18.8v-5.2h5v5.2"></path><path d="m17.7 4 .5 1.2 1.2.5-1.2.5-.5 1.2-.5-1.2-1.2-.5 1.2-.5.5-1.2Z"></path></svg></span><span>Maid At Home</span></a><p>Friendly, professional home cleaning across Melbourne. Cleaning spaces to improve lives since 2017.</p><div class="footer-contact"><a href="mailto:info@maidathome.com.au">info@maidathome.com.au</a><a href="https://maidathome.com.au">maidathome.com.au</a></div></div><div class="footer-col"><h3>Services</h3><nav><a href="/services/standard-clean">Standard clean</a><a href="/services/deep-clean">Deep clean</a><a href="/services/end-of-lease-clean">End of lease</a><a href="/services/move-in-clean">Move-in clean</a><a href="/services/hourly-clean">Hourly clean</a><a href="/services/carpet-clean">Carpet clean</a><a href="/services/oven-clean">Oven clean</a></nav></div><div class="footer-col"><h3>Explore</h3><nav><a href="/about-us">About us</a><a href="/pricing">Pricing</a><a href="/areas-we-serve">Areas we serve</a><a href="/faqs">FAQs</a><a href="/blog/">Blog</a></nav></div><div class="footer-col"><h3>Book &amp; contact</h3><nav><a href="/booking">Book a clean</a><a href="/contact">Contact us</a><a href="mailto:info@maidathome.com.au">Email our team</a></nav></div></div><div class="footer-bottom"><p>© <span id="year">2026</span> Maid At Home. All rights reserved.</p><div class="legal"><a href="/privacy-policy">Privacy policy</a><a href="/terms-and-conditions">Terms &amp; conditions</a></div></div></div></footer>`;
const datedMarkup = markup.replace('id=\"year\"', `id=\"${yearId}\"`);
const withoutCurrent = datedMarkup.replace(/\saria-current=(['"])page\1/g, '');
const current = currentPath.replace(/\/+$/, '') || '/index.html';
const html = withoutCurrent.replace(new RegExp('(href=([\"\'])' + current + '\\2)', 'g'), '$1 aria-current=\"page\"');
const basedHtml = html.replace(/(href|src)=([\"\'])\/(?!\/)/g, '$1=$2' + base);
---
<Fragment set:html={basedHtml} />
