              class="btn6-outline"
              id="bkCloseOverlay"
              style="font-size: 0.8rem; padding: 0.6rem 1.2rem;"
              >Back to Interactive Preview</button
            >
          </div>
        </div>
      </div>
    </section>

    <!-- ─ FOOTER ──────────────────────────────────── -->
    <footer id="ft6" aria-label="Site footer">
      <div class="ft6-inner">
        <div class="ft6-brand">
          <div class="ft6-logo">Maid at Home</div>
          <p>
            Melbourne's trusted professional cleaning service. Trained, insured,
            and committed to consistent quality since 2019.
          </p>
        </div>
        <div class="ft6-col">
          <div class="ft6-col-title">Services</div>
          <a href={withBase("services/standard-cleaning")}>Standard Cleaning</a>
          <a href={withBase("services") + "#deep"}>Deep Cleaning</a>
          <a href={withBase("services") + "#eol"}>End of Lease</a>
          <a href={withBase("services") + "#movein"}>Move In Cleaning</a>
          <a href={withBase("services") + "#addons"}>Extras & Add-Ons</a>
        </div>
        <div class="ft6-col">
          <div class="ft6-col-title">Company</div>
          <a href={withBase("about")}>About Us</a>
          <a href={withBase("careers")}>Work with Us</a>
          <a href={withBase("blog")}>Blog</a>
          <a href={withBase("areas")}>Service Areas</a>
          <a href={withBase("index") + "#rec6"}>Recurring Cleaning</a>
          <a href={withBase("index") + "#calc6"}>Pricing Calculator</a>
        </div>
        <div class="ft6-col">
          <div class="ft6-col-title">Contact</div>
          <a href="tel:+61399990000">(03) 9999 0000</a>
          <a href="mailto:hello@maidathome.com.au">hello@maidathome.com.au</a>
          <a href={withBase("booking")}>Book Online</a>
        </div>
      </div>
      <div class="ft6-bottom">
        <span>© 2026 Maid at Home. All rights reserved.</span>
        <div class="ft6-bottom-links">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      /* ─ HEADER ───────────────────────────────────── */
      const hd6 = document.getElementById("hd6");
      const onScroll6 = () =>
        hd6.classList.toggle("scrolled", window.scrollY > 20);
      window.addEventListener("scroll", onScroll6, { passive: true });
      onScroll6();

      /* ─ MOBILE NAV ───────────────────────────────── */
      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      const cls6 = document.getElementById("hd6MobClose");
      tog6.addEventListener("click", () => {
        mob6.classList.add("open");
        tog6.setAttribute("aria-expanded", "true");
      });
      if (cls6) {
        cls6.addEventListener("click", () => {
          mob6.classList.remove("open");
          tog6.setAttribute("aria-expanded", "false");
        });
      }
      mob6
        .querySelectorAll("a")
        .forEach((a) =>
          a.addEventListener("click", () => mob6.classList.remove("open")),
        );

      /* ─ INTERACTIVE SIMULATION LOGIC ─────────────── */
      const bkService = document.getElementById("bk-service");
      const bkBeds = document.getElementById("bk-beds");
      const bkBaths = document.getElementById("bk-baths");
      const bkPriceVal = document.getElementById("bk-price-val");
      const bkFreqBtns = document.querySelectorAll(".bk-freq-btn");
      const bkNextStep = document.getElementById("bk-next-step");
      const bkToggleReal = document.getElementById("bkToggleReal");
      const bkCloseOverlay = document.getElementById("bkCloseOverlay");
      const bkIframeOverlay = document.getElementById("bkIframeOverlay");

      let currentDiscount = 15; // default weekly

      const calculatePrice = () => {
        let basePrice = 120;

        // Add service multiplier
        if (bkService.value === "deep") basePrice += 80;
        if (bkService.value === "eol") basePrice += 150;
        if (bkService.value === "oven") basePrice = 90;

        if (bkService.value !== "oven") {
          // Add bedroom price
          const beds = parseInt(bkBeds.value) || 0;
          basePrice += beds * 30;

          // Add bathroom price
          const baths = parseInt(bkBaths.value) || 0;
          basePrice += baths * 25;
        }

        // Apply frequency discount
        const discounted = basePrice * (1 - currentDiscount / 100);
        bkPriceVal.innerHTML = `$${discounted.toFixed(2)}<span style="font-size:0.75rem;color:var(--grey);font-weight:500;">/visit</span>`;
      };

      bkService.addEventListener("change", () => {
        const isOven = bkService.value === "oven";
        bkBeds.disabled = isOven;
        bkBaths.disabled = isOven;
        calculatePrice();
      });
      bkBeds.addEventListener("change", calculatePrice);
      bkBaths.addEventListener("change", calculatePrice);

      bkFreqBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          bkFreqBtns.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          currentDiscount = parseInt(btn.getAttribute("data-discount")) || 0;
          calculatePrice();
        });
      });

      bkNextStep.addEventListener("click", () => {
        alert(
          "Thank you! This interactive preview represents where your BookingKoala widget resides. Real integrations will process submissions directly inside the BookingKoala portal.",
        );
      });

      bkToggleReal.addEventListener("click", () => {
        bkIframeOverlay.classList.add("show");
      });
      bkCloseOverlay.addEventListener("click", () => {
        bkIframeOverlay.classList.remove("show");
      });

      calculatePrice();
    </script>
  </body>
</html>
