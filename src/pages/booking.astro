---
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Online — Maid at Home Melbourne</title>
    <meta
      name="description"
      content="Book your professional house cleaning service online in under 60 seconds. Choose your schedule, customize your checklist, and get instant pricing."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy: #0a1d33;
        --blue-d: #142d4c;
        --blue: #1d6fa8;
        --blue-l: #5aaee0;
        --blue-xl: #e8f4fd;
        --sky: #f0f7fd;
        --yellow: #f6c133;
        --yellow-d: #e0ab1d;
        --yellow-l: #fffbe6;
        --green: #16a34a;
        --green-l: #e8f7ee;
        --grey: #5e6a75;
        --grey-d: #2d3748;
        --grey-l: #e2e8f0;
        --white: #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover: rgba(29, 111, 168, 0.18);
        --shadow-sm: 0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md: 0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg: 0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium: 0 24px 60px rgba(10, 29, 51, 0.08);

        --font: "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s: 8px;
        --r: 12px;
        --r-l: 20px;
        --r-xl: 28px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img {
        display: block;
        max-width: 100%;
      }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.7s var(--ease),
          transform 0.7s var(--ease);
      }
      .si[data-d="l"] {
        transform: translateX(-24px);
      }
      .si[data-d="r"] {
        transform: translateX(24px);
      }
      .si.in {
        opacity: 1;
        transform: none;
      }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6 {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }
      .pad {
        padding: 6.5rem 0;
      }
      .pad-sm {
        padding: 4.5rem 0;
      }
      #booking-trust-bar + #booking-section {
        padding-top: 8rem;
      }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: "";
        width: 16px;
        height: 2.5px;
        background: var(--yellow);
        border-radius: 2px;
        flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--navy);
        line-height: 1.15;
      }
      h2.h6 .ac {
        color: var(--blue);
      }
      .lead6 {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed;
        inset: 0 0 auto;
        z-index: 200;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4vw;
        transition:
          background 0.3s var(--ease),
          box-shadow 0.3s var(--ease),
          height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px;
        border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
      }
      .hd6-mark {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: var(--blue);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark {
        background: var(--navy);
      }
      .hd6-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
      }
      .hd6-nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .hd6-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--grey-d);
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition:
          color 0.2s,
          background 0.2s;
      }
      .hd6-nav a:hover,
      .hd6-nav a.active {
        color: var(--blue);
        background: var(--sky);
      }
      .hd6-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.9rem;
        padding: 0.55rem 1.35rem;
        border-radius: 100px;
        text-decoration: none;
        margin-left: 0.75rem;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        white-space: nowrap;
      }
      .hd6-cta:hover {
        background: var(--yellow-d);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.35);
      }
      .hd6-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
        padding: 4px;
        z-index: 201;
      }
      .hd6-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--navy);
        border-radius: 2px;
        transition:
          transform 0.3s var(--ease),
          opacity 0.3s var(--ease);
      }

      #hd6.menu-open {
        background: var(--white) !important;
        box-shadow: none !important;
        border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important;
      }
      #hd6.menu-open .hd6-toggle span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      #hd6.menu-open .hd6-toggle span:nth-child(2) {
        opacity: 0;
      }
      #hd6.menu-open .hd6-toggle span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* Dropdown Menu Styles */
      .hd6-nav-item-dropdown {
        position: relative;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        width: 220px;
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 0.6rem;
        margin-top: 0.5rem;
        box-shadow: var(--shadow-lg);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.25s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: none;
      }
      .hd6-dropdown-menu a {
        display: block;
        padding: 0.65rem 0.85rem;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
        border-radius: 6px;
      }
      .hd6-dropdown-menu a:hover {
        background: var(--sky);
        color: var(--blue);
      }

      #hd6-mob {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 199;
        background: var(--white);
        flex-direction: column;
        padding: 6rem 2rem 2rem;
        gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open {
        display: flex;
      }
      #hd6-mob a {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-cta {
        background: var(--yellow);
        color: var(--navy);
        text-align: center;
        border-radius: var(--r);
        padding: 1.1rem;
        margin-top: 1rem;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        display: block;
      }
      .hd6-mob-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--grey);
        margin-top: 1.25rem;
        margin-bottom: 0.25rem;
      }
      .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 0.75rem;
        border-left: 2px solid var(--border-subtle);
      }
      .mob6-sub-menu a {
        font-size: 1rem;
        padding: 0.65rem 0;
        font-weight: 500;
        color: var(--grey-d);
        border: none;
      }

      /* Responsive Header Toggle */
      @media (max-width: 1024px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
      }

      /* ─── PAGE HERO ───────────────────────────── */
      #std-hero {
        background: var(--sky);
        padding-top: 72px;
        position: relative;
        overflow: hidden;
      }
      .std-hero-sun {
        position: absolute;
        top: -120px;
        right: -100px;
        width: 560px;
        height: 560px;
        border-radius: 50%;
        background: radial-gradient(
          ellipse at center,
          rgba(246, 193, 51, 0.14) 0%,
          rgba(246, 193, 51, 0.03) 60%,
          transparent 80%
        );
        pointer-events: none;
      }
      .std-hero-body {
        max-width: 1180px;
        margin: 0 auto;
        padding: 4rem 2.5rem 5rem;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .std-hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--blue);
        letter-spacing: 0.05em;
        margin-bottom: 1.75rem;
        width: fit-content;
        background: var(--white);
        padding: 0.4rem 0.9rem;
        border-radius: 100px;
        box-shadow: var(--shadow-sm);
        animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .std-hero-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--yellow);
        flex-shrink: 0;
      }
      .std-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.08;
        color: var(--navy);
        margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .std-hero-h1 .ac {
        color: var(--blue);
      }
      .std-hero-desc {
        font-size: 1.1rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 500px;
        margin-bottom: 2.25rem;
        animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .std-hero-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        animation: fadeUp 0.65s var(--ease) 0.4s both;
      }
      .std-hero-right {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        animation: fadeUp 0.8s var(--ease) 0.2s both;
      }

      /* Buttons styling from pricing page */
      .btn6-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.95rem 2rem;
        border-radius: 100px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover {
        background: var(--yellow-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4);
      }
      .btn6-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--navy);
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.9rem 1.75rem;
        border-radius: 100px;
        border: 1px solid var(--grey-l);
        background: transparent;
        text-decoration: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          border-color 0.25s,
          background 0.25s,
          color 0.25s;
      }
      .btn6-outline:hover {
        border-color: var(--navy);
        background: var(--sky);
      }

      .hero-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-subtle);
        animation: fadeUp 0.65s var(--ease) 0.5s both;
      }
      .ht-item {
        font-size: 0.78rem;
        color: var(--grey-d);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .ht-item::before {
        content: "✓";
        color: var(--green);
        font-weight: 700;
      }

      /* Hero right — Method Cards */
      .hmc {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 1.5rem 1.75rem;
        box-shadow: var(--shadow-sm);
        transition:
          background 0.3s var(--ease),
          border-color 0.3s var(--ease),
          transform 0.3s var(--ease),
          box-shadow 0.3s var(--ease);
      }
      .hmc:hover {
        background: var(--sky);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }
      .hmc-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
      }
      .hmc-badge {
        font-size: 0.68rem;
        font-weight: 800;
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .badge-blue {
        background: var(--blue-xl);
        color: var(--blue);
      }
      .badge-yellow {
        background: var(--yellow-l);
        color: var(--yellow-d);
      }
      .hmc-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }
      .hmc-desc {
        font-size: 0.82rem;
        color: var(--grey);
        line-height: 1.55;
      }
      .hmc-price {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.03em;
        margin-top: 0.875rem;
      }
      .hmc-price span {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--grey);
        margin-left: 0.2rem;
      }

      #booking-section {
        background: var(--white);
      }

      /* Booking Container / Iframe Container */
      .booking-widget-card {
        background: var(--white);
        border-radius: var(--r-xl);
        padding: 0.5rem;
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-premium);
        animation: fadeUp 0.8s var(--ease) 0.1s both;
        overflow: hidden;
        min-height: 600px;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      /* Simulated BookingKoala Widget */
      .bookingkoala-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #f2f5f8;
      }

      .bk-header {
        background: var(--navy);
        padding: 1.25rem 1.5rem;
        color: var(--white);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .bk-header h3 {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .bk-header span {
        font-size: 0.72rem;
        background: rgba(255, 255, 255, 0.15);
        padding: 0.25rem 0.6rem;
        border-radius: 100px;
        font-weight: 600;
      }

      .bk-steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        background: var(--sky);
        border-bottom: 1px solid var(--border-subtle);
        text-align: center;
        padding: 0.75rem 0;
      }
      .bk-step {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--grey);
      }
      .bk-step.active {
        color: var(--blue);
      }

      .bk-form {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        flex: 1;
      }

      .bk-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .bk-group label {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--navy);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .bk-group select,
      .bk-group input {
        font-family: var(--font);
        font-size: 0.9rem;
        color: var(--navy);
        padding: 0.8rem 1rem;
        border: 1px solid var(--grey-l);
        border-radius: var(--r);
        background: var(--sky);
        outline: none;
        transition:
          border-color 0.2s,
          background 0.2s;
      }
      .bk-group select:focus,
      .bk-group input:focus {
        border-color: var(--blue);
        background: var(--white);
      }

      .bk-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .bk-frequency-selector {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.5rem;
      }
      .bk-freq-btn {
        border: 1px solid var(--grey-l);
        background: var(--white);
        border-radius: var(--r);
        padding: 0.75rem 0.5rem;
        font-size: 0.76rem;
        font-weight: 700;
        color: var(--grey-d);
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
      }
      .bk-freq-btn.active {
        border-color: var(--blue);
        background: var(--blue-xl);
        color: var(--blue);
      }

      .bk-summary-box {
        margin-top: auto;
        background: var(--sky);
        border: 1px dashed var(--blue-l);
        border-radius: var(--r);
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .bk-summary-total {
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--navy);
      }
      .bk-summary-total span {
        font-size: 0.75rem;
        color: var(--grey);
        font-weight: 500;
      }

      .bk-btn-submit {
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.98rem;
        padding: 0.95rem;
        border-radius: 100px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        text-align: center;
        transition: all 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .bk-btn-submit:hover {
        background: var(--yellow-d);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(246, 193, 51, 0.3);
      }

      /* Real iframe fallback element code comment for user */
      .bk-iframe-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.92);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        text-align: center;
        z-index: 10;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s var(--ease);
      }
      .bk-iframe-overlay.show {
        opacity: 1;
        pointer-events: all;
      }
      .bk-iframe-overlay-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
      }
      .bk-iframe-overlay h4 {
        font-size: 1.15rem;
        color: var(--navy);
        font-weight: 800;
        margin-bottom: 0.5rem;
      }
      .bk-iframe-overlay p {
        font-size: 0.85rem;
        color: var(--grey);
        margin-bottom: 1.5rem;
        line-height: 1.5;
      }
      .bk-toggle-real {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-xl);
        border: none;
        border-radius: 6px;
        padding: 0.4rem 0.8rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
      }
      .bk-toggle-real:hover {
        background: var(--blue-l);
        color: var(--white);
      }

      #booking-trust-bar {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        box-shadow: 0 4px 25px rgba(10, 29, 51, 0.01);
        padding: 0.85rem 0;
        position: sticky;
        top: 64px;
        z-index: 150;
      }
      .trust-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }
      .trust-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: center;
      }
      .trust-icon-box {
        font-size: 1.1rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
      }
      .trust-text h4 {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--navy);
        line-height: 1.2;
        margin-bottom: 0.15rem;
      }
      .trust-text p {
        font-size: 0.78rem;
        color: var(--grey);
        line-height: 1.35;
      }

      /* ─── FOOTER ────────────────────────────────── */
      #ft6 {
        background: var(--navy);
        padding: 5rem 4vw 2.5rem;
        color: rgba(255, 255, 255, 0.9);
      }
      .ft6-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr repeat(3, 1fr);
        gap: 4rem 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-bottom: 4rem;
      }
      .ft6-brand {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        max-width: 320px;
      }
      .ft6-logo {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.02em;
      }
      .ft6-brand p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.7);
      }
      .ft6-col {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }
      .ft6-col-title {
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue-l);
        margin-bottom: 0.4rem;
      }
      .ft6-col a {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        transition: color 0.2s;
        width: fit-content;
      }
      .ft6-col a:hover {
        color: var(--yellow);
      }
      .ft6-bottom {
        max-width: 1180px;
        margin: 2rem auto 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.55);
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .ft6-bottom-links {
        display: flex;
        gap: 1.5rem;
      }
      .ft6-bottom a {
        color: rgba(255, 255, 255, 0.55);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ft6-bottom a:hover {
        color: var(--white);
      }

      /* Responsive Tweaks */
      @media (max-width: 1024px) {
        .std-hero-body {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .std-hero-right {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 1.5rem;
        }
      }
      @media (max-width: 991px) {
        .trust-inner {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }
        .ft6-inner {
          grid-template-columns: repeat(2, 1fr);
          gap: 3rem 2rem;
        }
      }
      @media (max-width: 768px) {
        .std-hero-body {
          padding: 4rem 1.5rem 3rem;
        }
        .std-hero-right {
          grid-template-columns: 1fr;
        }
        .ft6-bottom {
          flex-direction: column;
          text-align: center;
          gap: 1rem;
        }
      }
      @media (max-width: 580px) {
        .trust-inner {
          grid-template-columns: 1fr;
        }
        .ft6-inner {
          grid-template-columns: 1fr;
        }
        .std-hero-pill {
          margin-bottom: 1.25rem;
        }
        .c6 {
          padding: 0 1.5rem;
        }
        #booking-trust-bar {
          padding: 1.25rem 0;
        }
      }
      @media (max-width: 768px) {
        #booking-trust-bar + #booking-section {
          padding-top: 5.5rem;
        }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
        max-width: 1180px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 2.5rem !important;
        padding-right: 2.5rem !important;
      }
      @media (max-width: 768px) {
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
          padding-top: 4.5rem !important;
          padding-bottom: 4.5rem !important;
        }
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
    </style>
  </head>

