          author: { name: 'Stefania Ramirez', initials: 'SR', color: 'linear-gradient(135deg,#7c3aed,#4c1d95)' },
          imageUrl: null,
        },
        {
          _id: 'demo-4', featured: false,
          title: 'How Often Should You Deep Clean Your Melbourne Apartment?',
          slug: 'how-often-deep-clean-apartment', category: 'Deep Cleaning',
          publishedAt: '2026-04-14T09:00:00Z', readTime: 4,
          excerpt: 'The honest answer depends on your lifestyle. We break down the signs that your home needs more than a standard clean, and how to set a realistic schedule.',
          author: { name: 'Pau Rodriguez', initials: 'PR', color: 'linear-gradient(135deg,#1e4d78,#0a1d33)' },
