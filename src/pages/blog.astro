        },
        {
          _id: 'demo-5', featured: false,
          title: 'Cleaning Hardwood Floors: The Method That Won\'t Damage Your Timber',
          slug: 'cleaning-hardwood-floors', category: 'Cleaning Tips',
          publishedAt: '2026-04-02T09:00:00Z', readTime: 5,
