      ];

      async function loadPosts() {
        document.getElementById('loading-state').style.display = 'block';
        document.getElementById('featured-wrap').style.display = 'none';
        document.getElementById('posts-grid').style.display     = 'none';

        let posts = [];

        if (SANITY_PROJECT_ID === 'YOUR_PROJECT_ID') {
          await new Promise(r => setTimeout(r, 600));
          posts = DEMO_POSTS;
        } else {
          try {
            const res  = await fetch(SANITY_URL);
            const data = await res.json();
            posts = data.result || [];
            if (posts.length === 0) posts = DEMO_POSTS;
          } catch (err) {
            console.error('[Maid at Home Blog] Failed to fetch from Sanity:', err);
            posts = DEMO_POSTS;
          }
        }

        document.getElementById('loading-state').style.display  = 'none';
        document.getElementById('featured-wrap').style.display  = '';
        document.getElementById('posts-grid').style.display     = '';

        allPosts = posts;
        updateHeroCount(posts.length);
        buildCategories(posts);
        buildPopular(posts);
        buildFeatured(getFeaturedPost(posts));
        applyFilters();
      }

      let searchTimeout;
      document.getElementById('search-input').addEventListener('input', e => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          searchQuery = e.target.value.trim();
          applyFilters();
        }, 280);
      });

      document.getElementById('sort-select').addEventListener('change', e => {
        sortOrder = e.target.value;
        applyFilters();
      });

      document.getElementById('load-more-btn').addEventListener('click', () => {
        visibleCount += PAGE_SIZE;
        renderGrid();
        const cards = document.querySelectorAll('#posts-grid .post-card');
        if (cards[visibleCount - PAGE_SIZE]) {
          cards[visibleCount - PAGE_SIZE].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });

      const hd6 = document.getElementById("hd6");
      let headerScrollTicking6 = false;
      const updateHeaderScroll6 = () => {
        headerScrollTicking6 = false;
        if (hd6) {
          hd6.classList.toggle("scrolled", window.scrollY > 20);
        }
      };
      const onScroll6 = () => {
        if (headerScrollTicking6) return;
        headerScrollTicking6 = true;
        window.requestAnimationFrame(updateHeaderScroll6);
      };
      window.addEventListener("scroll", onScroll6, { passive: true });
      updateHeaderScroll6();

      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      tog6.addEventListener("click", () => {
        const isOpen = mob6.classList.toggle("open");
        hd6.classList.toggle("menu-open", isOpen);
        tog6.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });
      mob6.querySelectorAll("a").forEach(a => a.addEventListener("click", () => {
        mob6.classList.remove("open");
        hd6.classList.remove("menu-open");
        tog6.setAttribute("aria-expanded", "false");
      }));

      const sObs6 = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const items = Array.from(entry.target.querySelectorAll(".si")).filter(el => !el.classList.contains("in"));
          items.forEach((item, i) => setTimeout(() => item.classList.add("in"), i * 110));
          sObs6.unobserve(entry.target);
        });
      }, { threshold: 0.05, rootMargin: "0px 0px -20px 0px" });
      document.querySelectorAll(".sg").forEach(g => sObs6.observe(g));

      loadPosts();
    </script>
  </body>
</html>

