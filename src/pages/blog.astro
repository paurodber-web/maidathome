    <script is:inline define:vars={{ withBaseUrl: withBase("blog-post") }}>
      const SANITY_PROJECT_ID = 'YOUR_PROJECT_ID';
      const SANITY_DATASET    = 'production';
      const SANITY_API_VER    = '2024-01-01';
      const BASE_POST_URL     = withBaseUrl + "?slug=";

      const AUTHOR_COLOURS = {
        'Pau Rodriguez':      'linear-gradient(135deg,#1d6fa8,#0a1d33)',
        'Stefania Ramirez':   'linear-gradient(135deg,#7c3aed,#4c1d95)',
        'Maid at Home Team':  'linear-gradient(135deg,#1d6fa8,#142d4c)',
      };

      const GROQ_QUERY = encodeURIComponent(`
        *[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
          _id,
          title,
          "slug": slug.current,
          publishedAt,
          excerpt,
          category,
          readTime,
          featured,
          "author": author->{ name, initials, color },
          "imageUrl": mainImage.asset->url
        }
      `);

      const SANITY_URL = `https://${SANITY_PROJECT_ID}.api.sanity.io/v${SANITY_API_VER}/data/query/${SANITY_DATASET}?query=${GROQ_QUERY}`;

      let allPosts        = [];
      let filteredPosts   = [];
      let activeCategory  = 'all';
      let searchQuery     = '';
      let sortOrder       = 'date-desc';
      let visibleCount    = 6;
      const PAGE_SIZE     = 6;

      function initials(name = '') {
        return name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase() || 'M';
      }

      function fmtDate(iso) {
        if (!iso) return '—';
        return new Date(iso).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
      }

      function imgUrl(url, w = 800) {
        if (!url) return null;
        return `${url}?w=${w}&auto=format&q=80`;
      }

      const CAT_COLOURS = ['#1d6fa8','#7c3aed','#0a1d33','#16a34a','#e0ab1d','#dc2626','#db2777','#6366f1'];
      const catColourMap = {};
      function catColour(cat) {
        if (!catColourMap[cat]) {
          const keys = Object.keys(catColourMap);
          catColourMap[cat] = CAT_COLOURS[keys.length % CAT_COLOURS.length];
        }
        return catColourMap[cat];
      }

      function buildFeatured(post) {
        const a = document.getElementById('featured-post');
        const label = document.getElementById('featured-label');
        if (!post) { document.getElementById('featured-wrap').style.display = 'none'; return; }

        label.style.display = '';
        a.href = `${BASE_POST_URL}${post.slug}`;
        a.setAttribute('aria-label', post.title);

        const fpImg = document.getElementById('fp-image');
        if (post.imageUrl) {
          fpImg.innerHTML = `<img src="${imgUrl(post.imageUrl, 900)}" alt="${post.title}" loading="eager">`;
        } else {
          const emoji = categoryEmoji(post.category);
          fpImg.innerHTML = `
            <div class="fp-image-placeholder">
              <span class="ph-icon">${emoji}</span>
              <span class="ph-text">${post.category || 'Article'}</span>
            </div>`;
        }

        const colour = catColour(post.category || 'General');
        document.getElementById('fp-cat').innerHTML = `<span class="fp-cat-dot" style="background:${colour}"></span>${post.category || 'Article'}`;
        document.getElementById('fp-title').textContent   = post.title;
        document.getElementById('fp-excerpt').textContent = post.excerpt || '';
        document.getElementById('fp-date').textContent    = fmtDate(post.publishedAt);
        document.getElementById('fp-read').textContent    = post.readTime ? `${post.readTime} min read` : '';

        const authorName  = post.author?.name  || 'Maid at Home Team';
        const authorInits = post.author?.initials || initials(authorName);
        const authorCol   = post.author?.color || AUTHOR_COLOURS[authorName] || AUTHOR_COLOURS['Maid at Home Team'];
        document.getElementById('fp-author-name').textContent = authorName;
        const ava = document.getElementById('fp-avatar');
        ava.textContent = authorInits;
        ava.style.background = authorCol;
      }

      function buildPostCard(post) {
        const emoji   = categoryEmoji(post.category);
        const colour  = catColour(post.category || 'General');
        const authorName  = post.author?.name  || 'Maid at Home Team';
        const authorInits = post.author?.initials || initials(authorName);
        const authorCol   = post.author?.color || AUTHOR_COLOURS[authorName] || AUTHOR_COLOURS['Maid at Home Team'];

        const imgHtml = post.imageUrl
          ? `<img src="${imgUrl(post.imageUrl, 600)}" alt="${post.title}" loading="lazy">`
          : `<div class="pc-image-placeholder">${emoji}</div>`;

        return `
          <a href="${BASE_POST_URL}${post.slug}" class="post-card" role="listitem" aria-label="${post.title}">
            <div class="pc-image">${imgHtml}</div>
            <div class="pc-body">
              <div class="pc-cat" style="color:${colour}">${post.category || 'Article'}</div>
              <div class="pc-title">${post.title}</div>
              <div class="pc-excerpt">${post.excerpt || ''}</div>
              <div class="pc-meta">
                <div class="pc-meta-left">
                  <div class="pc-avatar" style="background:${authorCol}">${authorInits}</div>
                  <span class="pc-author">${authorName}</span>
                </div>
                <span class="pc-date">${fmtDate(post.publishedAt)}</span>
                ${post.readTime ? `<span class="pc-read">${post.readTime} min</span>` : ''}
              </div>
            </div>
          </a>`;
      }

      function buildPopularPost(post, rank) {
        return `
          <a href="${BASE_POST_URL}${post.slug}" class="sw-pop-post">
            <span class="sw-pop-num">${rank}</span>
            <div>
              <div class="sw-pop-title">${post.title}</div>
              <div class="sw-pop-meta">${post.category || 'Article'} · ${fmtDate(post.publishedAt)}</div>
            </div>
          </a>`;
      }

      function categoryEmoji(cat = '') {
        const map = {
          'Cleaning Tips':    '🧹',
          'Deep Cleaning':    '🔍',
          'Organisation':     '📦',
          'Eco Cleaning':     '♻️',
          'Melbourne':        '🌆',
          'Seasonal':         '🍂',
          'Kitchen':          '🍳',
          'Bathroom':         '🚿',
          'Move In / Out':    '📋',
          'Product Reviews':  '⭐',
        };
        return map[cat] || '📰';
      }

      function applyFilters() {
        let posts = [...allPosts];
        const featured = getFeaturedPost(allPosts);
        if (featured && activeCategory === 'all' && !searchQuery) {
          posts = posts.filter(p => p._id !== featured._id);
        }
        if (activeCategory !== 'all') {
          posts = posts.filter(p => p.category === activeCategory);
        }
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          posts = posts.filter(p =>
            p.title.toLowerCase().includes(q) ||
            (p.excerpt || '').toLowerCase().includes(q) ||
            (p.category || '').toLowerCase().includes(q)
          );
        }
        if (sortOrder === 'date-asc') {
          posts.sort((a,b) => new Date(a.publishedAt) - new Date(b.publishedAt));
        } else {
          posts.sort((a,b) => new Date(b.publishedAt) - new Date(a.publishedAt));
        }
        filteredPosts = posts;
        visibleCount  = PAGE_SIZE;
        renderGrid();
      }

      function renderGrid() {
        const grid  = document.getElementById('posts-grid');
        const empty = document.getElementById('empty-state');
        const lmBtn = document.getElementById('load-more-btn');
        const label = document.getElementById('post-count-label');

        if (filteredPosts.length === 0) {
          grid.innerHTML = '';
          empty.style.display = 'block';
          lmBtn.style.display = 'none';
          label.textContent = '0 articles';
          return;
        }

        empty.style.display = 'none';
        const slice = filteredPosts.slice(0, visibleCount);
        grid.innerHTML = slice.map(buildPostCard).join('');
        label.textContent = `${filteredPosts.length} article${filteredPosts.length !== 1 ? 's' : ''}`;

        if (visibleCount < filteredPosts.length) {
          lmBtn.style.display = 'inline-flex';
          lmBtn.textContent = `Load ${Math.min(PAGE_SIZE, filteredPosts.length - visibleCount)} more articles`;
          lmBtn.disabled = false;
        } else {
          lmBtn.style.display = 'none';
        }
      }

      function buildCategories(posts) {
        const counts = {};
        posts.forEach(p => {
          if (p.category) counts[p.category] = (counts[p.category] || 0) + 1;
        });

        const cats = [{ label: 'All', value: 'all', count: posts.length }];
        Object.entries(counts)
          .sort((a,b) => b[1] - a[1])
          .forEach(([k,v]) => cats.push({ label: k, value: k, count: v }));

        const fbarEl = document.getElementById('fbar-cats');
        fbarEl.innerHTML = cats.map(c => `
          <button class="fbar-cat${c.value === 'all' ? ' active' : ''}" role="tab" aria-selected="${c.value === 'all'}" data-cat="${c.value}">
            ${c.label}
            <span class="fbar-cat-count">${c.count}</span>
          </button>`).join('');

        fbarEl.querySelectorAll('.fbar-cat').forEach(btn => {
          btn.addEventListener('click', () => {
            activeCategory = btn.dataset.cat;
            fbarEl.querySelectorAll('.fbar-cat').forEach(b => {
              b.classList.remove('active'); b.setAttribute('aria-selected','false');
            });
            btn.classList.add('active'); btn.setAttribute('aria-selected','true');
            syncSidebarCats();
            applyFilters();
          });
        });

        const sbarEl = document.getElementById('sidebar-cats');
        sbarEl.innerHTML = cats.map(c => `
          <button class="sw-cat-btn${c.value === 'all' ? ' active' : ''}" data-cat="${c.value}">
            ${c.label}
            <span class="sw-cat-count">${c.count}</span>
          </button>`).join('');

        sbarEl.querySelectorAll('.sw-cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            activeCategory = btn.dataset.cat;
            syncFbarCats();
            syncSidebarCats();
            applyFilters();
            document.getElementById('posts-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        });

        const heroEl = document.getElementById('hero-cats-list');
        heroEl.innerHTML = cats.slice(1).map(c => `
          <button class="hero-cat-btn" data-cat="${c.value}">
            <span>${categoryEmoji(c.value)} ${c.label}</span>
            <span class="hcb-count">${c.count}</span>
          </button>`).join('');
        heroEl.querySelectorAll('.hero-cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            activeCategory = btn.dataset.cat;
            syncFbarCats(); syncSidebarCats(); applyFilters();
            document.getElementById('blog-main').scrollIntoView({ behavior: 'smooth' });
          });
        });
      }

      function syncFbarCats() {
        document.querySelectorAll('.fbar-cat').forEach(b => {
          const on = b.dataset.cat === activeCategory;
          b.classList.toggle('active', on);
          b.setAttribute('aria-selected', on);
        });
      }
      
      function syncSidebarCats() {
        document.querySelectorAll('.sw-cat-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.cat === activeCategory);
        });
      }

      function getFeaturedPost(posts) {
        return posts.find(p => p.featured) || posts[0] || null;
      }

      function buildPopular(posts) {
        const popular = [...posts].slice(0, 5);
        const el = document.getElementById('sidebar-popular');
        el.innerHTML = popular.length
          ? popular.map((p,i) => buildPopularPost(p, i+1)).join('')
          : '<p style="font-size:0.82rem;color:var(--grey-400)">No articles yet.</p>';
      }

      function updateHeroCount(n) {
        document.getElementById('hero-count-text').textContent =
          n === 0 ? 'No articles yet — check back soon'
          : `${n} article${n !== 1 ? 's' : ''} published`;
      }

      const DEMO_POSTS = [
        {
          _id: 'demo-1', featured: true,
          title: 'The 10-Minute Tidy: How to Keep Your Home Clean Between Professional Visits',
          slug: 'ten-minute-tidy', category: 'Cleaning Tips',
