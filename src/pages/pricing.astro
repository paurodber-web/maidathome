        <span>© 2025 Maid at Home. All rights reserved.</span>
        <div style="display:flex; gap:1.5rem;">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      /* ─ HEADER ────────────────────────────────────── */
      const hd6 = document.getElementById("hd6");
      let headerScrollTicking6 = false;
      const updateHeaderScroll6 = () => {
        headerScrollTicking6 = false;
        if (hd6) {
          hd6.classList.toggle("scrolled", window.scrollY > 20);
        }
      };
      const onScroll6 = () => {
        if (headerScrollTicking6) return;
        headerScrollTicking6 = true;
        window.requestAnimationFrame(updateHeaderScroll6);
      };
      window.addEventListener("scroll", onScroll6, { passive: true });
      updateHeaderScroll6();

            /* ─ MOBILE NAV / MENU ────────────────────────── */
      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      const cls6 = document.getElementById("hd6MobClose");
      
      if (tog6 && mob6) {
        tog6.addEventListener("click", () => {
          const isOpen = mob6.classList.toggle("open");
          if (hd6) hd6.classList.toggle("menu-open", isOpen);
          tog6.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });
      }
      
      if (cls6 && mob6 && tog6) {
        cls6.addEventListener("click", () => {
          mob6.classList.remove("open");
          if (hd6) hd6.classList.remove("menu-open");
          tog6.setAttribute("aria-expanded", "false");
        });
      }
      
      if (mob6) {
        mob6.querySelectorAll("a").forEach(a => {
          a.addEventListener("click", () => {
            mob6.classList.remove("open");
            if (hd6) hd6.classList.remove("menu-open");
            if (tog6) tog6.setAttribute("aria-expanded", "false");
          });
        });
      }

      /* ─ MOBILE DROPDOWN ACCORDION ────────────────── */
      if (mob6) {
        mob6.querySelectorAll('.mob6-dropdown-toggle').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const targetId = btn.getAttribute('data-target');
            const submenu = document.getElementById(targetId);
            if (submenu) {
              const isCollapsed = submenu.classList.contains('collapsed');
              if (isCollapsed) {
                submenu.classList.remove('collapsed');
                btn.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
              } else {
                submenu.classList.add('collapsed');
                btn.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
              }
            }
          });
        });
      }

      /* ─ STAGGER OBSERVER ──────────────────────────── */
      const sObs6 = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const items = Array.from(
              entry.target.querySelectorAll(".si"),
            ).filter((el) => !el.classList.contains("in"));
            items.forEach((item, i) =>
              setTimeout(() => item.classList.add("in"), i * 110),
            );
            sObs6.unobserve(entry.target);
          });
        },
        { threshold: 0.05, rootMargin: "0px 0px -20px 0px" },
      );
      document.querySelectorAll(".sg").forEach((g) => sObs6.observe(g));

      /* ─ FAQ accordion logic ───────────────────────── */
      document.querySelectorAll(".faq6-item").forEach((item) => {
        item.querySelector(".faq6-q").addEventListener("click", () => {
          const open = item.classList.contains("open");
          document.querySelectorAll(".faq6-item.open").forEach((o) => {
            o.classList.remove("open");
            o.querySelector(".faq6-q").setAttribute("aria-expanded", "false");
          });
          if (!open) {
            item.classList.add("open");
            item.querySelector(".faq6-q").setAttribute("aria-expanded", "true");
          }
        });
      });

      /* ─ Active pricing nav link logic ──────────────── */
      const pnavLinks = document.querySelectorAll(".pnav-link");
      const pnavSections = [
        "methods",
        "flat-rate",
        "hourly",
        "estimate",
        "addons",
        "faq6",
      ].map((id) => document.getElementById(id));
      let pnavSectionsOffsets = [];
      let lastActiveIndex = -1;
      let pnavSectionsScrollTicking = false;
      let pnavSectionsResizeTicking = false;

      const measurePnavSections6 = () => {
        pnavSectionsResizeTicking = false;
        pnavSectionsOffsets = pnavSections.map((sec) => (sec ? sec.offsetTop : 0));
      };

      const updatePnavSections6 = () => {
        pnavSectionsScrollTicking = false;
        const offset = window.scrollY > 20 ? 64 : 72;
        const scrollY = window.scrollY + offset + 48 + 40;
        let current = 0;
        pnavSectionsOffsets.forEach((secTop, i) => {
          if (secTop <= scrollY) current = i;
        });
        if (current === lastActiveIndex) return;
        lastActiveIndex = current;
        pnavLinks.forEach((l, i) => l.classList.toggle("active", i === current));
      };

      const onPnavSectionsScroll6 = () => {
        if (pnavSectionsScrollTicking) return;
        pnavSectionsScrollTicking = true;
        window.requestAnimationFrame(updatePnavSections6);
      };

      const onPnavSectionsResize6 = () => {
        if (pnavSectionsResizeTicking) return;
        pnavSectionsResizeTicking = true;
        window.requestAnimationFrame(() => {
          measurePnavSections6();
          updatePnavSections6();
        });
      };

      window.addEventListener("scroll", onPnavSectionsScroll6, { passive: true });
      window.addEventListener("resize", onPnavSectionsResize6, { passive: true });
      window.addEventListener("load", onPnavSectionsResize6, { once: true });
      measurePnavSections6();
      updatePnavSections6();

      /* ─ Interactive Calculator Logic ───────────────── */
      const cs = {
        model: "flat",
        freq: "once",
        beds: 2,
        hours: 2.5,
        extras: 0,
      };
      const flatBase = { 1: 149, 2: 189, 3: 239, 4: 299 };
      const disc = { once: 0, weekly: 0.1, fortnightly: 0.1, monthly: 0.05 };
      const hourlyBase = 55;

      function calcTotal() {
        let base = 0;
        if (cs.model === "flat") {
          const bedKey = Math.min(cs.beds, 4);
          base = flatBase[bedKey] + (cs.beds > 4 ? (cs.beds - 4) * 30 : 0);
        } else {
          base = cs.hours * hourlyBase;
        }
        return Math.round((base + cs.extras) * (1 - disc[cs.freq]));
      }

      function renderCalc() {
        const total = calcTotal();
        document.getElementById("calc-out").textContent = total;
        const isHourly = cs.model === "hourly";
        document.getElementById("cr-lbl").textContent = isHourly
          ? "Estimated total (hourly)"
          : "Estimated total (flat rate)";
        const discText =
          disc[cs.freq] > 0
            ? ` · ${(disc[cs.freq] * 100).toFixed(0)}% recurring discount applied`
            : "";
        document.getElementById("cr-note").textContent =
          "Indicative · Confirmed at booking" + discText;
      }

      // Model Switch
      const modelFlatBtn = document.getElementById("calc-model-flat");
      const modelHourlyBtn = document.getElementById("calc-model-hourly");
      const bedsGroup = document.getElementById("beds-group");
      const hoursGroup = document.getElementById("hours-group");

      modelFlatBtn.addEventListener("click", () => {
        modelFlatBtn.classList.add("on");
        modelHourlyBtn.classList.remove("on");
        cs.model = "flat";
        bedsGroup.style.display = "";
        hoursGroup.style.display = "none";
        renderCalc();
      });

      modelHourlyBtn.addEventListener("click", () => {
        modelHourlyBtn.classList.add("on");
        modelFlatBtn.classList.remove("on");
        cs.model = "hourly";
        bedsGroup.style.display = "none";
        hoursGroup.style.display = "";
        renderCalc();
      });

      // Frequency Switch
      ["once", "weekly", "fortnightly", "monthly"].forEach((f) => {
        const btn = document.getElementById(`freq-${f}`);
        btn.addEventListener("click", () => {
          ["once", "weekly", "fortnightly", "monthly"].forEach((item) => {
            document.getElementById(`freq-${item}`).classList.remove("on");
          });
          btn.classList.add("on");
          cs.freq = f;
          renderCalc();
        });
      });

      // Beds steppers
      const bedsV = document.getElementById("beds-v");
      document.getElementById("beds-dec").addEventListener("click", () => {
        cs.beds = Math.max(cs.beds - 1, 1);
        bedsV.textContent = cs.beds;
        renderCalc();
      });
      document.getElementById("beds-inc").addEventListener("click", () => {
        cs.beds = Math.min(cs.beds + 1, 8);
        bedsV.textContent = cs.beds;
        renderCalc();
      });

      // Hours steppers
      const hoursV = document.getElementById("hours-v");
      document.getElementById("hours-dec").addEventListener("click", () => {
        cs.hours = Math.max(cs.hours - 0.5, 2);
        hoursV.textContent = cs.hours;
        renderCalc();
      });
      document.getElementById("hours-inc").addEventListener("click", () => {
        cs.hours = Math.min(cs.hours + 0.5, 10);
        hoursV.textContent = cs.hours;
        renderCalc();
      });

      // Extras toggling
      document.querySelectorAll(".c-extra").forEach((el) => {
        const price = parseInt(el.getAttribute("data-price") || "0", 10);
        el.addEventListener("click", () => {
          el.classList.toggle("on");
          const on = el.classList.contains("on");
          el.setAttribute("aria-checked", on);
          cs.extras += on ? price : -price;
          renderCalc();
        });
        el.addEventListener("keypress", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            el.click();
          }
        });
      });

      // Add-on cards add buttons visual feedback
      document.querySelectorAll(".addon-add-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const orig = btn.textContent;
          btn.textContent = "✓ Added";
          btn.style.background = "#16a34a";
          btn.style.color = "#fff";
          setTimeout(() => {
            btn.textContent = orig;
            btn.style.background = "";
            btn.style.color = "";
          }, 2000);
        });
      });
    </script>
  </body>
</html>

