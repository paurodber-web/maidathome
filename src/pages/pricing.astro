    <!-- ─ FOOTER ──────────────────────────────────── -->
    <footer id="ft6" aria-label="Site footer">
      <div class="ft6-inner">
        <div class="ft6-brand">
          <div class="ft6-logo">Maid at Home</div>
          <p>
            Melbourne's trusted professional cleaning service. Trained, insured,
            and committed to consistent quality since 2019.
          </p>
        </div>
        <div class="ft6-col">
          <div class="ft6-col-title">Services</div>
          <a href={withBase("services/standard-cleaning")}>Standard Cleaning</a>
          <a href={withBase("services/deep-cleaning")}>Deep Cleaning</a>
          <a href={withBase("services/end-of-lease-cleaning")}>End of Lease</a>
          <a href={withBase("services/move-in-cleaning")}>Move In Cleaning</a>
          <a href={withBase("services/oven-cleaning")}>Oven Cleaning</a>
          <a href={withBase("carpet-cleaning")}>Carpet Cleaning</a>
        </div>
        <div class="ft6-col">
          <div class="ft6-col-title">Company</div>
          <a href={withBase("about")}>About Us</a>
          <a href={withBase("careers")}>Work with Us</a>
        <a href={withBase("blog")}>Blog</a>
          <a href={withBase("areas")}>Service Areas</a>
          <a href={withBase("index") + "#rec6"}>Recurring Cleaning</a>
          <a href={withBase("index") + "#calc6"}>Pricing Calculator</a>
        </div>
