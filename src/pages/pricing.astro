              <p class="eyebrow6">Ready to start?</p>
              <h2 class="h6" id="cta6-h2">
                Ready to experience<br /><span class="ac">the difference?</span>
              </h2>
            </div>
            <p class="cta6-sub si">
              Join over 2,400 Melbourne households who trust Maid at Home.
              Transparent pricing, consistent results, and no lock-in contracts.
            </p>
            <div class="cta6-actions si">
              <a
                href={withBase("index") + "#calc6"}
