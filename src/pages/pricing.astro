---
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Transparent Rates & Pricing — Maid at Home Melbourne</title>
    <meta
      name="description"
      content="Clear, upfront pricing for every house cleaning service in Melbourne. Choose between fixed flat rate or flexible hourly rate. No hidden fees."
    />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy: #0a1d33;
        --blue-d: #142d4c;
        --blue: #1d6fa8;
        --blue-l: #5aaee0;
        --blue-xl: #e8f4fd;
        --sky: #f0f7fd;
        --yellow: #f6c133;
        --yellow-d: #e0ab1d;
        --yellow-l: #fffbe6;
        --green: #16a34a;
        --green-l: #e8f7ee;
        --grey: #5e6a75;
        --grey-d: #2d3748;
        --grey-l: #e2e8f0;
        --white: #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover: rgba(29, 111, 168, 0.18);
        --shadow-sm: 0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md: 0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg: 0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium: 0 24px 60px rgba(10, 29, 51, 0.08);

        --font: "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s: 8px;
        --r: 12px;
        --r-l: 20px;
        --r-xl: 28px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 120px; /* Offset for fixed header + sticky nav */
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img {
        display: block;
        max-width: 100%;
      }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes floatY {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-5px);
        }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.7s var(--ease),
          transform 0.7s var(--ease);
      }
      .si[data-d="l"] {
        transform: translateX(-24px);
      }
      .si[data-d="r"] {
        transform: translateX(24px);
      }
      .si.in {
        opacity: 1;
        transform: none;
      }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6 {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }
      .pad {
        padding: 6.5rem 0;
      }
      .pad-sm {
        padding: 4.5rem 0;
      }
      #pricing-nav + #methods {
        padding-top: 8rem;
      }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: "";
        width: 16px;
        height: 2.5px;
        background: var(--yellow);
        border-radius: 2px;
        flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--navy);
        line-height: 1.15;
      }
      h2.h6 .ac {
        color: var(--blue);
      }
      .lead6 {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 520px;
        margin-top: 0.75rem;
      }
      .sec-header6 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: end;
        margin-bottom: 4rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.95rem 2rem;
        border-radius: 100px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover {
        background: var(--yellow-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4);
      }
      .btn6-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--navy);
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.9rem 1.75rem;
        border-radius: 100px;
        border: 1px solid var(--grey-l);
        background: transparent;
        text-decoration: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          border-color 0.25s,
          background 0.25s,
          color 0.25s;
      }
      .btn6-outline:hover {
        border-color: var(--navy);
        background: var(--sky);
      }

      .btn6-outline-dark {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: transparent;
        color: var(--blue);
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.85rem 1.5rem;
        border-radius: 100px;
        border: 1.5px solid var(--grey-l);
        text-decoration: none;
        cursor: pointer;
        transition:
          color 0.25s,
          border-color 0.25s,
          background 0.25s;
        white-space: nowrap;
        font-family: var(--font);
      }
      .btn6-outline-dark:hover {
        color: var(--navy);
        border-color: var(--blue);
        background: var(--sky);
      }

      .btn6-ghost-dark {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: transparent;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 100px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        padding: 0.9rem 1.75rem;
        text-decoration: none;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          color 0.25s,
          border-color 0.25s,
          background 0.25s;
      }
      .btn6-ghost-dark:hover {
        color: var(--white);
        border-color: rgba(255, 255, 255, 0.4);
        background: rgba(255, 255, 255, 0.06);
      }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed;
        inset: 0 0 auto;
        z-index: 200;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4vw;
        transition:
          background 0.3s var(--ease),
          box-shadow 0.3s var(--ease),
          height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px;
        border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
      }
      .hd6-mark {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: var(--blue);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark {
        background: var(--navy);
      }
      .hd6-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
      }
      .hd6-nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .hd6-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--grey-d);
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition:
          color 0.2s,
          background 0.2s;
      }
      .hd6-nav a:hover,
      .hd6-nav a.active {
        color: var(--blue);
        background: var(--sky);
      }
      .hd6-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.9rem;
        padding: 0.55rem 1.35rem;
        border-radius: 100px;
        text-decoration: none;
        margin-left: 0.75rem;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        white-space: nowrap;
      }
      .hd6-cta:hover {
        background: var(--yellow-d);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.35);
      }
      .hd6-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
        padding: 4px;
        z-index: 201;
      }
      .hd6-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--navy);
        border-radius: 2px;
        transition:
          transform 0.3s var(--ease),
          opacity 0.3s var(--ease);
      }

      #hd6.menu-open {
        background: var(--white) !important;
        box-shadow: none !important;
        border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important;
      }
      #hd6.menu-open .hd6-toggle span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      #hd6.menu-open .hd6-toggle span:nth-child(2) {
        opacity: 0;
      }
      #hd6.menu-open .hd6-toggle span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      #hd6-mob {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 199;
        background: var(--white);
        flex-direction: column;
        padding: 6rem 2rem 2rem;
        gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open {
        display: flex;
      }
      #hd6-mob a {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-cta {
        background: var(--yellow);
        color: var(--navy);
        text-align: center;
        border-radius: var(--r);
        padding: 1.1rem;
        margin-top: 1rem;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        display: block;
      }

      /* ─── PAGE HERO ───────────────────────────── */
      #pricing-hero {
        background: var(--sky);
        padding-top: 72px;
        position: relative;
        overflow: hidden;
      }
      .pricing-hero-sun {
        position: absolute;
        top: -120px;
        right: -100px;
        width: 560px;
        height: 560px;
        border-radius: 50%;
        background: radial-gradient(
          ellipse at center,
          rgba(246, 193, 51, 0.14) 0%,
          rgba(246, 193, 51, 0.03) 60%,
          transparent 80%
        );
        pointer-events: none;
      }
      .pricing-hero-body {
        max-width: 1180px;
        margin: 0 auto;
        padding: 4rem 2.5rem 5rem;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .pricing-hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--blue);
        letter-spacing: 0.05em;
        margin-bottom: 1.75rem;
        width: fit-content;
        background: var(--white);
        padding: 0.4rem 0.9rem;
        border-radius: 100px;
        box-shadow: var(--shadow-sm);
        animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .pricing-hero-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--yellow);
        flex-shrink: 0;
      }
      .pricing-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.08;
        color: var(--navy);
        margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .pricing-hero-h1 .ac {
        color: var(--blue);
      }
      .pricing-hero-sub {
        font-size: 1.1rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 500px;
        margin-bottom: 2.25rem;
        animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .pricing-hero-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        animation: fadeUp 0.65s var(--ease) 0.4s both;
      }
      .pricing-hero-right {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        animation: fadeUp 0.8s var(--ease) 0.2s both;
      }

      .ph-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--grey);
        margin-bottom: 1.5rem;
      }
      .ph-breadcrumb a {
        color: var(--grey);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ph-breadcrumb a:hover {
        color: var(--blue);
      }
      .ph-breadcrumb span {
        color: var(--grey-l);
      }

      .hero-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-subtle);
        animation: fadeUp 0.65s var(--ease) 0.5s both;
      }
      .ht-item {
        font-size: 0.78rem;
        color: var(--grey-d);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .ht-item::before {
        content: "✓";
        color: var(--green);
        font-weight: 700;
      }

      /* Hero right — Method Cards */
      .hmc {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 1.5rem 1.75rem;
        box-shadow: var(--shadow-sm);
        transition:
          background 0.3s var(--ease),
          border-color 0.3s var(--ease),
          transform 0.3s var(--ease),
          box-shadow 0.3s var(--ease);
      }
      .hmc:hover {
        background: var(--sky);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }
      .hmc-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
      }
      .hmc-badge {
        font-size: 0.68rem;
        font-weight: 800;
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .badge-blue {
        background: var(--blue-xl);
        color: var(--blue);
      }
      .badge-yellow {
        background: var(--yellow-l);
        color: var(--yellow-d);
      }
      .hmc-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }
      .hmc-desc {
        font-size: 0.82rem;
        color: var(--grey);
        line-height: 1.55;
      }
      .hmc-price {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.03em;
        margin-top: 0.875rem;
      }
      .hmc-price span {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--grey);
        margin-left: 0.2rem;
      }

      #pricing-nav {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 64px;
        z-index: 150;
      }
      .pnav-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pnav-inner::-webkit-scrollbar {
        display: none;
      }
      .pnav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--grey);
        padding: 1.1rem 1.15rem;
        text-decoration: none;
        white-space: nowrap;
        border-bottom: 3px solid transparent;
        margin-bottom: -1px;
        transition:
          color 0.25s,
          border-color 0.25s;
      }
      .pnav-link:hover {
        color: var(--blue);
      }
      .pnav-link.active {
        color: var(--blue);
        border-bottom-color: var(--blue);
        font-weight: 700;
      }

      /* ─── SCROLL TARGET ADJUSTMENTS ───────────── */
      #methods, #flat-rate, #hourly, #estimate, #addons, #faq6 {
        padding-top: 3rem;
      }

      /* ─── METHODS SECTION ──────────────────────── */
      #methods {
        background: var(--white);
      }
      .methods-intro {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 3.5rem;
      }
      .methods-intro h2 {
        margin-bottom: 1rem;
      }
      .methods-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }

      .method-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
          border-color 0.4s var(--ease),
          box-shadow 0.4s var(--ease),
          transform 0.4s var(--ease);
      }
      .method-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-lg);
        transform: translateY(-4px);
      }
      .method-card.featured {
        background: var(--navy);
        border-color: var(--navy);
      }
      .method-card.featured:hover {
        box-shadow: var(--shadow-premium);
      }
      .method-card-top {
        padding: 2.5rem 2.5rem 2rem;
        flex: 1;
      }
      .method-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        transition: background 0.25s;
      }
      .method-card:hover .method-icon {
        background: var(--blue-xl);
      }
      .method-card.featured .method-icon {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.08);
      }

      .method-label {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.5rem;
      }
      .method-card.featured .method-label {
        color: var(--blue-l);
      }

      .method-card-top h3 {
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
        margin-bottom: 0.85rem;
        line-height: 1.25;
      }
      .method-card.featured .method-card-top h3 {
        color: var(--white);
      }

      .method-card-top p {
        font-size: 0.92rem;
        color: var(--grey);
        line-height: 1.7;
      }
      .method-card.featured .method-card-top p {
        color: rgba(255, 255, 255, 0.55);
      }

      .method-tag-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }
      .method-tag {
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        color: var(--blue);
      }
      .method-card.featured .method-tag {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.6);
      }

      .method-card-bottom {
        padding: 2rem 2.5rem 2.5rem;
        background: var(--sky);
        border-top: 1px solid var(--border-subtle);
      }
      .method-card.featured .method-card-bottom {
        background: rgba(255, 255, 255, 0.02);
        border-top-color: rgba(255, 255, 255, 0.05);
      }

      .method-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.75rem;
      }
      .method-li {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        font-size: 0.85rem;
        color: var(--grey-d);
        line-height: 1.5;
      }
      .method-li::before {
        content: "✓";
        color: var(--green);
        font-weight: 800;
        font-size: 0.85rem;
        flex-shrink: 0;
      }
      .method-card.featured .method-li {
        color: rgba(255, 255, 255, 0.65);
      }
      .method-card.featured .method-li::before {
        color: var(--yellow);
      }

      .method-rec {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.75rem;
      }
      .method-card.featured .method-rec {
        background: rgba(246, 193, 51, 0.05);
        border-color: rgba(246, 193, 51, 0.15);
      }
      .method-rec-label {
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--grey);
        margin-bottom: 0.3rem;
      }
      .method-card.featured .method-rec-label {
        color: rgba(255, 255, 255, 0.4);
      }
      .method-rec-text {
        font-size: 0.83rem;
        color: var(--grey-d);
        line-height: 1.5;
      }
      .method-card.featured .method-rec-text {
        color: rgba(255, 255, 255, 0.7);
      }

      /* ─── FLAT RATE SECTION ────────────────────── */
      #flat-rate {
        background: var(--sky);
      }
      .flat-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
      }
      .flat-card {
        background: var(--white);
        padding: 2.25rem 1.75rem;
        display: flex;
        flex-direction: column;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        transition:
          transform 0.4s var(--ease),
          border-color 0.4s var(--ease),
          box-shadow 0.4s var(--ease);
        position: relative;
      }
      .flat-card:hover {
        transform: translateY(-5px);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-lg);
      }
      .flat-card.popular {
        border-color: var(--yellow);
        box-shadow: 0 8px 30px rgba(246, 193, 51, 0.1);
      }
      .flat-card.popular:hover {
        box-shadow: 0 16px 48px rgba(246, 193, 51, 0.2);
      }

      .flat-pop-badge {
        position: absolute;
        top: -11px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--yellow);
        color: var(--navy);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.25rem 0.85rem;
        border-radius: 100px;
        box-shadow: var(--shadow-sm);
        white-space: nowrap;
      }
      .flat-beds {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.35rem;
      }
      .flat-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 1.25rem;
        letter-spacing: -0.01em;
      }
      .flat-price {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.05em;
        line-height: 1;
      }
      .flat-price sup {
        font-size: 1.1rem;
        font-weight: 600;
        vertical-align: top;
        margin-top: 0.2rem;
        display: inline-block;
      }
      .flat-per {
        font-size: 0.75rem;
        color: var(--grey);
        margin-top: 0.25rem;
        font-weight: 600;
      }
      .flat-divider {
        height: 1px;
        background: var(--border-subtle);
        margin: 1.5rem 0;
      }
      .flat-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
      }
      .flat-det {
        font-size: 0.82rem;
        color: var(--grey);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .flat-det::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--blue);
        flex-shrink: 0;
      }
      .flat-cta {
        margin-top: 1.75rem;
      }

      .flat-btn {
        display: block;
        text-align: center;
        padding: 0.75rem;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        background: var(--sky);
        color: var(--navy);
        border: 1px solid var(--border-subtle);
      }
      .flat-btn:hover {
        background: var(--blue-xl);
        border-color: var(--blue);
        color: var(--blue);
      }
      .flat-card.popular .flat-btn {
        background: var(--yellow);
        color: var(--navy);
        border-color: transparent;
      }
      .flat-card.popular .flat-btn:hover {
        background: var(--yellow-d);
      }

      /* Frequency cards */
      .freq-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        margin-top: 1.5rem;
      }
      .freq-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.5rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition:
          transform 0.3s var(--ease),
          border-color 0.3s var(--ease),
          box-shadow 0.3s var(--ease);
        position: relative;
      }
      .freq-card:hover {
        transform: translateY(-3px);
        border-color: var(--blue-l);
        box-shadow: var(--shadow-md);
      }
      .freq-card.featured {
        border-color: var(--blue);
        background: var(--blue-xl);
      }
      .freq-card.featured::before {
        content: "Popular";
        position: absolute;
        top: -10px;
        font-size: 0.62rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: var(--blue);
        color: var(--white);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
      }
      .freq-card.featured-weekly::before {
        content: "Best Value";
        background: var(--green);
      }
      .freq-card.featured-weekly {
        border-color: var(--green);
        background: var(--green-l);
      }
      .freq-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.2rem;
      }
      .freq-cadence {
        font-size: 0.75rem;
        color: var(--grey);
        margin-bottom: 0.75rem;
      }
      .freq-disc-val {
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--green);
        letter-spacing: -0.02em;
        margin-bottom: 0.15rem;
      }
      .freq-disc-val.none {
        color: var(--grey);
      }
      .freq-disc-lbl {
        font-size: 0.72rem;
        color: var(--grey);
        font-weight: 600;
      }
      .freq-badge-note {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--green);
        background: var(--green-l);
        padding: 0.3rem 0.85rem;
        border-radius: 100px;
      }

      /* ─── HOURLY SECTION ───────────────────────── */
      #hourly {
        background: var(--white);
        border-bottom: 1px solid var(--border-subtle);
        position: relative;
        overflow: hidden;
      }
      .hourly-layout {
        display: grid;
        grid-template-columns: 5.5fr 6.5fr;
        gap: 5rem;
        align-items: start;
        position: relative;
        z-index: 1;
      }
      .hourly-intro p.lead {
        margin-top: 0.75rem;
        margin-bottom: 2rem;
      }
      .hourly-note {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
      }
      .hourly-note p {
        font-size: 0.85rem;
        color: var(--grey);
        line-height: 1.6;
      }
      .hourly-note strong {
        display: block;
        color: var(--navy);
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
      }

      .hourly-min-note {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        background: var(--yellow-l);
        border: 1px solid rgba(246, 193, 51, 0.35);
        border-radius: var(--r);
        padding: 1.1rem 1.25rem;
      }
      .hourly-min-note p {
        font-size: 0.83rem;
        color: var(--grey-d);
        line-height: 1.6;
      }
      .hourly-min-note strong {
        color: var(--yellow-d);
        font-weight: 700;
      }

      .hourly-right {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .hourly-rate-main {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 2.25rem;
      }
      .hrm-label {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.5rem;
      }
      .hrm-rate {
        font-size: 3.2rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.05em;
        line-height: 1;
      }
      .hrm-rate sup {
        font-size: 1.35rem;
        font-weight: 600;
        vertical-align: top;
        margin-top: 0.4rem;
        display: inline-block;
      }
      .hrm-rate span {
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--grey);
      }
      .hrm-divider {
        height: 1px;
        background: var(--border-subtle);
        margin: 1.5rem 0;
      }
      .hrm-note {
        font-size: 0.84rem;
        color: var(--grey);
        line-height: 1.6;
      }

      .hourly-freq-cards {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .hfc-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.1rem 1.5rem;
        transition:
          background 0.25s,
          border-color 0.25s,
          box-shadow 0.25s;
      }
      .hfc-row:hover {
        background: var(--sky);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-sm);
      }
      .hfc-row.hfc-featured {
        background: var(--yellow-l);
        border-color: rgba(246, 193, 51, 0.4);
      }
      .hfc-left {
        display: flex;
        flex-direction: column;
      }
      .hfc-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--navy);
      }
      .hfc-row.hfc-featured .hfc-name {
        color: var(--yellow-d);
      }
      .hfc-cadence {
        font-size: 0.75rem;
        color: var(--grey);
      }
      .hfc-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .hfc-original {
        font-size: 0.85rem;
        color: var(--grey);
        text-decoration: line-through;
        opacity: 0.6;
      }
      .hfc-final {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.01em;
      }
      .hfc-row.hfc-featured .hfc-final {
        color: var(--navy);
      }
      .hfc-save {
        font-size: 0.72rem;
        font-weight: 800;
        background: var(--green-l);
        color: var(--green);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
      }

      /* ─── ESTIMATE CALCULATOR ─────────────────── */
      #estimate {
        background: var(--sky);
      }
      .est-layout {
        display: grid;
        grid-template-columns: 5fr 7fr;
        gap: 5rem;
        align-items: start;
      }
      .est-intro {
        padding-top: 1rem;
      }
      .est-intro p.lead {
        margin-top: 0.75rem;
        margin-bottom: 2rem;
      }
      .est-note {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.25rem;
        box-shadow: var(--shadow-sm);
      }
      .est-note p {
        font-size: 0.83rem;
        color: var(--grey-d);
        line-height: 1.6;
      }

      .est-box {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 2.5rem;
        box-shadow: var(--shadow-lg);
      }
      .est-box-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 1.5rem;
        letter-spacing: -0.01em;
      }
      .c-group {
        margin-bottom: 1.5rem;
      }
      .c-label {
        font-size: 0.72rem;
        font-weight: 800;
        color: var(--grey);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.6rem;
      }
      .c-opts {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }
      .c-opt {
        padding: 0.55rem 1.15rem;
        border-radius: 100px;
        border: 1.5px solid var(--grey-l);
        background: var(--white);
        font-size: 0.83rem;
        font-weight: 600;
        color: var(--grey);
        cursor: pointer;
        transition: all 0.25s var(--ease);
        font-family: var(--font);
      }
      .c-opt:hover {
        border-color: var(--blue);
        color: var(--blue);
      }
      .c-opt.on {
        background: var(--blue);
        border-color: var(--blue);
        color: var(--white);
      }

      .c-stepper {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--grey-l);
        border-radius: 100px;
        overflow: hidden;
        width: fit-content;
        background: var(--white);
      }
      .c-step-btn {
        width: 40px;
        height: 40px;
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        color: var(--grey);
        transition:
          background 0.2s,
          color 0.2s;
        font-family: var(--font);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .c-step-btn:hover {
        background: var(--sky);
        color: var(--blue);
      }
      .c-step-val {
        width: 50px;
        text-align: center;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--navy);
        border-left: 1px solid var(--grey-l);
        border-right: 1px solid var(--grey-l);
        line-height: 40px;
      }

      .c-extras {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .c-extra {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.15rem;
        border: 1.5px solid var(--grey-l);
        border-radius: var(--r);
        background: var(--white);
        cursor: pointer;
        transition: all 0.25s var(--ease);
      }
      .c-extra:hover {
        border-color: var(--blue-l);
      }
      .c-extra.on {
        border-color: var(--blue);
        background: var(--blue-xl);
      }
      .c-extra-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--grey-d);
      }
      .c-extra.on .c-extra-name {
        color: var(--blue-d);
        font-weight: 700;
      }
      .c-extra-amt {
        font-size: 0.82rem;
        color: var(--grey);
        font-weight: 600;
      }
      .c-extra.on .c-extra-amt {
        color: var(--blue);
      }

      .calc-result {
        background: var(--navy);
        border-radius: var(--r-l);
        padding: 1.75rem 2rem;
        margin-top: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .cr-lbl {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.45);
        margin-bottom: 0.15rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .cr-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.04em;
        line-height: 1;
      }
      .cr-price span {
        color: var(--yellow);
      }
      .cr-price sup {
        font-size: 1.1rem;
        font-weight: 600;
        vertical-align: top;
        margin-top: 0.2rem;
        display: inline-block;
        color: var(--white);
      }
      .cr-note {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.35);
        margin-top: 0.3rem;
      }

      /* ─── ADD-ONS SECTION ──────────────────────── */
      #addons {
        background: var(--white);
      }
      .addons-intro {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: end;
        margin-bottom: 3.5rem;
      }

      .addons-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
      }
      .addon-item {
        padding: 2rem 1.75rem;
        border-right: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
        background: var(--white);
        transition: background 0.25s var(--ease);
        position: relative;
      }
      .addon-item:nth-child(4n) {
        border-right: none;
      }
      .addon-item:nth-child(n + 5) {
        border-bottom: none;
      }
      .addon-item:hover {
        background: var(--sky);
      }

      .addon-icon {
        width: 46px;
        height: 46px;
        background: var(--sky);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 1.25rem;
        transition:
          background 0.25s,
          transform 0.25s;
        border: 1px solid var(--border-subtle);
      }
      .addon-item:hover .addon-icon {
        background: var(--blue-xl);
        transform: scale(1.05);
      }
      .addon-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }
      .addon-desc {
        font-size: 0.83rem;
        color: var(--grey);
        line-height: 1.6;
        margin-bottom: 1.25rem;
      }
      .addon-price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .addon-price {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--blue);
        letter-spacing: -0.02em;
      }
      .addon-add-btn {
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.4rem 0.85rem;
        border-radius: 100px;
        background: var(--yellow);
        color: var(--navy);
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: var(--shadow-sm);
      }
      .addon-add-btn:hover {
        background: var(--yellow-d);
        transform: scale(1.03);
      }

      .addons-note {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-top: 2rem;
      }
      .addons-note p {
        font-size: 0.85rem;
        color: var(--grey-d);
        line-height: 1.6;
      }
      .addons-note strong {
        font-weight: 700;
        color: var(--blue);
      }

      /* ─── FAQ SECTION (Style 6) ────────────────── */
      #faq6 {
        background: var(--white);
        border-top: 1px solid var(--border-subtle);
      }
      .faq6-layout {
        display: grid;
        grid-template-columns: 4fr 8fr;
        gap: 5rem;
        align-items: start;
      }
      .faq6-contact {
        padding: 1.5rem;
        background: var(--sky);
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        margin-top: 2rem;
        box-shadow: var(--shadow-sm);
      }
      .faq6-contact p {
        font-size: 0.88rem;
        color: var(--grey);
        line-height: 1.6;
      }
      .faq6-contact a {
        color: var(--blue);
        font-weight: 700;
        text-decoration: none;
      }
      .faq6-list {
        border-top: 1px solid var(--border-subtle);
      }
      .faq6-item {
        border-bottom: 1px solid var(--border-subtle);
      }
      .faq6-q {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.35rem 0;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        font-family: var(--font);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--navy);
        text-align: left;
        transition: color 0.2s;
      }
      .faq6-q:hover {
        color: var(--blue);
      }
      .faq6-ico {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 1px solid var(--grey-l);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: var(--grey);
        font-weight: 400;
        flex-shrink: 0;
        transition: all 0.3s var(--ease);
        line-height: 1;
      }
      .faq6-item.open .faq6-ico {
        background: var(--yellow);
        border-color: var(--yellow);
        color: var(--navy);
        transform: rotate(45deg);
      }
      .faq6-a {
        font-size: 0.9rem;
        color: var(--grey);
        line-height: 1.75;
        max-height: 0;
        overflow: hidden;
        transition:
          max-height 0.4s var(--ease),
          padding 0.3s;
      }
      .faq6-item.open .faq6-a {
        max-height: 280px;
        padding-bottom: 1.35rem;
      }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      #cta6.cta-white {
        background: var(--white);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        border-top: 1px solid var(--grey-l);
        padding-top: 1.5rem;
      }
      .cta6-trust-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.83rem;
        font-weight: 600;
        color: var(--grey-d);
      }
      .cta6-trust-item::before {
        content: "✓";
        color: var(--green);
        font-weight: 800;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 {
        background: var(--navy);
        padding: 4.5rem 2.5rem 2.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .ft6-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3.5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .ft6-brand p {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.4);
        line-height: 1.7;
        margin-top: 0.85rem;
        max-width: 280px;
      }
      .ft6-logo {
        font-size: 1.2rem;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: -0.02em;
      }
      .ft6-col-title {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 1.25rem;
      }
      .ft6-col a {
        display: block;
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.45);
        text-decoration: none;
        margin-bottom: 0.6rem;
        transition: color 0.2s;
      }
      .ft6-col a:hover {
        color: rgba(255, 255, 255, 0.85);
      }
      .ft6-bottom {
        max-width: 1180px;
        margin: 1.75rem auto 0;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .ft6-bottom span,
      .ft6-bottom a {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.25);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ft6-bottom a:hover {
        color: rgba(255, 255, 255, 0.6);
      }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
        .pricing-hero-body {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .pricing-hero-right {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 1.5rem;
        }
        .cta6-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .cta6-right {
          height: 320px;
        }
        .methods-grid {
          grid-template-columns: 1fr;
        }
        .flat-cards {
          grid-template-columns: repeat(2, 1fr);
        }
        .freq-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .hourly-layout,
        .est-layout {
          grid-template-columns: 1fr;
          gap: 4rem;
        }
        .addons-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .addon-item:nth-child(2n) {
          border-right: none;
        }
        .addon-item:nth-child(n + 5) {
          border-bottom: 1px solid var(--border-subtle);
        }
        .addons-intro {
          grid-template-columns: 1fr;
          gap: 1rem;
        }
        .faq6-layout {
          grid-template-columns: 1fr;
          gap: 4rem;
        }
        .ft6-inner {
          grid-template-columns: 1fr 1fr;
          gap: 2.5rem;
        }
      }
      @media (max-width: 768px) {
        .pricing-hero-body {
          padding: 4rem 1.5rem 3rem;
        }
        .pricing-hero-right {
          grid-template-columns: 1fr;
        }
        .cta6-left {
          padding: 2.5rem 1.5rem;
        }
        .c6 {
          padding: 0 1.5rem;
        }
        .pad {
          padding: 4.5rem 0;
        }
        .ft6-inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .freq-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      /* Dropdown style system */
      .hd6-nav-item-dropdown {
        position: relative;
        display: inline-block;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: var(--white);
        min-width: 220px;
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-lg);
        padding: 0.65rem 0;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 0.2s var(--ease),
          transform 0.2s var(--ease),
          visibility 0.2s;
        z-index: 250;
        display: flex;
        flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .hd6-dropdown-menu a {
        display: block !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        color: var(--grey-d) !important;
        padding: 0.6rem 1.25rem !important;
        border-radius: 0 !important;
        transition:
          background 0.2s,
          color 0.2s !important;
        text-align: left;
      }
      .hd6-dropdown-menu a:hover {
        background: var(--sky) !important;
        color: var(--blue) !important;
      }

      /* Mobile sub-menu styling */
      .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .hd6-mob-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--grey);
        letter-spacing: 0.08em;
        margin-top: 0.75rem;
        margin-bottom: 0.25rem;
      }

      @media (max-width: 640px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
        .flat-cards {
          grid-template-columns: 1fr;
        }
        .addons-grid {
          grid-template-columns: 1fr;
        }
        .addon-item {
          border-right: none !important;
          border-bottom: 1px solid var(--border-subtle) !important;
        }
        .addon-item:last-child {
          border-bottom: none !important;
        }
        .pnav-inner {
          padding: 0 1.5rem;
        }
        .freq-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 768px) {
        #pricing-nav + #methods {
          padding-top: 5.5rem;
        }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
        max-width: 1180px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 2.5rem !important;
        padding-right: 2.5rem !important;
      }
      @media (max-width: 768px) {
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
          padding-top: 4.5rem !important;
          padding-bottom: 4.5rem !important;
        }
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
      @media (max-width: 768px), (hover: none), (pointer: coarse) {
        #hd6.scrolled,
        nav[id$="-nav"]:not(#hd6-mob),
        .eol6-strip-img span {
          backdrop-filter: none;
          -webkit-backdrop-filter: none;
        }
        .srv6-card-blur {
          display: none;
        }
      }
    </style>
  </head>

