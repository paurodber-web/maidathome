                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path></svg
                >
              </a>
              <a href="tel:+61399990000" class="btn6-outline" id="cta6-call"
                >Call (03) 9999 0000</a
              >
            </div>
            <div class="cta6-trust si">
              <div class="cta6-trust-item">No lock-in contracts</div>
