        background: rgba(255, 255, 255, 0.06);
      }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed;
        inset: 0 0 auto;
        z-index: 200;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4vw;
