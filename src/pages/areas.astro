        color: var(--blue);
      }
      .lead6 {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
