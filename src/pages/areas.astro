---
import { suburbsData } from '../data/suburbs';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};

const getSuburbLink = (suburbName: string) => {
  const cleanName = suburbName.replace(/,/g, '').toLowerCase().replace(/\s+/g, '-');
  const slug = `house-cleaning-${cleanName}`;
  const hasPage = Object.values(suburbsData).some(s => s.slug === slug);
  if (hasPage) {
    return withBase(`areas/${slug}`);
  }
  return withBase("pricing");
};
