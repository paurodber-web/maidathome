      }

      /* Modern Suburb Cards */
      .suburb-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
      }
      .suburb-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 1.6rem;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        min-height: 145px;
        box-shadow: var(--shadow-sm);
        transition: all 0.25s var(--ease);
        position: relative;
        overflow: hidden;
      }
      .suburb-card::after {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: var(--zone-color, var(--blue));
        opacity: 0;
        transition: opacity 0.2s;
      }
      .suburb-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
        background: var(--sky);
      }
      .suburb-card:hover::after {
        opacity: 1;
      }

      .sc-postcode {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        color: var(--grey);
        margin-bottom: 0.5rem;
      }
      .sc-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
        margin-bottom: auto;
        line-height: 1.25;
      }
      .sc-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.25rem;
      }
      .sc-dist {
        font-size: 0.76rem;
        color: var(--grey);
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-weight: 500;
      }
      .sc-dist::before {
        content: "📍";
        font-size: 0.75rem;
      }
      .sc-arrow {
        font-size: 0.95rem;
        color: var(--blue);
        opacity: 0;
        transform: translate(-3px, 3px);
        transition: all 0.25s var(--ease);
      }
      .suburb-card:hover .sc-arrow {
        opacity: 1;
        transform: none;
      }

      /* ─── NOT LISTED CTA ──────────────────────── */
      #not-listed {
        background: var(--navy);
        padding: 6.5rem 0;
        position: relative;
        overflow: hidden;
      }
      #not-listed::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse 60% 60% at 50% 50%,
          rgba(29, 111, 168, 0.22) 0%,
          transparent 70%
        );
        pointer-events: none;
      }
      #not-listed::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      .nl-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 4rem;
        align-items: center;
      }
      .nl-tag {
        display: inline-block;
        background: rgba(246, 193, 51, 0.12);
        border: 1px solid rgba(246, 193, 51, 0.2);
        color: var(--yellow);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.35rem 0.95rem;
        border-radius: 100px;
        margin-bottom: 1.25rem;
      }
      .nl-inner h2.h6 {
        color: var(--white);
        margin-bottom: 0.85rem;
      }
      .nl-inner .lead6 {
        color: rgba(255, 255, 255, 0.55);
        max-width: 540px;
        margin: 0;
      }
      .nl-actions {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }

      /* ─── WHY LOCAL MATTERS ───────────────────── */
      #local {
        background: var(--white);
      }
      .local-layout {
        display: grid;
        grid-template-columns: 5fr 7fr;
        gap: 5rem;
        align-items: start;
      }
      .local-copy h2.h6 {
        margin-bottom: 1.25rem;
      }
      .local-copy p {
        font-size: 0.98rem;
        color: var(--grey);
        line-height: 1.8;
        margin-bottom: 1.25rem;
      }

      .local-cards {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .local-card {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        padding: 1.75rem;
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        border-radius: var(--r-l);
        box-shadow: var(--shadow-sm);
        transition: all 0.25s var(--ease);
      }
      .local-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateX(3px);
        background: var(--white);
      }
      .local-card-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
        border: 1px solid var(--border-subtle);
        transition: background 0.25s;
      }
      .local-card:hover .local-card-icon {
        background: var(--sky);
      }
      .local-card h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }
      .local-card p {
        font-size: 0.86rem;
        color: var(--grey);
        line-height: 1.6;
      }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        border-top: 1px solid var(--grey-l);
        padding-top: 1.5rem;
      }
      .cta6-trust-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.83rem;
        font-weight: 600;
        color: var(--grey-d);
      }
      .cta6-trust-item::before {
        content: "✓";
        color: var(--green);
        font-weight: 800;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 {
        background: var(--navy);
        padding: 4.5rem 2.5rem 2.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .ft6-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3.5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .ft6-brand p {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.4);
        line-height: 1.7;
        margin-top: 0.85rem;
        max-width: 280px;
      }
      .ft6-logo {
        font-size: 1.2rem;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: -0.02em;
      }
      .ft6-col-title {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 1.25rem;
      }
      .ft6-col a {
        display: block;
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.45);
        text-decoration: none;
        margin-bottom: 0.6rem;
        transition: color 0.2s;
      }
      .ft6-col a:hover {
        color: rgba(255, 255, 255, 0.85);
      }
      .ft6-bottom {
        max-width: 1180px;
        margin: 1.75rem auto 0;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .ft6-bottom span,
      .ft6-bottom a {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.25);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ft6-bottom a:hover {
        color: rgba(255, 255, 255, 0.6);
      }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
        .hero-inner {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .hero-right {
          display: none;
        }
        .znav-inner {
          padding: 0 1.5rem;
        }
        .suburb-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .zone-header {
          grid-template-columns: 1fr;
          gap: 1rem;
        }
        .local-layout {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .nl-inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .ft6-inner {
          grid-template-columns: 1fr 1fr;
          gap: 2.5rem;
        }
        .cta6-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .cta6-right {
          height: 320px;
        }
      }
      @media (max-width: 768px) {
        #hero {
          padding: 7rem 0 4.5rem;
        }
        .c6 {
          padding: 0 1.5rem;
        }
        .pad {
          padding: 4.5rem 0;
        }
        .suburb-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .ft6-inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
      /* Dropdown style system */
      .hd6-nav-item-dropdown {
        position: relative;
        display: inline-block;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: var(--white);
        min-width: 220px;
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-lg);
        padding: 0.65rem 0;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 0.2s var(--ease),
          transform 0.2s var(--ease),
          visibility 0.2s;
        z-index: 250;
        display: flex;
        flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .hd6-dropdown-menu a {
        display: block !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        color: var(--grey-d) !important;
        padding: 0.6rem 1.25rem !important;
        border-radius: 0 !important;
        transition:
          background 0.2s,
          color 0.2s !important;
        text-align: left;
      }
      .hd6-dropdown-menu a:hover {
        background: var(--sky) !important;
        color: var(--blue) !important;
      }

      /* Mobile sub-menu styling */
      .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .hd6-mob-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--grey);
        letter-spacing: 0.08em;
        margin-top: 0.75rem;
        margin-bottom: 0.25rem;
      }

      @media (max-width: 640px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
        #hero h1 {
          font-size: 2.2rem;
        }

        .suburb-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 768px) {
        #zone-nav + #inner-city {
          padding-top: 5.5rem;
        }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
        max-width: 1180px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 2.5rem !important;
        padding-right: 2.5rem !important;
      }
      @media (max-width: 768px) {
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
          padding-top: 4.5rem !important;
          padding-bottom: 4.5rem !important;
        }
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
      @media (max-width: 768px), (hover: none), (pointer: coarse) {
        #hd6.scrolled,
        nav[id$="-nav"]:not(#hd6-mob),
        .eol6-strip-img span {
          backdrop-filter: none;
          -webkit-backdrop-filter: none;
        }
        .srv6-card-blur {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <!-- ─ HEADER ─────────────────────────────────── -->
    <header id="hd6" aria-label="Site header">
      <a href={withBase("index")} class="hd6-logo" aria-label="Maid at Home">
        <div class="hd6-mark" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path
              d="M9 2L11 7H16L12 10.5L13.5 16L9 12.5L4.5 16L6 10.5L2 7H7L9 2Z"
              fill="white"
              fill-opacity="0.9"></path>
          </svg>
        </div>
        <span class="hd6-name">Maid at Home</span>
      </a>
      <nav class="hd6-nav" aria-label="Main navigation">
        <div class="hd6-nav-item-dropdown">
          <a href={withBase("services")} class="hd6-nav-dropdown-toggle">
            Our Services
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="hd6-dropdown-menu">
            <a href={withBase("services/standard-cleaning")}>Standard Cleaning</a>
            <a href={withBase("services/deep-cleaning")}>Deep Cleaning</a>
            <a href={withBase("services/end-of-lease-cleaning")}>End of Lease</a>
            <a href={withBase("services/move-in-cleaning")}>Move In Cleaning</a>
            <a href={withBase("services/oven-cleaning")}>Oven Cleaning</a>
            <a href={withBase("services/window-cleaning")}>Window Cleaning</a>
            <a href={withBase("services/balcony-cleaning")}>Balcony Cleaning</a>
          </div>
        </div>
        <a href={withBase("carpet-cleaning")}>Carpet Cleaning</a>
        <a href={withBase("pricing")}>Pricing</a>
        <a href={withBase("areas")}>Areas We Serve</a>
        <a href={withBase("about")}>About Us</a>
        <a href={withBase("careers")}>Join Our Team</a>
        <div class="hd6-nav-item-dropdown">
          <a href="#" class="hd6-nav-dropdown-toggle" onclick="event.preventDefault()">
            Help
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="hd6-dropdown-menu">
            <a href={withBase("faqs")}>FAQs</a>
            <a href={withBase("contact")}>Contact Us</a>
          </div>
        </div>
        <a href={withBase("blog")}>Blog</a>
        <a href={withBase("booking")} class="hd6-cta">Book Now</a>
      </nav>
      <button
        class="hd6-toggle"
        id="hd6Toggle"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>
    </header>

    <nav id="hd6-mob" aria-label="Mobile navigation">
      
      <!-- Services Row -->
      <div class="mob6-dropdown-item">
        <div class="mob6-dropdown-trigger">
          <a href={withBase("services")}>Services</a>
          <button class="mob6-dropdown-toggle" aria-label="Toggle Services Menu" aria-expanded="false" data-target="mob-services-submenu">
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="mob6-sub-menu collapsed" id="mob-services-submenu">
          <a href={withBase("services/standard-cleaning")}>Standard Cleaning</a>
          <a href={withBase("services/deep-cleaning")}>Deep Cleaning</a>
          <a href={withBase("services/end-of-lease-cleaning")}>End of Lease</a>
          <a href={withBase("services/move-in-cleaning")}>Move In Cleaning</a>
          <a href={withBase("services/oven-cleaning")}>Oven Cleaning</a>
          <a href={withBase("services/window-cleaning")}>Window Cleaning</a>
          <a href={withBase("services/balcony-cleaning")}>Balcony Cleaning</a>
        </div>
      </div>

      <a href={withBase("carpet-cleaning")}>Carpet Cleaning</a>
      <a href={withBase("pricing")}>Pricing</a>
      <a href={withBase("areas")}>Areas We Serve</a>
      <a href={withBase("about")}>About Us</a>
      <a href={withBase("careers")}>Join Our Team</a>

      <!-- Help Row -->
      <div class="mob6-dropdown-item">
        <div class="mob6-dropdown-trigger">
          <span class="mob6-dropdown-label">Help</span>
          <button class="mob6-dropdown-toggle" aria-label="Toggle Help Menu" aria-expanded="false" data-target="mob-help-submenu">
            <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="mob6-sub-menu collapsed" id="mob-help-submenu">
          <a href={withBase("faqs")}>FAQs</a>
          <a href={withBase("contact")}>Contact Us</a>
        </div>
      </div>

      <a href={withBase("blog")}>Blog</a>
      <a href={withBase("booking")} class="mob6-cta">Book Now →</a>
    </nav>

    <!-- ─ HERO ───────────────────────────────────── -->
    <section id="hero" aria-labelledby="hero-h1">
      <div class="hero-sun" aria-hidden="true"></div>
      <div class="hero-body">
        <div class="hero-left">

          <h1 class="hero-pill" id="hero-h1">
            <span class="hero-pill-dot" aria-hidden="true"></span>
            House Cleaning Service Areas in Melbourne
          </h1>
          <p class="hero-display-title" aria-hidden="true">
            Across Melbourne.<br />
            <span class="ac">Close to you.</span>
          </p>
          <p class="hero-sub">
            Maid at Home operates across 20 premium Melbourne suburbs — from the
            CBD and Southbank to Toorak, Brighton, Kew, and beyond. Find your
            suburb below and book a clean today.
          </p>
          <div class="hero-ctas">
            <a href="#inner-city" class="btn6-primary">
              Find My Suburb
              <svg
                width="13"
                height="13"
                viewBox="0 0 13 13"
                fill="none"
                aria-hidden="true"
                ><path
                  d="M6.5 2v9M2 7.5l4.5 4.5L11 7.5"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </a>
            <a href={withBase("pricing")} class="btn6-outline">Get a Quote</a>
          </div>
        </div>

        <div class="hero-right" aria-hidden="true">
          <a href="#inner-city" class="hz-card">
            <div class="hz-dot" style="background: var(--z-city)"></div>
            <div class="hz-name">Inner City & CBD</div>
            <div class="hz-count">6 suburbs</div>
            <div class="hz-suburbs">
              CBD · Southbank · Docklands · Collingwood · Richmond · Prahran
            </div>
          </a>
          <a href="#inner-south" class="hz-card">
            <div class="hz-dot" style="background: var(--z-south)"></div>
            <div class="hz-name">Inner South</div>
            <div class="hz-count">7 suburbs</div>
            <div class="hz-suburbs">
              South Yarra · Toorak · Malvern · Malvern East · St Kilda · Elwood
              · Brighton
            </div>
          </a>
          <a href="#inner-east" class="hz-card">
            <div class="hz-dot" style="background: var(--z-east)"></div>
            <div class="hz-name">Inner East</div>
            <div class="hz-count">4 suburbs</div>
            <div class="hz-suburbs">Kew · Balwyn · Hawthorn · Camberwell</div>
          </a>
          <a href="#port" class="hz-card">
            <div class="hz-dot" style="background: var(--z-port)"></div>
            <div class="hz-name">Port & Waterfront</div>
            <div class="hz-count">3 suburbs</div>
            <div class="hz-suburbs">
              Port Melbourne · Albert Park · Middle Park
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ─ ZONE FILTER NAV ───────────────────────── -->
    <nav id="zone-nav" aria-label="Jump to zone">
