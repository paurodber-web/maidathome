      }
      #hd6.scrolled .hd6-mark {
        background: var(--navy);
      }
      .hd6-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
      }
      .hd6-nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .hd6-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--grey-d);
