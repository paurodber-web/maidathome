        font-family: var(--font);
        white-space: nowrap;
        transition:
          border-color 0.25s,
          background 0.25s,
          color 0.25s;
      }
      .btn6-outline:hover {
        border-color: var(--navy);
        background: var(--sky);
      }

      .btn6-outline-dark {
