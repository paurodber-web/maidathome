      }
      #hd6.menu-open .hd6-toggle span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      #hd6-mob {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 199;
        background: var(--white);
        flex-direction: column;
        padding: 6rem 2rem 2rem;
        gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open {
        display: flex;
      }
      #hd6-mob a {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-cta {
        background: var(--yellow);
        color: var(--navy);
        text-align: center;
        border-radius: var(--r);
        padding: 1.1rem;
        margin-top: 1rem;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        display: block;
      }

      /* ─── HERO ────────────────────────────────── */
      #hero {
        background: var(--sky);
        padding-top: 72px;
        position: relative;
        overflow: hidden;
      }
      .hero-sun {
        position: absolute;
        top: -120px;
        right: -100px;
        width: 560px;
        height: 560px;
        border-radius: 50%;
        background: radial-gradient(
          ellipse at center,
          rgba(246, 193, 51, 0.14) 0%,
          rgba(246, 193, 51, 0.03) 60%,
          transparent 80%
        );
        pointer-events: none;
      }
      .hero-body {
        max-width: 1180px;
        margin: 0 auto;
        padding: 4rem 2.5rem 5rem;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--blue);
        letter-spacing: 0.05em;
        margin-bottom: 1.75rem;
        width: fit-content;
        background: var(--white);
        padding: 0.4rem 0.9rem;
        border-radius: 100px;
        box-shadow: var(--shadow-sm);
        animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .hero-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--yellow);
        flex-shrink: 0;
      }
      .hero-left {
        opacity: 0;
        animation: fadeUp 0.8s var(--ease) 0.1s forwards;
      }

      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        color: var(--grey);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }
      .breadcrumb a {
        color: var(--grey);
        text-decoration: none;
        transition: color 0.2s;
      }
      .breadcrumb a:hover {
        color: var(--blue);
      }
      .breadcrumb .sep {
        color: var(--grey-l);
      }
      .breadcrumb .current {
        color: var(--grey-d);
      }

      .hero-display-title {
        font-size: clamp(2.8rem, 5vw, 4rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.04em;
        color: var(--navy);
        margin-bottom: 1.5rem;
      }
      .hero-display-title .ac {
        color: var(--blue);
      }
      .hero-sub {
        font-size: 1.1rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 500px;
        margin-bottom: 2.25rem;
      }
      .hero-ctas {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 0;
      }
      .hero-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        border-top: 1px solid var(--border-subtle);
        padding-top: 1.5rem;
      }
      .hero-pill-item {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--grey-d);
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: 100px;
        padding: 0.35rem 0.85rem;
        box-shadow: var(--shadow-sm);
      }

      /* Hero right: zone cards */
      .hero-right {
        opacity: 0;
        animation: fadeUp 0.9s var(--ease) 0.3s forwards;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .hz-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 1.5rem;
        transition: all 0.25s var(--ease);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-sm);
      }
      .hz-card:hover {
        background: var(--sky);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }
      .hz-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 0.85rem;
      }
      .hz-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.2rem;
      }
      .hz-count {
        font-size: 0.78rem;
        color: var(--blue);
        font-weight: 600;
      }
      .hz-suburbs {
        font-size: 0.72rem;
        color: var(--grey);
        margin-top: 0.75rem;
        line-height: 1.55;
      }

      /* ─── ZONE FILTER NAV ─────────────────────── */
      #zone-nav {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 72px;
        z-index: 100;
        transition: top 0.3s var(--ease);
      }
      #hd6.scrolled ~ #zone-nav {
        top: 64px;
      }

      .znav-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .znav-inner::-webkit-scrollbar {
        display: none;
      }
      .znav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--grey);
        padding: 1.1rem 1.15rem;
        text-decoration: none;
        white-space: nowrap;
        border-bottom: 3px solid transparent;
        transition:
          color 0.25s,
          border-color 0.25s;
        margin-bottom: -1px;
      }
      .znav-link:hover {
        color: var(--blue);
      }
      .znav-link.active {
        color: var(--blue);
        border-bottom-color: var(--blue);
        font-weight: 700;
      }
      .znav-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
      }

