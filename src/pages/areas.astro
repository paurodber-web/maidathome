        border: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
