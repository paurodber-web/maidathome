    />
    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy: #0a1d33;
        --blue-d: #142d4c;
        --blue: #1d6fa8;
        --blue-l: #5aaee0;
        --blue-xl: #e8f4fd;
        --sky: #f0f7fd;
        --yellow: #f6c133;
        --yellow-d: #e0ab1d;
        --yellow-l: #fffbe6;
        --green: #16a34a;
        --green-l: #e8f7ee;
        --grey: #5e6a75;
        --grey-d: #2d3748;
        --grey-l: #e2e8f0;
        --white: #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover: rgba(29, 111, 168, 0.18);
        --shadow-sm: 0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md: 0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg: 0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium: 0 24px 60px rgba(10, 29, 51, 0.08);

        --font: "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s: 8px;
        --r: 12px;
        --r-l: 20px;
        --r-xl: 28px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);

        /* Zone Colors */
        --z-city: #1d6fa8;
        --z-south: #7c3aed;
        --z-east: #0e7490;
        --z-port: #16a34a;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img {
        display: block;
        max-width: 100%;
      }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.7s var(--ease),
          transform 0.7s var(--ease);
      }
      .si[data-d="l"] {
        transform: translateX(-24px);
      }
      .si[data-d="r"] {
        transform: translateX(24px);
      }
      .si.in {
        opacity: 1;
        transform: none;
      }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6 {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }
      .pad {
        padding: 6.5rem 0;
      }
      .pad-sm {
        padding: 4.5rem 0;
      }
      #zone-nav + #inner-city {
        padding-top: 8rem;
      }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: "";
        width: 16px;
        height: 2.5px;
        background: var(--yellow);
        border-radius: 2px;
        flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--navy);
        line-height: 1.15;
      }
