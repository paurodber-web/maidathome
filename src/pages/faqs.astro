    <script is:inline>
      /* ─ HEADER ───────────────────────────────────── */
      const hd6 = document.getElementById("hd6");
      const onScroll6 = () => hd6.classList.toggle("scrolled", window.scrollY > 20);
      window.addEventListener("scroll", onScroll6, { passive: true });
      onScroll6();

            /* ─ MOBILE NAV / MENU ────────────────────────── */
      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      const cls6 = document.getElementById("hd6MobClose");
      
      if (tog6 && mob6) {
        tog6.addEventListener("click", () => {
          const isOpen = mob6.classList.toggle("open");
          if (hd6) hd6.classList.toggle("menu-open", isOpen);
          tog6.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });
      }
      
      if (cls6 && mob6 && tog6) {
        cls6.addEventListener("click", () => {
          mob6.classList.remove("open");
          if (hd6) hd6.classList.remove("menu-open");
          tog6.setAttribute("aria-expanded", "false");
        });
      }
      
      if (mob6) {
        mob6.querySelectorAll("a").forEach(a => {
          a.addEventListener("click", () => {
            mob6.classList.remove("open");
            if (hd6) hd6.classList.remove("menu-open");
            if (tog6) tog6.setAttribute("aria-expanded", "false");
          });
        });
      }

      /* ─ MOBILE DROPDOWN ACCORDION ────────────────── */
      if (mob6) {
        mob6.querySelectorAll('.mob6-dropdown-toggle').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const targetId = btn.getAttribute('data-target');
            const submenu = document.getElementById(targetId);
            if (submenu) {
              const isCollapsed = submenu.classList.contains('collapsed');
              if (isCollapsed) {
                submenu.classList.remove('collapsed');
                btn.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
              } else {
                submenu.classList.add('collapsed');
                btn.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
              }
            }
          });
        });
      }

      /* ─ STAGGER OBSERVER ─────────────────────────── */
      const sObs6 = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const items = Array.from(entry.target.querySelectorAll(".si")).filter(el => !el.classList.contains("in"));
          items.forEach((item, i) => setTimeout(() => item.classList.add("in"), i * 110));
          sObs6.unobserve(entry.target);
        });
      }, { threshold: 0.05, rootMargin: "0px 0px -20px 0px" });
      document.querySelectorAll(".sg").forEach(g => sObs6.observe(g));

      /* ─ FAQ ACCORDION LOGIC ───────────────────────── */
      document.querySelectorAll(".faq-item").forEach(item => {
        item.querySelector(".faq-q").addEventListener("click", () => {
          const open = item.classList.contains("open");
          if (open) {
            item.classList.remove("open");
            item.querySelector(".faq-q").setAttribute("aria-expanded", "false");
          } else {
            item.classList.add("open");
            item.querySelector(".faq-q").setAttribute("aria-expanded", "true");
          }
        });
      });

      /* ─ FAQ CATEGORY FILTER LOGIC ─────────────────── */
      const catBtns = document.querySelectorAll(".faq-cat-btn");
      const sections = document.querySelectorAll(".faq-cat-section");

      catBtns.forEach(btn => {
        btn.addEventListener("click", () => {
          catBtns.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");

          const cat = btn.getAttribute("data-cat");
          sections.forEach(sec => {
            if (cat === "all" || sec.getAttribute("data-section") === cat) {
              sec.style.display = "block";
            } else {
              sec.style.display = "none";
            }
          });
        });
      });
    </script>
  </body>
