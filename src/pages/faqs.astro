---
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Frequently Asked Questions — Maid at Home Melbourne</title>
    <meta name="description" content="Got questions? Find clear answers about our professional house cleaning services in Melbourne, booking procedures, pricing, and our satisfaction guarantee." />

    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-italic.woff2") format("woff2");
      }      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: none; }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .si[data-d="l"] { transform: translateX(-24px); }
      .si[data-d="r"] { transform: translateX(24px); }
      .si.in { opacity: 1; transform: none; }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6     { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; }
      .pad    { padding: 6.5rem 0; }
      .pad-sm { padding: 4.5rem 0; }
      #std-hero + section.pad { padding-top: 8rem; }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--blue); margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: ""; width: 16px; height: 2.5px;
        background: var(--yellow); border-radius: 2px; flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--navy); line-height: 1.15;
      }
      h2.h6 .ac { color: var(--blue); }
      .lead6 {
        font-size: 1.05rem; color: var(--grey);
        line-height: 1.75; max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.95rem;
        padding: 0.95rem 2rem; border-radius: 100px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: var(--font); white-space: nowrap;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4); }
      .btn6-outline {
        display: inline-flex; align-items: center; gap: 0.45rem;
        color: var(--navy); font-weight: 600; font-size: 0.9rem;
        padding: 0.9rem 1.75rem; border-radius: 100px;
        border: 1px solid var(--grey-l); background: transparent;
        text-decoration: none; cursor: pointer; font-family: var(--font); white-space: nowrap;
        transition: border-color 0.25s, background 0.25s, color 0.25s;
      }
      .btn6-outline:hover { border-color: var(--navy); background: var(--sky); }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }

      /* Dropdown style system */
      .hd6-nav-item-dropdown { position: relative; display: inline-block; }
      .hd6-nav-dropdown-toggle { display: inline-flex; align-items: center; gap: 0.35rem; cursor: pointer; }
      .hd6-nav-dropdown-toggle svg { transition: transform 0.2s var(--ease); }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg { transform: rotate(180deg); }
      .hd6-dropdown-menu {
        position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(8px);
        background: var(--white); min-width: 220px; border-radius: var(--r);
        border: 1px solid var(--border-subtle); box-shadow: var(--shadow-lg);
        padding: 0.65rem 0; opacity: 0; visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250; display: flex; flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
      .hd6-dropdown-menu a {
        display: block !important; font-size: 0.88rem !important; font-weight: 600 !important;
        color: var(--grey-d) !important; padding: 0.6rem 1.25rem !important; border-radius: 0 !important;
        transition: background 0.2s, color 0.2s !important; text-align: left;
      }
      .hd6-dropdown-menu a:hover { background: var(--sky) !important; color: var(--blue) !important; }

      /* Mobile sub-menu styling */
      .mob6-sub-menu { display: flex; flex-direction: column; padding-left: 1.25rem; border-left: 2px solid var(--border-subtle); margin: 0.25rem 0 0.75rem; gap: 0.35rem; }
      .mob6-sub-menu a { font-size: 0.95rem !important; color: var(--grey) !important; padding: 0.5rem 0 !important; border-bottom: none !important; }
      .mob6-sub-menu a:hover { color: var(--blue) !important; }
      .hd6-mob-section-title { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: var(--grey); letter-spacing: 0.08em; margin-top: 0.75rem; margin-bottom: 0.25rem; }

      /* ─── PAGE HERO ───────────────────────────── */
      #std-hero { background: var(--sky); padding-top: 72px; position: relative; overflow: hidden; }
      .std-hero-sun {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      .std-hero-body {
        max-width: 1180px; margin: 0 auto; padding: 5rem 2.5rem 6rem;
        display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; z-index: 2;
      }
      
      .std-hero-pill {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.75rem; font-weight: 700; color: var(--blue); letter-spacing: 0.05em;
        margin-bottom: 1.75rem; width: fit-content;
        background: var(--white); padding: 0.4rem 0.9rem; border-radius: 100px;
        box-shadow: var(--shadow-sm); animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .std-hero-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--yellow); flex-shrink: 0; }
      
      .std-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 800; letter-spacing: -0.04em;
        line-height: 1.08; color: var(--navy); margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.15s both;
      }
      .std-hero-h1 .ac { color: var(--blue); }
      .std-hero-desc { font-size: 1.15rem; color: var(--grey-d); line-height: 1.7; max-width: 680px; margin: 0 auto 2rem; animation: fadeUp 0.65s var(--ease) 0.15s both; }

      /* ─── CATEGORY FILTERS ────────────────────── */
      .faq-cats { display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 3.5rem; }
      .faq-cat-btn {
        background: var(--white); border: 1px solid var(--border-subtle);
        color: var(--grey-d); font-family: var(--font); font-size: 0.88rem; font-weight: 600;
        padding: 0.65rem 1.25rem; border-radius: 100px; cursor: pointer;
        transition: all 0.25s var(--ease); box-shadow: var(--shadow-sm);
      }
      .faq-cat-btn:hover { border-color: var(--blue-l); color: var(--blue); }
      .faq-cat-btn.active { background: var(--blue); border-color: var(--blue); color: var(--white); box-shadow: 0 4px 14px rgba(29, 111, 168, 0.2); }

      /* ─── FAQ ACCORDION LIST ──────────────────── */
      .faq-layout-main { max-width: 800px; margin: 0 auto; }
      .faq-group-title {
        font-size: 1.25rem; font-weight: 800; color: var(--navy);
        margin: 2.5rem 0 1.25rem; display: flex; align-items: center; gap: 0.6rem;
      }
      .faq-group-title::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--blue); }
      .faq-item {
        background: var(--white); border: 1px solid var(--border-subtle);
        border-radius: var(--r); margin-bottom: 0.85rem; overflow: hidden;
        transition: border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
      }
      .faq-item:hover { border-color: var(--blue-l); box-shadow: var(--shadow-sm); }
      .faq-item.open { border-color: var(--blue); box-shadow: var(--shadow-md); }
      .faq-q {
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: 1.25rem 1.5rem; cursor: pointer; background: none; border: none;
        width: 100%; font-family: var(--font); font-size: 1rem; font-weight: 700;
        color: var(--navy); text-align: left; transition: color 0.2s;
      }
      .faq-q:hover { color: var(--blue); }
      .faq-ico {
        width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--grey-l);
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
        color: var(--grey); font-weight: 400; flex-shrink: 0; transition: all 0.3s var(--ease); line-height: 1;
      }
      .faq-item.open .faq-ico { background: var(--yellow); border-color: var(--yellow); color: var(--navy); transform: rotate(45deg); }
      .faq-a {
        font-size: 0.95rem; color: var(--grey-d); line-height: 1.75;
        max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease), padding 0.3s;
        padding: 0 1.5rem;
      }
      .faq-item.open .faq-a { max-height: 380px; padding-bottom: 1.5rem; }

      /* ─── COMPACT CONTACT CARD ────────────────── */
      .compact-contact-card {
        padding: 2rem 2.25rem;
        background: var(--sky);
        border-radius: 20px;
        border: 1px solid var(--border-subtle);
        width: 100%;
        max-width: 600px;
        margin: 4.5rem auto 0;
        display: flex;
        align-items: center;
        justify-content: space-around;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
      }
      .compact-card-line {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.95rem;
        line-height: 1.2;
        color: var(--blue);
        font-weight: 700;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .compact-card-line:hover { opacity: 0.85; }
      .compact-card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        flex-shrink: 0;
      }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 { background: var(--navy); padding: 4.5rem 2.5rem 2.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
      .ft6-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3.5rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .ft6-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.7; margin-top: 0.85rem; max-width: 280px; }
      .ft6-logo { font-size: 1.2rem; font-weight: 800; color: rgba(255,255,255,0.85); letter-spacing: -0.02em; }
      .ft6-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
      .ft6-col a { display: block; font-size: 0.88rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.2s; }
      .ft6-col a:hover { color: rgba(255,255,255,0.85); }
      .ft6-bottom { max-width: 1180px; margin: 1.75rem auto 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      .ft6-bottom span, .ft6-bottom a { font-size: 0.78rem; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
      .ft6-bottom a:hover { color: rgba(255,255,255,0.6); }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .cta6-grid { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-right { height: 320px; }
        .ft6-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      }
      @media (max-width: 768px) {
        .pad { padding: 4.5rem 0; }
        .ft6-inner { grid-template-columns: 1fr; gap: 2rem; }
        .compact-contact-card { flex-direction: column; gap: 1.25rem; align-items: flex-start; }
      }
      @media (max-width: 640px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .std-hero-h1 { font-size: 2.4rem; }
      }
      @media (max-width: 768px) {
        #std-hero + section.pad { padding-top: 5.5rem; }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
