re{content:"";position:absolute;right:-150px;bottom:-190px;width:390px;height:390px;border:62px solid rgba(169,209,231,.22);border-radius:50%}.legal-hero:after{content:"";position:absolute;top:115px;left:-95px;width:190px;height:190px;border-radius:50%;background:rgba(251,242,213,.55)}.breadcrumb{position:relative;z-index:1;display:flex;align-items:center;gap:10px;margin-bottom:45px;color:var(--soft);font-size:.71rem;font-weight:650}.breadcrumb a{color:var(--b700)}.breadcrumb svg{width:13px;color:var(--b400)}.hero-grid{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1.18fr) minmax(330px,.62fr);align-items:end;gap:70px}.legal-hero h1{max-width:720px;margin:0 0 19px;font-size:clamp(3rem,5.5vw,5rem);font-weight:600;line-height:.98;letter-spacing:-.06em}.legal-hero h1 em{color:var(--b700);font-style:normal}.hero-copy p{max-width:620px;margin:0}.hero-card{padding:24px;border:1px solid var(--b200);border-radius:20px;background:rgba(255,255,255,.86);box-shadow:var(--shadow)}.hero-card-top{display:flex;align-items:center;gap:13px;margin-bottom:16px}.hero-icon{display:grid;width:43px;height:43px;place-items:center;border-radius:14px;color:var(--b800);background:var(--beige)}.hero-icon svg{width:21px}.hero-card strong{display:block;font-size:.76rem}.hero-card span{display:block;color:var(--soft);font-size:.62rem}.hero-card p{margin:0;padding-top:15px;border-top:1px solid var(--g100);font-size:.7rem}.summary-wrap{padding:0 0 42px;background:linear-gradient(var(--b50) 0 34px,#fff 34px)}.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);overflow:hidden;border:1px solid var(--b200);border-radius:21px;background:#fff;box-shadow:var(--shadow)}.summary-item{min-height:122px;padding:23px;border-left:1px solid var(--b200)}.summary-item:first-child{border-left:0}.summary-item svg{width:20px;margin-bottom:13px;color:var(--b700)}.summary-item strong{display:block;margin-bottom:4px;font-size:.76rem}.summary-item span{display:block;color:var(--soft);font-size:.63rem;line-height:1.45}.legal-area{padding:56px 0 115px}.legal-layout{display:grid;grid-template-columns:245px minmax(0,790px);justify-content:center;gap:clamp(48px,7vw,90px)}.toc{position:sticky;top:calc(var(--nav) + 28px);align-self:start}.toc-title{display:block;margin-bottom:16px;color:var(--b700);font-size:.62rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.toc nav{display:grid;border-left:1px solid var(--b200)}.toc a{position:relative;padding:8px 0 8px 16px;color:var(--soft);font-size:.7rem;font-weight:650;line-height:1.4;transition:color .25s}.toc a:before{content:"";position:absolute;top:0;bottom:0;left:-1px;width:2px;background:var(--b700);transform:scaleY(0);transition:transform .25s}.toc a:hover,.toc a.active{color:var(--b800)}.toc a.active:before{transform:scaleY(1)}.toc-contact{margin-top:23px;padding:18px;border-radius:15px;background:var(--beige2)}.toc-contact strong{display:block;margin-bottom:6px;font-size:.7rem}.toc-contact p{margin:0 0 10px;font-size:.63rem}.legal-content{min-width:0}.legal-intro{margin-bottom:55px;padding-bottom:32px;border-bottom:1px solid var(--g200)}.legal-intro p{font-size:1.05rem;line-height:1.8}.legal-section{position:relative;padding:0 0 58px;margin-bottom:58px;border-bottom:1px solid var(--g200)}.legal-section:last-of-type{border-bottom:0}.section-number{display:block;margin-bottom:13px;color:var(--b600);font:800 .64rem "Plus Jakarta Sans";letter-spacing:.12em}.legal-section h2{max-width:660px;margin:0 0 20px;font-size:clamp(1.75rem,3.2vw,2.55rem);font-weight:650}.legal-section h3{margin:30px 0 11px;font-size:1.06rem;font-weight:700}.legal-section p{margin-bottom:19px;font-size:.92rem;line-height:1.82}.legal-section ul{display:grid;gap:10px;margin:0 0 23px;padding-left:21px;color:var(--soft)}.legal-section li{padding-left:5px;font-size:.9rem;line-height:1.7}.legal-section strong{color:var(--ink)}.legal-section a{color:var(--b700);font-weight:700;text-decoration:underline;text-decoration-color:var(--b300);text-underline-offset:3px}.plain-note{display:grid;grid-template-columns:42px 1fr;gap:16px;margin:27px 0;padding:22px;border:1px solid var(--b200);border-radius:17px;background:var(--b50)}.plain-note i{display:grid;width:42px;height:42px;place-items:center;border-radius:50%;color:var(--b800);background:var(--beige);font-style:normal}.plain-note svg{width:19px}.plain-note strong{display:block;margin:2px 0 4px;font-size:.75rem}.plain-note p{margin:0;font-size:.7rem;line-height:1.55}.definition-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:25px 0}.definition{padding:19px;border:1px solid var(--b200);border-radius:15px;background:#fff}.definition strong{display:block;margin-bottom:5px;font-size:.73rem}.definition span{display:block;color:var(--soft);font-size:.65rem;line-height:1.5}.contact-panel{position:relative;overflow:hidden;padding:35px;border-radius:24px;color:#fff;background:var(--b900)}.contact-panel:after{content:"";position:absolute;right:-50px;bottom:-70px;width:190px;height:190px;border:1px solid rgba(255,255,255,.12);border-radius:50%;box-shadow:0 0 0 38px rgba(255,255,255,.025)}.contact-panel>*{position:relative;z-index:1}.contact-panel h2{color:#fff}.contact-panel p{max-width:600px;color:rgba(255,255,255,.68)}.contact-panel .button{margin-top:8px}.page-switch{display:flex;align-items:center;justify-content:space-between;gap:25px;margin-top:45px;padding:24px;border:1px solid var(--b200);border-radius:18px;background:var(--beige2)}.page-switch p{margin:0;font-size:.72rem}footer{padding:68px 0 28px;background:var(--b50)}.footer-top{display:grid;grid-template-columns:1.4fr repeat(3,.7fr);gap:50px;padding-bottom:52px}.footer-brand p{max-width:310px;margin:18px 0 23px;font-size:.76rem}.footer-contact{display:grid;gap:6px;color:var(--b800);font-size:.72rem;font-weight:700}.footer-col h3{margin-bottom:18px;font-size:.77rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase}.footer-col nav{display:grid;gap:10px}.footer-col a{width:fit-content;color:var(--soft);font-size:.73rem}.footer-bottom{display:flex;align-items:center;justify-content:space-between;gap:20px;padding-top:24px;border-top:1px solid var(--b200)}.footer-bottom p{margin:0;font-size:.65rem}.legal-links{display:flex;gap:18px;color:var(--soft);font-size:.65rem}.legal-links a[aria-current=page]{color:var(--b700);font-weight:800}@media(max-width:1040px){:root{--shell:min(100% - 40px,940px)}.desktop-nav{gap:15px}.desktop-nav>a:not(.nav-cta){font-size:.76rem}.desktop-nav>a:nth-child(4){display:none}.legal-layout{grid-template-columns:220px minmax(0,700px);gap:50px}.footer-top{gap:30px}}@media(max-width:820px){:root{--nav:74px;--shell:min(100% - 36px,720px)}.desktop-nav{display:none}.menu-btn,.mobile-menu{display:block}.legal-hero{padding-top:calc(var(--nav) + 25px)}.hero-grid{grid-template-columns:1fr;gap:30px}.summary-grid{grid-template-columns:repeat(2,1fr)}.summary-item:nth-child(odd){border-left:0}.summary-item:nth-child(n+3){border-top:1px solid var(--b200)}.legal-layout{grid-template-columns:1fr;max-width:790px;margin:auto}.toc{position:static;padding:21px;border:1px solid var(--b200);border-radius:17px;background:var(--b50)}.toc nav{grid-template-columns:repeat(2,1fr);gap:1px 18px;border-left:0}.toc a{padding:8px 0;border-bottom:1px solid var(--g200)}.toc a:before{display:none}.toc-contact{display:none}.footer-top{grid-template-columns:1.4fr 1fr 1fr}.footer-brand{grid-column:1/-1}}@media(max-width:620px){:root{--shell:calc(100% - 30px)}body{font-size:15px}.legal-hero{padding-bottom:48px}.breadcrumb{margin-bottom:32px}.legal-hero h1{font-size:clamp(2.5rem,13vw,3.5rem)}.summary-wrap{background:linear-gradient(var(--b50) 0 20px,#fff 20px)}.summary-item{min-height:112px;padding:19px}.legal-area{padding-top:35px;padding-bottom:80px}.toc nav{grid-template-columns:1fr}.legal-intro{margin-bottom:44px}.legal-section{padding-bottom:44px;margin-bottom:44px}.legal-section h2{font-size:clamp(1.7rem,9vw,2.25rem)}.definition-grid{grid-template-columns:1fr}.plain-note{grid-template-columns:1fr}.contact-panel{padding:29px 24px}.page-switch{align-items:flex-start;flex-direction:column}.footer-top{grid-template-columns:repeat(2,1fr)}.footer-brand{grid-column:1/-1}.footer-bottom{align-items:flex-start;flex-direction:column}}@media(max-width:400px){.summary-grid{grid-template-columns:1fr}.summary-item{border-top:1px solid var(--b200);border-left:0}.summary-item:first-child{border-top:0}.footer-top{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){html{scroll-behavior:auto}*,*:before,*:after{animation-duration:.01ms!important;transition-duration:.01ms!important}.reveal{opacity:1;transform:none}}.reading-progress{position:fixed;z-index:200;top:0;left:0;width:0;height:3px;background:var(--beige,#f4df9f);transition:width 0.08s linear}.nav-item-dropdown{position:relative;display:inline-block}.dropdown-menu{position:absolute;top:100%;left:50%;transform:translateX(-50%) translateY(10px);background:var(--white,#fff);border:1px solid var(--grey-200,#dbe4e8);border-radius:12px;box-shadow:0 10px 30px rgba(29,80,119,0.08);padding:10px;min-width:160px;opacity:0;visibility:hidden;transition:opacity 0.25s cubic-bezier(.22,1,.36,1),transform 0.25s cubic-bezier(.22,1,.36,1),visibility 0.25s;z-index:1000;display:flex;flex-direction:column;gap:6px}.nav-item-dropdown:hover .dropdown-menu{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0)}.dropdown-menu a{display:block;padding:8px 12px;border-radius:6px;font-size:0.8rem !important;font-weight:600;color:var(--ink,#183042) !important;white-space:nowrap;transition:background 0.2s,color 0.2s;text-align:left}.dropdown-menu a::after{display:none !important}.dropdown-menu a:hover{background:var(--blue-50,#f4fafc) !important;color:var(--blue-700,#286b9d) !important}`;
const scripts = `<script>
    (()=>{const header=document.getElementById('header'),btn=document.getElementById('menuBtn'),menu=document.getElementById('mobileMenu'),content=document.getElementById('legalContent');const setMenu=open=>{btn.setAttribute('aria-expanded',open);btn.setAttribute('aria-label',open?'Close menu':'Open menu');menu.setAttribute('aria-hidden',!open);menu.classList.toggle('open',open);document.body.classList.toggle('menu-open',open)};btn.addEventListener('click',()=>setMenu(btn.getAttribute('aria-expanded')!=='true'));menu.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>setMenu(false)));document.addEventListener('keydown',e=>{if(e.key==='Escape')setMenu(false)});const sections=[...document.querySelectorAll('.legal-section[id],.contact-panel[id]')],links=[...document.querySelectorAll('.toc a')];const update=()=>{header.classList.toggle('scrolled',scrollY>24);const start=content.offsetTop-innerHeight*.35,end=content.offsetTop+content.offsetHeight-innerHeight*.65;let current=sections[0]?.id;sections.forEach(s=>{if(s.getBoundingClientRect().top<innerHeight*.38)current=s.id});links.forEach(a=>a.classList.toggle('active',a.hash==='#'+current))};update();addEventListener('scroll',update,{passive:true});const items=document.querySelectorAll('.reveal');if('IntersectionObserver'in window&&!matchMedia('(prefers-reduced-motion:reduce)').matches){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('show');io.unobserve(e.target)}}),{threshold:.06,rootMargin:'0px 0px -25px'});items.forEach(x=>io.observe(x))}else items.forEach(x=>x.classList.add('show'));document.getElementById('year').textContent=new Date().getFullYear()})();
  
  // Scroll progress bar logic
  (function() {
    const progress = document.getElementById("readingProgress");
    if (progress) {
      const updateProgress = () => {
        const scrolled = window.scrollY;
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const pct = maxScroll > 0 ? (scrolled / maxScroll) * 100 : 0;
        progress.style.width = Math.min(100, Math.max(0, pct)) + "%";
      };
      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
    }
  })();

</script>`;
const preHeader = `<div class="reading-progress" id="readingProgress"></div><a class="skip" href="#legalContent">Skip to terms and conditions</a>`;
const content = `<main>
    <section class="legal-hero"><div class="shell"><nav class="breadcrumb"><a href="/">Home</a><svg viewBox="0 0 16 16" fill="none" stroke="currentColor"><path d="m6 3 5 5-5 5"></path></svg><span>Terms &amp; conditions</span></nav><div class="hero-grid"><div class="hero-copy"><div class="kicker">Clear terms for every booking</div><h1>Booking terms,<br><em>made clear.</em></h1><p>These terms and conditions explain exactly how Maid At Home bookings, payments, changes and cleaning services work, so you know what to expect before your team arrives.</p></div><aside class="hero-card"><div class="hero-card-top"><span class="hero-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M6 3h9l3 3v15H6zM9 11h6M9 15h6M9 7h3"></path></svg></span><div><strong>Terms &amp; Conditions</strong><span>Last updated 13 July 2026</span></div></div><p>Nothing in these terms limits rights or remedies that cannot lawfully be excluded under Australian Consumer Law.</p></aside></div></div></section>
    <div class="summary-wrap"><div class="summary-grid shell reveal"><div class="summary-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M5 4h14v16H5zM8 8h8M8 12h8M8 16h5"></path></svg><strong>Booking confirmation</strong><span>Your booking is confirmed by email after a cleaner or team is assigned.</span></div><div class="summary-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 7h18v11H3zM3 10h18M7 15h3"></path></svg><strong>Simple payments</strong><span>A card hold may be placed before service; the final amount is charged after.</span></div><div class="summary-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 7v5l3 2M4 12a8 8 0 1 0 2-5.3M4 3v4h4"></path></svg><strong>Clear cancellation</strong><span>Fees depend on how much notice you give and whether the team has arrived.</span></div><div class="summary-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3 4 6v6c0 5 3.3 8 8 9 4.7-1 8-4 8-9V6l-8-3ZM8 12l2.5 2.5L16 9"></path></svg><strong>Your rights remain</strong><span>Australian Consumer Law rights and remedies continue to apply.</span></div></div></div>
    <section class="legal-area" id="legalContent"><div class="legal-layout shell"><aside class="toc"><span class="toc-title">In these terms</span><nav><a href="#about">About these terms</a><a href="#booking">Bookings</a><a href="#scope">Service scope</a><a href="#pricing">Pricing</a><a href="#payment">Payment</a><a href="#access">Your responsibilities</a><a href="#cancellations">Changes and cancellation</a><a href="#recurring">Recurring services</a><a href="#service-issues">Service concerns</a><a href="#end-of-lease">End of lease</a><a href="#damage">Damage or loss</a><a href="#steam">Carpet steam cleaning</a><a href="#liability">Consumer rights</a><a href="#website">Website and tools</a><a href="#changes">General terms</a><a href="#contact">Contact us</a></nav><div class="toc-contact"><strong>Booking question?</strong><p>Contact us before your service if anything is unclear.</p><a class="text-link" href="mailto:info@maidathome.com.au">Email us <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a></div></aside>
      <article class="legal-content"><div class="legal-intro reveal"><p>These terms apply when you use our website, request or make a booking, or receive a residential cleaning service from Maid At Home in Melbourne. By making a booking, you agree to these terms.</p><p>If there is any inconsistency between these terms and a written booking confirmation or agreed quote, the written booking confirmation or quote applies to that inconsistency. Nothing in these terms excludes, restricts or modifies a right or remedy that cannot lawfully be excluded.</p></div>
        <section class="legal-section reveal" id="about"><span class="section-number">01 / SCOPE</span><h2>About these terms.</h2><p>“Maid At Home”, “we”, “us” and “our” refer to the business operating under the Maid At Home name. “You” and “customer” mean the person who makes the booking and, where relevant, the person responsible for the property.</p><p>You must be at least 18 years old and authorised to arrange the service at the property. If you book for another person, you are responsible for giving them relevant booking information and ensuring you have permission to provide their details.</p></section>
        <section class="legal-section reveal" id="booking"><span class="section-number">02 / BOOKINGS</span><h2>Requests, assignments and confirmation.</h2><p>Submitting a booking form or receiving an automated receipt means we have received your request. It does not by itself confirm that a cleaner or team has been assigned.</p><div class="plain-note"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 6h16v12H4zM4 7l8 6 8-6"></path></svg></i><div><strong>When your booking is confirmed</strong><p>Your booking is confirmed when we email you to confirm that a cleaner or team has been assigned. Availability, dates and arrival windows remain subject to that confirmation.</p></div></div><p>We may reasonably decline a request or propose another time if no suitable team is available, the property is outside our service area, the requested work is unsafe or outside our services, or required information has not been provided.</p></section>
        <section class="legal-section reveal" id="scope"><span class="section-number">03 / SERVICE SCOPE</span><h2>What your clean includes.</h2><p>The service includes the tasks shown for the service type and any extras listed in your confirmed booking or written quote. Results depend on property condition, available time, access and whether surfaces or items can be safely cleaned.</p><ul><li><strong>Fixed-scope services:</strong> we complete the included checklist within reasonable limits. Additional tasks, excessive build-up or conditions not disclosed may require extra time and cost.</li><li><strong>Hourly services:</strong> the team works through your stated priorities during the booked time. Completion of every requested task is not guaranteed.</li><li><strong>Changes on the day:</strong> additions need our approval and may change the price or duration. The team may decline unsafe, specialist or out-of-scope work.</li></ul><p>We may use one cleaner or a team. Where a team attends, the total labour time can be divided among team members. For example, two cleaners working for two hours equals four labour hours.</p></section>
        <section class="legal-section reveal" id="pricing"><span class="section-number">04 / PRICING</span><h2>Quotes, prices and extras.</h2><p>Prices are in Australian dollars. Your confirmed booking or written quote sets out the expected price based on the information supplied. You must provide accurate details about the property, its condition and the work required.</p><p>If the property or requested work is materially different from what was described, we will seek your approval before reasonably changing the scope, duration or price where practical. If we cannot contact you, the team may complete only the confirmed scope or stop work where continuing would be unsafe or unreasonable.</p><p>Parking, tolls, specialist equipment, extra labour and optional extras are charged only when disclosed in the booking, quote or approved change.</p></section>
        <section class="legal-section reveal" id="payment"><span class="section-number">05 / PAYMENT</span><h2>Card authorisation and final charge.</h2><p>You authorise our payment provider to verify and charge the payment method supplied for the booking. We may place a pre-authorisation or temporary hold up to 48 hours before the service. If you book less than 48 hours before the service, the hold may be placed immediately.</p><p>A hold is not necessarily a completed charge and its release timing is controlled by your bank or card provider. We generally charge the final amount after the service. Approved extras, additional time, cancellation fees, failed-access fees or other agreed adjustments may change the final amount.</p><p>If payment fails, you must provide another valid payment method promptly. Any refund or adjustment will be processed to the original payment method where practical. Bank processing times are outside our control.</p></section>
        <section class="legal-section reveal" id="access"><span class="section-number">06 / YOUR RESPONSIBILITIES</span><h2>Help us prepare for the service.</h2><p>You must provide safe and timely access to the property, accurate instructions and a working contact number. Before the team arrives, please:</p><ul><li>secure pets and tell us about any safety, access or parking issue</li><li>provide working electricity, hot and cold water, lighting and ventilation</li><li>remove or identify valuables, cash, medication, fragile items and confidential materials</li><li>tell us about damaged, unstable, delicate or specially treated surfaces and items</li><li>ensure areas to be cleaned are reasonably accessible and free from hazardous waste, pests or unsafe conditions</li><li>provide a safe, working vacuum and mop unless you arranged in advance for the team to bring equipment.</li></ul><p>We may pause, modify or refuse work where conditions present a reasonable health or safety risk. This includes aggressive animals, exposed sharps, biological hazards, illegal activity, unsafe structures or harassment.</p></section>
        <section class="legal-section reveal" id="cancellations"><span class="section-number">07 / CHANGES</span><h2>Rescheduling, cancellation and failed access.</h2><p>Please tell us as early as possible if plans change. Cancellation fees reflect the time and resources reserved for your booking and apply only to the extent permitted by law.</p><div class="definition-grid"><div class="definition"><strong>Less than 24 hours</strong><span>A cancellation fee equal to 50% of the booked service price may apply.</span></div><div class="definition"><strong>Same day or on arrival</strong><span>A cancellation fee equal to 100% of the booked service price may apply.</span></div></div><p>You may postpone once without a cancellation fee if you give at least 24 hours' notice and move the service to an available time within the next 7 days. Further changes may be treated as a cancellation.</p><h3>If we cannot enter</h3><p>If the team cannot access the property at the agreed time, we will try to contact you and may wait up to 15 minutes. If access is still unavailable, the booking may be treated as a same-day cancellation and the applicable fee may be charged.</p><h3>If we need to change a booking</h3><p>We may need to change an arrival window, cleaner or date because of illness, emergencies, traffic or other circumstances outside reasonable control. We will give notice as soon as practical and offer a reasonable alternative. If we cancel and cannot provide a suitable alternative, you will not be charged for the unperformed service and any amount paid for it will be refunded.</p></section>
        <section class="legal-section reveal" id="recurring"><span class="section-number">08 / RECURRING SERVICES</span><h2>Ongoing bookings and savings.</h2><p>Recurring services continue at the agreed frequency until cancelled. A recurring schedule does not guarantee the same cleaner, exact arrival time or availability on public holidays, although we will try to maintain consistency.</p><ul><li>weekly and fortnightly Standard or Deep Cleans receive a 10% saving</li><li>Standard or Deep Cleans every 3 or 4 weeks receive a 5% saving</li><li>the saving begins from the second completed service and applies only while the eligible recurring schedule continues.</li></ul><p>If you skip, pause or change frequency, future prices and eligibility may change. Each service remains subject to the cancellation and access terms above.</p></section>
        <section class="legal-section reveal" id="service-issues"><span class="section-number">09 / SERVICE CONCERNS</span><h2>If something was missed.</h2><p>Tell us as soon as possible if an agreed task was missed or the service did not meet the applicable consumer guarantee. For Standard, Deep, Move In and Hourly services, contact us within 24 hours where reasonably possible and include photos or details that help us assess the concern.</p><p>We may inspect the issue, request more information or offer an appropriate remedy, which may include returning to address an agreed missed item, a price adjustment, refund or another remedy required by law. You must give us a reasonable opportunity to assess and, where appropriate, remedy the issue.</p><p>Reporting windows help us verify conditions close to the service time. They do not limit any longer period or remedy available under Australian Consumer Law.</p></section>
        <section class="legal-section reveal" id="end-of-lease"><span class="section-number">10 / END OF LEASE</span><h2>Re-clean support, not a bond promise.</h2><p>For an eligible End of Lease Clean, we provide re-clean support for agreed checklist items raised by you, the landlord or managing agent within 7 days after the original service. Send the relevant feedback and supporting photos within 48 hours of receiving it, and allow reasonable access for any approved return visit.</p><p>This support applies only to tasks included in the confirmed service. It does not cover new dirt, occupied areas, damage, maintenance, mould treatment, pest issues, inaccessible areas or items excluded from the booking.</p><div class="plain-note"><i><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3 4 6v6c0 5 3.3 8 8 9 4.7-1 8-4 8-9V6l-8-3"></path></svg></i><div><strong>About your bond</strong><p>We do not guarantee the return of a rental bond. Bond decisions are made by the landlord, managing agent or relevant authority and can involve matters unrelated to cleaning.</p></div></div><p>The property should be empty unless agreed otherwise, with electricity and water available. Please provide the condition report or agent checklist before the service if you want us to consider it in the confirmed scope.</p></section>
        <section class="legal-section reveal" id="damage"><span class="section-number">11 / DAMAGE OR LOSS</span><h2>Tell us promptly about property damage.</h2><p>If you believe the team caused damage or loss, contact us within 24 hours where reasonably possible. Include photos, purchase or repair information and any other evidence needed to assess what happened. Do not arrange a non-urgent repair before giving us a reasonable opportunity to inspect or respond.</p><p>We are not responsible for ordinary wear, pre-existing damage, inherent defects, deterioration, unstable or poorly installed items, or damage that results from instructions that did not disclose a known risk, except to the extent responsibility cannot lawfully be excluded.</p><p>Keep irreplaceable, high-value or highly fragile items secure and tell us before service about any item requiring special handling.</p></section>
        <section class="legal-section reveal" id="steam"><span class="section-number">12 / CARPET STEAM</span><h2>Carpet steam cleaning.</h2><p>Carpet steam cleaning has a minimum booking of two rooms and is subject to technician availability, property access and the condition and material of the carpet. Stain reduction cannot be guaranteed because results vary with fibre type, age, previous treatments and the nature of the stain.</p><p>You must disclose delicate fibres, existing damage, odours, pet contamination and prior treatments. We may recommend a specialist or decline work that cannot be performed safely.</p></section>
        <section class="legal-section reveal" id="liability"><span class="section-number">13 / YOUR RIGHTS</span><h2>Australian Consumer Law applies.</h2><p>Our services come with consumer guarantees that cannot be excluded under Australian Consumer Law, including that services will be provided with due care and skill, be fit for a disclosed purpose where applicable, and be supplied within a reasonable time when no time is fixed.</p><p>Nothing in these terms excludes, restricts or modifies those guarantees or any other non-excludable right or remedy. Where the law permits us to limit liability, our liability is limited to the reasonable cost of supplying the affected service again or another remedy available by law.</p><p>To the extent permitted by law, we are not liable for indirect or consequential loss that was not reasonably foreseeable when the booking was made. You remain responsible for taking reasonable steps to reduce avoidable loss.</p></section>
        <section class="legal-section reveal" id="website"><span class="section-number">14 / ONLINE SERVICES</span><h2>Website and third-party tools.</h2><p>Website information is general and may change. While we try to keep it accurate and available, errors, interruptions or outdated information may occur. A confirmed quote or booking email takes priority over general website content.</p><p>Our website may use third-party booking, payment, mapping, messaging or analytics tools. Their services may also be governed by their own terms and privacy notices. Maid At Home names, website copy, graphics and branding may not be reproduced or commercially used without permission, except as allowed by law.</p><p>Our handling of personal information is explained in our <a href="/privacy-policy">Privacy Policy</a>.</p></section>
        <section class="legal-section reveal" id="changes"><span class="section-number">15 / GENERAL</span><h2>Changes, governing law and severability.</h2><p>We may update these terms for future bookings when our services, systems or legal obligations change. The version published when you make a booking applies to that booking unless a change is required by law or you agree otherwise.</p><p>If part of these terms is invalid or unenforceable, it is read down or removed to the minimum extent necessary without affecting the remaining terms. A delay in exercising a right does not waive that right.</p><p>These terms are governed by the laws of Victoria, Australia. You and Maid At Home submit to the courts and tribunals with jurisdiction in Victoria, without limiting any right you have to bring a claim elsewhere under applicable consumer law.</p></section>
        <section class="contact-panel reveal" id="contact"><span class="section-number">16 / CONTACT</span><h2>Questions or concerns?</h2><p>Contact Maid At Home before your service if you have a question about these terms. For a complaint, include your booking details and a clear description of the issue so we can respond.</p><a class="button beige" href="mailto:info@maidathome.com.au">info@maidathome.com.au <i><svg viewBox="0 0 20 20" fill="none" stroke="currentColor"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></i></a></section>
        <div class="page-switch reveal"><p>Want to know how we collect, use and protect personal information?</p><a class="text-link" href="/privacy-policy">Read our Privacy Policy <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"><path d="M4 10h11M11 6l4 4-4 4"></path></svg></a></div>
      </article></div></section>
  </main>
  <!-- PAGE CONTENT END -->`;
const contentParts = content.split(/__ASTRO_IMAGE_\d+__/);
const images: Array<Record<string, any>> = [];
---
<SiteLayout title={title} description={description} styles={styles} scripts={scripts} preHeader={preHeader} legacyHeader={true} skipLink={false} yearId="year" currentPath="/terms-and-conditions" bodyClass="">
  {contentParts.map((part, index) => (<>
    <Fragment set:html={part} />
    {images[index] && <OptimizedImage {...images[index]} />}
  </>))}
</SiteLayout>
