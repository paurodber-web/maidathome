const title = `Terms &amp; Conditions | Maid At Home Melbourne`;
const description = `Read the Maid At Home Terms and Conditions covering bookings, payments, cancellations and residential cleaning services across Melbourne.`;
const styles = `:root{--ink:#183042;--soft:#526978;--b900:#153e60;--b800:#1d5077;--b700:#286b9d;--b600:#3d86b9;--b400:#6ea6c9;--b300:#a9d1e7;--b200:#cfe7f3;--b100:#e8f5fb;--b50:#f4fafc;--white:#fff;--g50:#f7f9fa;--g100:#edf2f4;--g200:#dbe4e8;--beige:#f4df9f;--beige2:#fbf2d5;--green:#2e755d;--shadow:0 10px 30px rgba(29,80,119,.08);--shadow2:0 24px 70px rgba(23,63,93,.13);--shell:min(1180px,calc(100% - 48px));--nav:84px;--ease:cubic-bezier(.22,1,.36,1)}*,*:before,*:after{box-sizing:border-box}html{scroll-behavior:smooth;scroll-padding-top:calc(var(--nav) + 25px)}body{margin:0;min-width:320px;overflow-x:clip;color:var(--ink);background:#fff;font:16px/1.65 "DM Sans",Arial,sans-serif;-webkit-font-smoothing:antialiased}body.menu-open{overflow:hidden}button,a{-webkit-tap-highlight-color:transparent}button{font:inherit;color:inherit}a{color:inherit;text-decoration:none}h1,h2,h3,p,ul,ol{margin-top:0}h1,h2,h3{font-family:"Plus Jakarta Sans",Arial,sans-serif;line-height:1.1;letter-spacing:-.04em}p{color:var(--soft)}:focus-visible{outline:3px solid var(--beige);outline-offset:4px}::selection{color:var(--ink);background:var(--beige)}.shell{width:var(--shell);margin-inline:auto}.skip{position:fixed;z-index:1000;top:12px;left:12px;padding:11px 16px;color:#fff;background:var(--b900);border-radius:8px;transform:translateY(-160%);transition:.2s}.skip:focus{transform:none}.reveal{opacity:0;transform:translateY(18px);transition:opacity .7s var(--ease),transform .7s var(--ease)}.reveal.show{opacity:1;transform:none}.kicker{display:flex;align-items:center;gap:10px;margin-bottom:18px;color:var(--b700);font-size:.7rem;font-weight:800;letter-spacing:.14em;line-height:1;text-transform:uppercase}.kicker:before{content:"";width:26px;height:2px;background:currentColor}.button{display:inline-flex;min-height:54px;align-items:center;justify-content:space-between;gap:20px;padding:7px 7px 7px 21px;border:1px solid transparent;border-radius:100px;font-size:.88rem;font-weight:700;line-height:1;transition:transform .35s var(--ease),background .35s}.button:hover{transform:translateY(-2px)}.button i{display:grid;width:40px;height:40px;place-items:center;border-radius:50%;font-style:normal;transition:transform .35s}.button:hover i{transform:rotate(-8deg) translateX(2px)}.button svg{width:16px}.button.blue{color:#fff;background:var(--b700)}.button.blue i{color:var(--b900);background:var(--beige)}.button.beige{color:var(--ink);background:var(--beige)}.button.beige i{color:#fff;background:var(--b800)}.text-link{display:inline-flex;align-items:center;gap:8px;color:var(--b700);font-size:.78rem;font-weight:800}.text-link svg{width:14px;transition:transform .3s}.text-link:hover svg{transform:translateX(4px)}.site-header{position:fixed;z-index:100;top:0;left:0;width:100%;height:var(--nav);color:var(--ink);background:#fff;transition:background .35s,box-shadow .35s}.site-header.scrolled{background:rgba(255,255,255,.96);box-shadow:0 8px 30px rgba(27,63,88,.08);backdrop-filter:blur(14px)}.nav{display:flex;height:100%;align-items:center;justify-content:space-between;gap:28px}.brand{position:relative;z-index:102;display:inline-flex;align-items:center;gap:10px;font-family:"Plus Jakarta Sans";font-size:1.06rem;font-weight:800;letter-spacing:-.035em}.brand-mark{display:grid;width:36px;height:36px;place-items:center;border-radius:11px 11px 16px 11px;color:var(--b800);background:var(--beige);box-shadow:0 7px 17px rgba(24,48,66,.13);transform:rotate(-4deg)}.brand-mark svg{width:21px;transform:rotate(4deg)}.desktop-nav{display:flex;align-items:center;gap:clamp(18px,2.1vw,32px);margin-left:auto}.desktop-nav>a:not(.nav-cta){position:relative;padding-block:8px;font-size:.83rem;font-weight:600}.desktop-nav>a:not(.nav-cta):after{content:"";position:absolute;right:0;bottom:2px;left:0;height:1px;background:currentColor;transform:scaleX(0);transform-origin:right;transition:transform .35s}.desktop-nav>a:hover:after{transform:scaleX(1);transform-origin:left}.nav-cta{display:inline-flex;min-height