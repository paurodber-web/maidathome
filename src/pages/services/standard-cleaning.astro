---
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import { brightCleanLivingRoom } from "../../data/site-images";
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Standard House Cleaning Melbourne — Maid at Home</title>
    <meta name="description" content="Professional standard house cleaning in Melbourne. Trained, insured cleaners, eco-friendly products, consistent results every visit. Book online in 60 seconds." />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px; /* Offset for fixed header */
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: none; }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .si[data-d="l"] { transform: translateX(-24px); }
      .si[data-d="r"] { transform: translateX(24px); }
      .si.in { opacity: 1; transform: none; }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6     { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; }
      .pad    { padding: 6.5rem 0; }
      .pad-sm { padding: 4.5rem 0; }
      #service-nav + #what { padding-top: 8rem; }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--blue); margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: ""; width: 16px; height: 2.5px;
        background: var(--yellow); border-radius: 2px; flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--navy); line-height: 1.15;
      }
      h2.h6 .ac { color: var(--blue); }
      .lead6 {
        font-size: 1.05rem; color: var(--grey);
        line-height: 1.75; max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.95rem;
        padding: 0.95rem 2rem; border-radius: 100px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: var(--font); white-space: nowrap;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4); }
      .btn6-outline {
        display: inline-flex; align-items: center; gap: 0.45rem;
        color: var(--navy); font-weight: 600; font-size: 0.9rem;
        padding: 0.9rem 1.75rem; border-radius: 100px;
        border: 1px solid var(--grey-l); background: transparent;
        text-decoration: none; cursor: pointer; font-family: var(--font); white-space: nowrap;
        transition: border-color 0.25s, background 0.25s, color 0.25s;
      }
      .btn6-outline:hover { border-color: var(--navy); background: var(--sky); }

      .btn6-outline-dark {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: var(--blue); font-weight: 600; font-size: 0.9rem;
        padding: 0.85rem 1.5rem; border-radius: 100px; border: 1.5px solid var(--grey-l);
        text-decoration: none; cursor: pointer; transition: color 0.25s, border-color 0.25s, background 0.25s;
        white-space: nowrap; font-family: var(--font);
      }
      .btn6-outline-dark:hover { color: var(--navy); border-color: var(--blue); background: var(--sky); }

      .btn6-ghost-dark {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: rgba(255,255,255,0.6);
        font-weight: 500; font-size: 0.9rem; border-radius: 100px;
        border: 1px solid rgba(255,255,255,0.15);
        padding: 0.9rem 1.75rem; text-decoration: none;
        font-family: var(--font); white-space: nowrap;
        transition: color 0.25s, border-color 0.25s, background 0.25s;
      }
      .btn6-ghost-dark:hover { color: var(--white); border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.06); }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }

      /* ─── PAGE HERO ───────────────────────────── */
      #std-hero { background: var(--sky); padding-top: 72px; position: relative; overflow: hidden; }
      .std-hero-sun {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      .std-hero-body {
        max-width: 1180px; margin: 0 auto; padding: 4rem 2.5rem 5rem;
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem; align-items: center; position: relative; z-index: 2;
      }
      .ph-breadcrumb {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.78rem; font-weight: 500; color: var(--grey);
        margin-bottom: 1.5rem; animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .ph-breadcrumb a {
        color: var(--grey);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ph-breadcrumb a:hover {
        color: var(--blue);
      }
      .ph-breadcrumb .sep {
        color: var(--grey);
        display: inline-block;
      }

      .std-hero-pill {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.75rem; font-weight: 700; color: var(--blue); letter-spacing: 0.05em;
        margin-bottom: 1.75rem; width: fit-content;
        background: var(--white); padding: 0.4rem 0.9rem; border-radius: 100px;
        box-shadow: var(--shadow-sm); animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .std-hero-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
      
      .std-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 800; letter-spacing: -0.04em;
        line-height: 1.08; color: var(--navy); margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .std-hero-h1 .ac { color: var(--blue); }
      .std-hero-sub {
        font-size: 1.1rem; color: var(--grey); line-height: 1.75; max-width: 500px;
        margin-bottom: 2.25rem; animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .std-hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; animation: fadeUp 0.65s var(--ease) 0.4s both; }
      .std-hero-stats { display: flex; gap: 2rem; padding-top: 2rem; border-top: 1px solid var(--border-subtle); animation: fadeUp 0.65s var(--ease) 0.5s both; }
      .std-stat-val { font-size: 1.6rem; font-weight: 800; color: var(--navy); letter-spacing: -0.03em; line-height: 1; }
      .std-stat-lbl { font-size: 0.75rem; color: var(--grey); margin-top: 0.25rem; }
      .std-stat-div { width: 1px; background: var(--border-subtle); align-self: stretch; }

      /* Floating Booking Summary Card */
      .std-hero-right { display: flex; flex-direction: column; animation: fadeUp 0.8s var(--ease) 0.2s both; }
      .book-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 2.25rem;
        box-shadow: var(--shadow-lg);
        width: 100%;
      }
      .book-card-label { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--grey); margin-bottom: 1.25rem; }
      .book-price-from { font-size: 0.8rem; color: var(--grey); font-weight: 600; }
      .book-price-row { display: flex; align-items: flex-end; gap: 0.5rem; margin-bottom: 0.25rem; }
      .book-price { font-size: 2.5rem; font-weight: 800; color: var(--navy); letter-spacing: -0.05em; line-height: 1; }
      .book-price sup { font-size: 1.1rem; font-weight: 600; vertical-align: top; margin-top: 0.35rem; display: inline-block; }
      .book-price-note { font-size: 0.82rem; color: var(--grey); margin-bottom: 1.5rem; line-height: 1.5; }
      .book-divider { height: 1px; background: var(--border-subtle); margin: 1.5rem 0; }
      .book-includes { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 1.75rem; }
      .book-inc { display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; color: var(--grey-d); line-height: 1.5; }
      .book-inc::before { content: '✓'; color: var(--green); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; }
      .book-cta { display: block; text-align: center; background: var(--yellow); color: var(--navy); font-weight: 700; font-size: 0.95rem; padding: 0.95rem; border-radius: 100px; text-decoration: none; transition: background 0.25s, transform 0.2s, box-shadow 0.25s; margin-bottom: 0.85rem; box-shadow: 0 4px 14px rgba(246,193,51,0.25); }
      .book-cta:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246,193,51,0.4); }
      .book-cta-sub { text-align: center; font-size: 0.76rem; color: var(--grey); }

      /* ─── WHAT IS SECTION ──────────────────────── */
      #what { background: var(--white); }
      .what-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
      .what-visual { position: relative; }
      .what-vis-main {
        background: var(--navy);
        border-radius: var(--r-xl);
        padding: 2.5rem;
        position: relative; overflow: hidden;
        box-shadow: var(--shadow-lg);
      }
      .what-vis-main::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 70% at 80% 20%, rgba(29, 111, 168, 0.25) 0%, transparent 70%); pointer-events: none; }
      .what-vis-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; border-radius: var(--r-xl); }
      .what-vis-content { position: relative; z-index: 1; }
      .what-vis-tag { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 1.5rem; }
      .what-vis-rooms { display: flex; flex-direction: column; gap: 0.65rem; }
      .wvr { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; border-radius: var(--r); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); transition: background 0.2s; }
      .wvr:hover { background: rgba(255,255,255,0.08); }
      .wvr-left { display: flex; align-items: center; gap: 0.75rem; }
      .wvr-icon { font-size: 1.1rem; }
      .wvr-name { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.8); }
      .wvr-status { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; font-weight: 700; }
      .wvr-done { color: var(--green); }
      .wvr-pending { color: rgba(255,255,255,0.25); }
      .what-vis-footer { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between; }
      .what-vis-footer-label { font-size: 0.75rem; color: rgba(255,255,255,0.35); }
      .what-vis-footer-val { font-size: 0.9rem; font-weight: 700; color: var(--yellow); }

      /* Floating Badges */
      .what-float-badge {
        position: absolute;
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 0.8rem 1.25rem;
        box-shadow: var(--shadow-md);
        display: flex; align-items: center; gap: 0.75rem;
      }
      .what-float-badge.badge-tl { top: -1.5rem; left: -1.5rem; }
      .what-float-badge.badge-br { bottom: -1.5rem; right: -1.5rem; }
      .wfb-icon { font-size: 1.25rem; flex-shrink: 0; }
      .wfb-text { font-size: 0.85rem; font-weight: 800; color: var(--navy); white-space: nowrap; }
      .wfb-sub { font-size: 0.72rem; color: var(--grey); margin-top: 0.1rem; }

      .what-copy h2.h6 { margin-bottom: 1.5rem; }
      .what-copy p { font-size: 0.98rem; color: var(--grey); line-height: 1.8; margin-bottom: 1.25rem; }
      .what-copy p:last-of-type { margin-bottom: 2rem; }

      /* ─── INCLUDES SECTION ─────────────────────── */
      #includes { background: var(--sky); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      .includes-top { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; margin-bottom: 3.5rem; }
      
      .checklist-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
        background: var(--border-subtle); border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl); overflow: hidden;
        box-shadow: var(--shadow-sm);
      }
      .cl-room { background: var(--white); padding: 2rem; transition: background 0.25s; }
      .cl-room:hover { background: var(--blue-xl); }
      .cl-room-head { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.25rem; }
      .cl-room-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--sky); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; border: 1px solid var(--border-subtle); transition: background 0.2s; }
      .cl-room:hover .cl-room-icon { background: var(--white); }
      .cl-room-name { font-size: 1.05rem; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
      .cl-items { display: flex; flex-direction: column; gap: 0.55rem; }
      .cl-item { display: flex; align-items: flex-start; gap: 0.55rem; font-size: 0.86rem; color: var(--grey-d); line-height: 1.5; }
      .cl-item::before { content: '✓'; color: var(--blue); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; margin-top: 1px; }

      .cl-note {
        margin-top: 2.25rem;
        background: var(--white); border: 1px solid var(--border-subtle);
        border-radius: var(--r-l); padding: 1.35rem 1.6rem;
        display: flex; align-items: flex-start; gap: 0.85rem;
        box-shadow: var(--shadow-sm);
      }
      .cl-note p { font-size: 0.86rem; color: var(--grey-d); line-height: 1.6; }
      .cl-note strong { color: var(--navy); }

      /* ─── HOW IT WORKS SECTION ────────────────── */
      #how { background: var(--navy); position: relative; overflow: hidden; color: var(--white); }
      #how::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 50% 70% at 90% 10%, rgba(29,111,168,0.18) 0%, transparent 60%); pointer-events: none; }
      #how .eyebrow6 { color: var(--blue-l); }
      #how h2.h6 { color: var(--white); }
      #how .lead6 { color: rgba(255,255,255,0.65); }
      
      .how-layout { display: grid; grid-template-columns: 5fr 7fr; gap: 5rem; align-items: start; margin-top: 4rem; position: relative; z-index: 1; }
      .how-steps { display: flex; flex-direction: column; }
      .how-step { display: flex; gap: 1.5rem; padding: 1.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .how-step:last-child { border-bottom: none; }
      .step-num-wrap { flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
      .step-num-wrap.active { background: var(--yellow); }
      .step-num-wrap.pending { background: rgba(255,255,255,0.05); border: 1.5px solid rgba(255,255,255,0.1); }
      .step-num { font-size: 0.9rem; font-weight: 800; }
      .step-num-wrap.active .step-num { color: var(--navy); }
      .step-num-wrap.pending .step-num { color: rgba(255,255,255,0.3); }
      .step-body h3 { font-size: 1.05rem; font-weight: 700; color: var(--white); margin-bottom: 0.35rem; padding-top: 0.5rem; letter-spacing: -0.01em; }
      .step-body p { font-size: 0.88rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

      .how-right { display: flex; flex-direction: column; gap: 1.25rem; }
      .expect-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: var(--r-xl);
        padding: 1.6rem;
        display: flex; gap: 1.1rem;
        align-items: flex-start;
        transition: background 0.25s, border-color 0.25s;
      }
      .expect-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
      .expect-icon { font-size: 1.35rem; flex-shrink: 0; margin-top: 2px; }
      .expect-body h4 { font-size: 0.98rem; font-weight: 700; color: var(--white); margin-bottom: 0.35rem; letter-spacing: -0.01em; }
      .expect-body p { font-size: 0.84rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

      /* ─── WHEN TO BOOK SECTION ────────────────── */
      #ideal { background: var(--white); }
      .ideal-layout { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: start; }
      .ideal-scenarios { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
      .ideal-scenario {
        display: flex; gap: 1.25rem;
        padding: 1.75rem;
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        background: var(--white);
        transition: border-color 0.25s, background 0.25s, transform 0.25s, box-shadow 0.25s;
        cursor: default;
        box-shadow: var(--shadow-sm);
      }
      .ideal-scenario:hover { border-color: var(--border-hover); background: var(--sky); transform: translateX(4px); box-shadow: var(--shadow-md); }
      .is-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--sky); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; border: 1px solid var(--border-subtle); transition: background 0.25s; }
      .ideal-scenario:hover .is-icon { background: var(--white); }
      .is-body h4 { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 0.35rem; letter-spacing: -0.01em; }
      .is-body p { font-size: 0.88rem; color: var(--grey); line-height: 1.65; }

      .ideal-right { display: flex; flex-direction: column; gap: 1.75rem; }
      .not-ideal-box {
        background: var(--sky); border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl); padding: 2rem;
        box-shadow: var(--shadow-sm);
      }
      .not-ideal-box h3 { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 0.45rem; letter-spacing: -0.01em; }
      .not-ideal-box > p { font-size: 0.88rem; color: var(--grey); line-height: 1.65; margin-bottom: 1.5rem; }
      .not-ideal-items { display: flex; flex-direction: column; gap: 0.65rem; }
      .ni-item { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.85rem; color: var(--grey-d); line-height: 1.5; }
      .ni-item::before { content: '→'; color: var(--blue); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; margin-top: 1px; }

      .service-nudge {
        background: var(--navy); border-radius: var(--r-xl); padding: 2rem;
        position: relative; overflow: hidden;
        box-shadow: var(--shadow-md);
      }
      .service-nudge::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 80% at 100% 100%, rgba(29, 111, 168, 0.2) 0%, transparent 70%); pointer-events: none; }
      .service-nudge h3 { font-size: 1.05rem; font-weight: 700; color: var(--white); margin-bottom: 0.5rem; position: relative; z-index: 1; letter-spacing: -0.01em; }
      .service-nudge p { font-size: 0.86rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 1.5rem; position: relative; z-index: 1; }
      .nudge-links { display: flex; flex-direction: column; gap: 0.65rem; position: relative; z-index: 1; }
      .nudge-link {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.85rem 1.15rem;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
        border-radius: var(--r); text-decoration: none;
        transition: background 0.2s, border-color 0.2s;
      }
      .nudge-link:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }
      .nl-name { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.85); }
      .nl-arrow { color: rgba(255,255,255,0.3); font-size: 0.95rem; transition: transform 0.2s; }
      .nudge-link:hover .nl-arrow { transform: translateX(3px); color: var(--white); }

      /* ─── PRICING SECTION ─────────────────────── */
      #pricing { background: var(--sky); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      .pricing-layout { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: start; }
      .pricing-copy h2.h6 { margin-bottom: 1.25rem; }
      .freq-perks { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 2.25rem; margin-top: 1.75rem; }
      .freq-perk { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.92rem; color: var(--grey-d); line-height: 1.6; }
      .freq-perk::before { content: '✓'; color: var(--blue); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; width: 18px; height: 18px; background: var(--white); border: 1px solid var(--border-subtle); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-top: 2px; }
      
      .pricing-panel { display: flex; flex-direction: column; gap: 1.25rem; }
      .pricing-model-tabs { display: flex; gap: 0; background: var(--grey-l); border: 1px solid var(--border-subtle); border-radius: var(--r); padding: 4px; }
      .pmt-tab { flex: 1; text-align: center; padding: 0.7rem; font-size: 0.88rem; font-weight: 700; color: var(--grey); border-radius: 8px; cursor: pointer; transition: all 0.25s var(--ease); border: none; background: none; font-family: var(--font); }
      .pmt-tab.on { background: var(--white); color: var(--navy); box-shadow: var(--shadow-sm); }

      #flat-panel .bed-rows { display: flex; flex-direction: column; gap: 0.65rem; }
      .bed-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.1rem 1.5rem;
        background: var(--white); border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s, background 0.2s;
      }
      .bed-row:hover { border-color: var(--border-hover); background: var(--sky); }
      .bed-row.featured { background: var(--navy); border-color: var(--navy); }
      .bed-row.featured:hover { background: var(--blue-d); }
      .bed-info { display: flex; flex-direction: column; }
      .bed-label { font-size: 0.95rem; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
      .bed-row.featured .bed-label { color: var(--white); }
      .bed-sublabel { font-size: 0.76rem; color: var(--grey); margin-top: 0.15rem; }
      .bed-row.featured .bed-sublabel { color: rgba(255,255,255,0.4); }
      .bed-price { font-size: 1.35rem; font-weight: 800; color: var(--blue); letter-spacing: -0.03em; }
      .bed-row.featured .bed-price { color: var(--yellow); }
      .bed-pop { font-size: 0.68rem; font-weight: 800; background: var(--yellow); color: var(--navy); padding: 0.25rem 0.65rem; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; }

      .freq-disc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; margin-top: 0.5rem; }
      .fd-card {
        padding: 1.1rem; border-radius: var(--r-l);
        border: 1px solid var(--border-subtle); background: var(--white);
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s, background 0.2s;
      }
      .fd-card:hover { border-color: var(--border-hover); background: var(--sky); }
      .fd-card.fd-featured { background: linear-gradient(135deg, var(--blue-d), var(--navy)); border-color: var(--navy); }
      .fd-name { font-size: 0.9rem; font-weight: 700; color: var(--navy); }
      .fd-card.fd-featured .fd-name { color: var(--white); }
      .fd-cadence { font-size: 0.75rem; color: var(--grey); margin-bottom: 0.5rem; }
      .fd-card.fd-featured .fd-cadence { color: rgba(255,255,255,0.45); }
      .fd-disc { font-size: 1.15rem; font-weight: 800; color: var(--green); letter-spacing: -0.02em; }
      .fd-card.fd-featured .fd-disc { color: var(--yellow); }

      #hourly-panel .hr-main { background: var(--white); border: 1px solid var(--border-subtle); border-radius: var(--r-l); padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--shadow-sm); }
      .hr-rate-label { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--grey); margin-bottom: 0.35rem; }
      .hr-rate-val { font-size: 2.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.04em; line-height: 1; }
      .hr-rate-val sup { font-size: 0.95rem; font-weight: 600; vertical-align: top; margin-top: 0.15rem; display: inline-block; }
      .hr-rate-val span { font-size: 0.9rem; font-weight: 500; color: var(--grey); }
      .hr-min-badge { background: var(--blue-xl); border: 1px solid var(--border-subtle); border-radius: var(--r); padding: 0.45rem 0.85rem; font-size: 0.78rem; font-weight: 700; color: var(--blue); }
      
      .panel { display: none; }
      .panel.active { display: block; }

      /* ─── TESTIMONIALS SECTION ────────────────── */
      #reviews { background: var(--white); }
      .reviews-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3.5rem; flex-wrap: wrap; gap: 1rem; }
      .g-badge { display: flex; align-items: center; gap: 0.5rem; background: var(--sky); border: 1px solid var(--border-subtle); border-radius: 100px; padding: 0.45rem 1.15rem; font-size: 0.82rem; color: var(--navy); font-weight: 700; box-shadow: var(--shadow-sm); }
      .g-logo { font-weight: 800; font-size: 0.9rem; background: linear-gradient(180deg,#4285F4 0%,#34A853 33%,#FBBC05 66%,#EA4335 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      
      .t-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .t-card { background: var(--sky); border: 1px solid var(--border-subtle); border-radius: var(--r-xl); padding: 2rem; transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s; box-shadow: var(--shadow-sm); }
      .t-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-md); transform: translateY(-3px); }
      .t-stars { color: var(--yellow); font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 0.85rem; }
      .t-text { font-size: 0.92rem; line-height: 1.7; color: var(--grey-d); margin-bottom: 1.5rem; font-style: italic; }
      .t-author { display: flex; align-items: center; gap: 0.75rem; border-top: 1px solid var(--border-subtle); padding-top: 1.25rem; }
      .t-avatar { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: var(--white); flex-shrink: 0; }
      .t-name { font-size: 0.9rem; font-weight: 700; color: var(--navy); }
      .t-meta { font-size: 0.75rem; color: var(--grey); margin-top: 0.1rem; }
      .t-verified { display: flex; align-items: center; gap: 0.25rem; font-size: 0.72rem; color: var(--green); font-weight: 700; margin-top: 0.15rem; }

      /* ─── FAQ SECTION ─────────────────────────── */
      #faq { background: var(--sky); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      .faq-layout { display: grid; grid-template-columns: 4fr 8fr; gap: 5rem; align-items: start; }
      .faq-contact { margin-top: 2.25rem; background: var(--white); border: 1px solid var(--border-subtle); border-radius: var(--r-l); padding: 1.5rem; box-shadow: var(--shadow-sm); }
      .faq-contact p { font-size: 0.88rem; color: var(--grey); line-height: 1.65; margin: 0; }
      .faq-contact a { color: var(--blue); font-weight: 700; text-decoration: none; }
      .faq-list { border-top: 1px solid var(--border-subtle); }
      .faq-item { border-bottom: 1px solid var(--border-subtle); }
      .faq-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.35rem 0; cursor: pointer; background: none; border: none; width: 100%; font-family: var(--font); font-size: 0.95rem; font-weight: 700; color: var(--navy); text-align: left; transition: color 0.2s; }
      .faq-q:hover { color: var(--blue); }
      .faq-q-icon { width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; border: 1px solid var(--grey-l); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--grey); font-weight: 400; transition: all 0.3s var(--ease); line-height: 1; }
      .faq-item.open .faq-q-icon { background: var(--yellow); border-color: var(--yellow); color: var(--navy); transform: rotate(45deg); }
      .faq-a { font-size: 0.9rem; color: var(--grey); line-height: 1.75; max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease), padding 0.3s; }
      .faq-item.open .faq-a { max-height: 300px; padding-bottom: 1.35rem; }

      /* ─── OTHER SERVICES SECTION ──────────────── */
      #other-services { background: var(--white); }
      .other-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; }
      .other-card {
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 2rem;
        text-decoration: none;
        background: var(--white);
        box-shadow: var(--shadow-sm);
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s, background 0.25s;
        display: flex; flex-direction: column;
      }
      .other-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-md); transform: translateY(-3px); background: var(--sky); }
      .other-card-icon { width: 46px; height: 46px; border-radius: 11px; background: var(--sky); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; margin-bottom: 1.25rem; border: 1px solid var(--border-subtle); transition: background 0.25s, transform 0.25s; }
      .other-card:hover .other-card-icon { background: var(--white); transform: scale(1.06); }
      .other-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 0.45rem; letter-spacing: -0.01em; }
      .other-card p { font-size: 0.86rem; color: var(--grey); line-height: 1.6; flex: 1; }
      .other-card-link { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.82rem; font-weight: 700; color: var(--blue); margin-top: 1.25rem; opacity: 0; transform: translateX(-4px); transition: opacity 0.25s, transform 0.25s; }
      .other-card:hover .other-card-link { opacity: 1; transform: none; }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 { background: var(--navy); padding: 4.5rem 2.5rem 2.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
      .ft6-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3.5rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .ft6-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.7; margin-top: 0.85rem; max-width: 280px; }
      .ft6-logo { font-size: 1.2rem; font-weight: 800; color: rgba(255,255,255,0.85); letter-spacing: -0.02em; }
      .ft6-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
      .ft6-col a { display: block; font-size: 0.88rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.2s; }
      .ft6-col a:hover { color: rgba(255,255,255,0.85); }
      .ft6-bottom { max-width: 1180px; margin: 1.75rem auto 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      .ft6-bottom span, .ft6-bottom a { font-size: 0.78rem; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
      .ft6-bottom a:hover { color: rgba(255,255,255,0.6); }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .std-hero-body { grid-template-columns: 1fr; gap: 3rem; }
        /* .std-hero-right { display: none; } */
        .what-layout, .includes-top, .how-layout, .ideal-layout, .pricing-layout, .faq-layout { grid-template-columns: 1fr; gap: 3rem; }
        .checklist-grid { grid-template-columns: 1fr; }
        .t-grid { grid-template-columns: 1fr 1fr; }
        .other-grid { grid-template-columns: 1fr 1fr; }
        .cta6-grid { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-right { height: 320px; }
        .ft6-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      }
      @media (max-width: 768px) {
        .std-hero-body { padding: 4rem 1.5rem 3rem; }
        .cta6-left { padding: 2.5rem 1.5rem; }
        .c6 { padding: 0 1.5rem; }
        .pad { padding: 4.5rem 0; }
        .ft6-inner { grid-template-columns: 1fr; gap: 2rem; }
      }
      /* Dropdown style system */
      .hd6-nav-item-dropdown {
        position: relative;
        display: inline-block;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: var(--white);
        min-width: 220px;
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-lg);
        padding: 0.65rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250;
        display: flex;
        flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
