---
import SiteFooter from "../components/SiteFooter.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { brightCleanLivingRoom } from "../data/site-images";
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All Services & Checklists — Maid at Home Melbourne</title>
    <meta name="description" content="Explore our complete range of house cleaning services in Melbourne. Checklists and pricing for Standard, Deep Clean, End of Lease, and Move In services." />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global define:vars={{ plusJakartaFontSrc: `url("${withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}") format("woff2")`, loraFontSrc: `url("${withBase("fonts/lora-latin-normal.woff2")}") format("woff2")`, loraItalicFontSrc: `url("${withBase("fonts/lora-latin-italic.woff2")}") format("woff2")` }}>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: var(--plusJakartaFontSrc);
      }

      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 120px; /* Offset for fixed header + sticky nav */
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: none; }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .si[data-d="l"] { transform: translateX(-24px); }
      .si[data-d="r"] { transform: translateX(24px); }
      .si.in { opacity: 1; transform: none; }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6     { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; }
      .pad    { padding: 6.5rem 0; }
      .pad-sm { padding: 4.5rem 0; }
      #service-nav + #standard { padding-top: 8rem; }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--blue); margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: ""; width: 16px; height: 2.5px;
        background: var(--yellow); border-radius: 2px; flex-shrink: 0;
      }
      .h6 {
        display: block;
        margin: 0;
        font-family: var(--font);
font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--navy); line-height: 1.15;
      }
      .h6 .ac { color: var(--blue); }
      .lead6 {
        font-size: 1.05rem; color: var(--grey);
        line-height: 1.75; max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.95rem;
        padding: 0.95rem 2rem; border-radius: 100px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: var(--font); white-space: nowrap;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4); }
      .btn6-outline {
        display: inline-flex; align-items: center; gap: 0.45rem;
        color: var(--navy); font-weight: 600; font-size: 0.9rem;
        padding: 0.9rem 1.75rem; border-radius: 100px;
        border: 1px solid var(--grey-l); background: transparent;
        text-decoration: none; cursor: pointer; font-family: var(--font); white-space: nowrap;
        transition: border-color 0.25s, background 0.25s, color 0.25s;
      }
      .btn6-outline:hover { border-color: var(--navy); background: var(--sky); }

      .btn6-outline-dark {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: var(--blue); font-weight: 600; font-size: 0.9rem;
        padding: 0.85rem 1.5rem; border-radius: 100px; border: 1.5px solid var(--grey-l);
        text-decoration: none; cursor: pointer; transition: color 0.25s, border-color 0.25s, background 0.25s;
        white-space: nowrap; font-family: var(--font);
      }
      .btn6-outline-dark:hover { color: var(--navy); border-color: var(--blue); background: var(--sky); }

      .btn6-ghost-dark {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: rgba(255,255,255,0.6);
        font-weight: 500; font-size: 0.9rem; border-radius: 100px;
        border: 1px solid rgba(255,255,255,0.15);
        padding: 0.9rem 1.75rem; text-decoration: none;
        font-family: var(--font); white-space: nowrap;
        transition: color 0.25s, border-color 0.25s, background 0.25s;
      }
      .btn6-ghost-dark:hover { color: var(--white); border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.06); }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }

      /* ─── PAGE HERO ───────────────────────────── */
      #services-hero { background: var(--sky); padding-top: 72px; position: relative; overflow: hidden; }
      .services-hero-sun {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      .services-hero-body {
        max-width: 1180px; margin: 0 auto; padding: 4rem 2.5rem 5rem;
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem; align-items: center; position: relative; z-index: 2;
      }
      .ph-breadcrumb {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.78rem; font-weight: 500; color: var(--grey);
        margin-bottom: 1.5rem; animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .ph-breadcrumb a { color: var(--grey); text-decoration: none; transition: color 0.2s; }
      .ph-breadcrumb a:hover { color: var(--blue); }
      .ph-breadcrumb span { color: var(--grey-l); }
      .services-hero-pill {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.75rem; font-weight: 700; color: var(--blue); letter-spacing: 0.05em;
        margin-bottom: 1.75rem; width: fit-content;
        background: var(--white); padding: 0.4rem 0.9rem; border-radius: 100px;
        box-shadow: var(--shadow-sm); animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .services-hero-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--yellow); flex-shrink: 0; }

      .services-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 800; letter-spacing: -0.04em;
        line-height: 1.08; color: var(--navy); margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .services-hero-h1 .ac { color: var(--blue); }
      .services-hero-sub {
        font-size: 1.1rem; color: var(--grey); line-height: 1.75; max-width: 500px;
        margin-bottom: 2.25rem; animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .services-hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; animation: fadeUp 0.65s var(--ease) 0.4s both; }
      
      /* Hero Right Overview Cards */
      .services-hero-right { display: flex; flex-direction: column; gap: 0.75rem; animation: fadeUp 0.8s var(--ease) 0.2s both; }
      
      .ph-service-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-l);
        padding: 1.15rem 1.5rem;
        display: flex; align-items: center; gap: 1rem;
        box-shadow: var(--shadow-sm);
        transition: background 0.25s, border-color 0.25s, transform 0.25s, box-shadow 0.25s;
        text-decoration: none;
        cursor: pointer;
      }
      .ph-service-card:hover {
        background: var(--sky);
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }
      .ph-card-icon {
        width: 42px; height: 42px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; flex-shrink: 0;
        border: 1px solid var(--border-subtle);
        background: var(--sky);
        transition: background 0.25s;
      }
      .ph-service-card:hover .ph-card-icon { background: var(--blue-xl); }
      .ph-card-body { flex: 1; }
      .ph-card-name { font-size: 0.95rem; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
      .ph-card-desc { font-size: 0.8rem; color: var(--grey); margin-top: 0.1rem; }
      .ph-card-price { font-size: 0.85rem; font-weight: 700; color: var(--blue); white-space: nowrap; }
      .ph-card-arrow { color: var(--grey-l); font-size: 1rem; flex-shrink: 0; transition: transform 0.2s, color 0.2s; }
      .ph-service-card:hover .ph-card-arrow { transform: translateX(3px); color: var(--blue); }

      #service-nav {
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 64px;
        z-index: 150;
      }
      .pnav-inner { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; display: flex; align-items: center; gap: 0.5rem; overflow-x: auto; scrollbar-width: none; }
      .pnav-inner::-webkit-scrollbar { display: none; }
      .pnav-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--grey); padding: 1.1rem 1.15rem; text-decoration: none; white-space: nowrap; border-bottom: 3px solid transparent; margin-bottom: -1px; transition: color 0.25s, border-color 0.25s; }
      .pnav-link:hover { color: var(--blue); }
      .pnav-link.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 700; }

      /* ─── SERVICE SECTIONS GENERAL ────────────── */
      #standard, #deep, #eol, #movein, #addons, #compare {
        padding-top: 3rem;
      }
      .svc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
      
      .svc-tag {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--blue-xl); border: 1px solid var(--border-subtle);
        border-radius: 6px; padding: 0.35rem 0.75rem; margin-bottom: 1.25rem;
        font-size: 0.72rem; font-weight: 700; color: var(--blue); letter-spacing: 0.06em; text-transform: uppercase;
      }
      .svc-includes-list { display: flex; flex-direction: column; border-top: 1px solid var(--grey-l); margin-bottom: 2.25rem; margin-top: 1.5rem; }
      .svc-inc-item {
        display: flex; align-items: flex-start; gap: 0.75rem;
        padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l);
        font-size: 0.9rem; color: var(--grey-d); line-height: 1.55;
      }
      .svc-inc-icon { font-size: 1rem; flex-shrink: 0; margin-top: 2px; }
      .svc-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
      
      .svc-panel {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 2.25rem;
        box-shadow: var(--shadow-sm);
      }
      .svc-panel-title { font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.35rem; letter-spacing: -0.01em; }
      .svc-panel-sub { font-size: 0.85rem; color: var(--grey); margin-bottom: 1.5rem; line-height: 1.5; }
      .svc-checklist { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 1.75rem; }
      .svc-chk {
        display: flex; align-items: flex-start; gap: 0.6rem;
        font-size: 0.86rem; color: var(--grey-d); line-height: 1.5;
      }
      .svc-chk::before { content: '✓'; color: var(--green); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; margin-top: 1px; }
      
      .svc-price-box {
        background: var(--navy); border-radius: var(--r-l);
        padding: 1.25rem 1.75rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        box-shadow: var(--shadow-md);
      }
      .spb-label { font-size: 0.72rem; color: rgba(255,255,255,0.45); margin-bottom: 0.15rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
      .spb-price { font-size: 1.85rem; font-weight: 800; color: var(--white); letter-spacing: -0.04em; line-height: 1; }
      .spb-price sup { font-size: 0.95rem; font-weight: 600; vertical-align: top; margin-top: 0.15rem; display: inline-block; }
      .spb-note { font-size: 0.73rem; color: rgba(255,255,255,0.35); margin-top: 0.25rem; }
      .svc-freq-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 1rem; }
      .freq-badge {
        font-size: 0.75rem; font-weight: 600;
        padding: 0.3rem 0.75rem; border-radius: 100px;
        background: var(--blue-xl); border: 1px solid var(--border-subtle); color: var(--blue);
      }
      .freq-badge.featured {
        background: var(--green-l); border-color: rgba(22,163,74,0.15); color: var(--green);
      }

      /* Standard Clean (White) */
      #standard { background: var(--white); }

      /* Deep Clean (Sky/Gradient) */
      #deep { background: var(--sky); position: relative; overflow: hidden; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      #deep .svc-panel { background: var(--white); }
      .deep-badge {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow-l); border: 1px solid rgba(246,193,51,0.25);
        border-radius: 6px; padding: 0.35rem 0.75rem; margin-bottom: 1.25rem;
        font-size: 0.72rem; font-weight: 700; color: var(--yellow-d); letter-spacing: 0.06em; text-transform: uppercase;
      }

      /* End of Lease (Navy/Dark) */
      #eol { background: var(--navy); position: relative; overflow: hidden; color: var(--white); }
      #eol .h6 { display: block;
        margin: 0;
        font-family: var(--font);
color: var(--white); }
      #eol .eyebrow6 { color: var(--blue-l); }
      #eol .lead6 { color: rgba(255,255,255,0.6); }
      #eol .svc-tag {
        background: rgba(246, 193, 51, 0.1); border-color: rgba(246, 193, 51, 0.2);
        color: var(--yellow);
      }
      #eol .svc-includes-list { border-top-color: rgba(255,255,255,0.08); }
      #eol .svc-inc-item { border-bottom-color: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); }
      #eol .svc-panel {
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.06);
      }
      #eol .svc-panel-title { color: var(--white); }
      #eol .svc-panel-sub { color: rgba(255,255,255,0.4); }
      #eol .svc-chk { color: rgba(255,255,255,0.7); }
      #eol .svc-chk::before { color: var(--yellow); }
      
      .eol-guarantee-box {
        background: rgba(246, 193, 51, 0.06);
        border: 1px solid rgba(246, 193, 51, 0.18);
        border-radius: var(--r); padding: 1.15rem; margin-top: 1.5rem;
      }
      .eol-guarantee-box strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--yellow); margin-bottom: 0.25rem; }
      .eol-guarantee-box p { font-size: 0.8rem; color: rgba(255,255,255,0.5); line-height: 1.5; }
      
      .eol-stat-row { display: flex; gap: 1.5rem; margin-top: 2rem; flex-wrap: wrap; }
      .eol-stat { flex: 1; min-width: 100px; }
      .eol-stat-val { font-size: 2rem; font-weight: 800; color: var(--white); letter-spacing: -0.04em; line-height: 1; }
      .eol-stat-val span { color: var(--yellow); }
      .eol-stat-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.25rem; font-weight: 500; }

      /* Move In Clean (White) */
      #movein { background: var(--white); }
      .movein-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
      .movein-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 1.75rem;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
        box-shadow: var(--shadow-sm);
      }
      .movein-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-md); transform: translateY(-3px); }
      .movein-card-icon {
        width: 46px; height: 46px; border-radius: 12px;
        background: var(--sky); display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem; margin-bottom: 1.25rem;
        border: 1px solid var(--border-subtle);
        transition: background 0.25s, transform 0.25s;
      }
      .movein-card:hover .movein-card-icon { background: var(--blue-xl); transform: scale(1.05); }
      .movein-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 0.45rem; letter-spacing: -0.01em; }
      .movein-card p { font-size: 0.86rem; color: var(--grey); line-height: 1.6; }
      
      .movein-bottom {
        display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: start; margin-top: 4.5rem;
      }
      .movein-includes .svc-checklist { column-count: 2; column-gap: 2rem; display: block; }
      .movein-includes .svc-chk { break-inside: avoid; display: flex; margin-bottom: 0.65rem; }
      
      .movein-price-wrap { display: flex; flex-direction: column; gap: 1.25rem; }
      .movein-price-card {
        background: var(--white);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        padding: 1.75rem;
        box-shadow: var(--shadow-sm);
      }
      .mpc-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
      .mpc-label { font-size: 0.75rem; font-weight: 800; color: var(--grey); text-transform: uppercase; letter-spacing: 0.08em; }
      .mpc-tag { font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.65rem; border-radius: 100px; background: var(--green-l); color: var(--green); border: 1px solid rgba(22,163,74,0.15); }
      .mpc-price { font-size: 2.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.04em; line-height: 1; margin-bottom: 0.25rem; }
      .mpc-price sup { font-size: 0.95rem; font-weight: 600; vertical-align: top; margin-top: 0.15rem; }
      .mpc-note { font-size: 0.78rem; color: var(--grey); }

      /* Add-Ons (Sky/Gradient) */
      #addons { background: var(--sky); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      .addons-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; margin-bottom: 3.5rem; }
      .addons-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
      }
      .addon-item {
        padding: 1.85rem 1.6rem;
        border-right: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
        background: var(--white);
        transition: background 0.25s, transform 0.25s;
        position: relative;
      }
      .addon-item:nth-child(4n) { border-right: none; }
      .addon-item:nth-child(n+5) { border-bottom: none; }
      .addon-item:hover { background: var(--sky); }
      .addon-icon {
        width: 44px; height: 44px;
        background: var(--sky); border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; margin-bottom: 1.1rem;
        border: 1px solid var(--border-subtle);
        transition: background 0.25s, transform 0.25s;
      }
      .addon-item:hover .addon-icon { background: var(--blue-xl); transform: scale(1.05); }
      .addon-name { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.4rem; letter-spacing: -0.01em; }
      .addon-desc { font-size: 0.82rem; color: var(--grey); line-height: 1.6; margin-bottom: 1.25rem; }
      .addon-price-row { display: flex; align-items: center; justify-content: space-between; }
      .addon-price { font-size: 1.1rem; font-weight: 800; color: var(--blue); letter-spacing: -0.02em; }
      .addon-add-btn {
        font-size: 0.75rem; font-weight: 700;
        padding: 0.4rem 0.85rem; border-radius: 100px;
        background: var(--yellow); color: var(--navy);
        border: none; cursor: pointer;
        transition: background 0.2s, transform 0.2s, color 0.2s;
        box-shadow: 0 2px 6px rgba(246,193,51,0.25);
      }
      .addon-add-btn:hover { background: var(--yellow-d); transform: scale(1.03); }
      
      .addons-note {
        background: var(--blue-xl); border: 1px solid var(--border-subtle);
        border-radius: var(--r-l); padding: 1.35rem 1.6rem;
        display: flex; align-items: flex-start; gap: 0.85rem;
        margin-top: 2rem;
        box-shadow: var(--shadow-sm);
      }
      .addons-note-icon { font-size: 1.15rem; flex-shrink: 0; margin-top: 1px; }
      .addons-note p { font-size: 0.85rem; color: var(--blue-d); line-height: 1.6; }
      .addons-note strong { font-weight: 700; color: var(--navy); }

      /* Compare Table (White) */
      #compare { background: var(--white); }
      .compare-table-wrap { overflow-x: auto; margin-top: 3.5rem; border-radius: var(--r-xl); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-md); }
      .compare-table {
        width: 100%; border-collapse: collapse;
        overflow: hidden;
      }
      .compare-table th {
        padding: 1.2rem 1.35rem;
        font-size: 0.8rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase;
        color: var(--white); background: var(--navy);
        text-align: center; border-right: 1px solid rgba(255,255,255,0.06);
      }
      .compare-table th:first-child { text-align: left; }
      .compare-table th:last-child { border-right: none; }
      .compare-table td {
        padding: 1.1rem 1.35rem;
        font-size: 0.9rem; color: var(--grey-d);
        border-right: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle);
        text-align: center; background: var(--white);
      }
      .compare-table td:first-child { text-align: left; font-weight: 600; color: var(--navy); background: var(--sky); }
      .compare-table tr:last-child td { border-bottom: none; }
      .compare-table tr:hover td { background: var(--sky); }
      .compare-table tr:hover td:first-child { background: var(--blue-xl); }
      .ct-yes { color: var(--green); font-size: 1.1rem; font-weight: bold; }
      .ct-no { color: var(--grey-l); font-size: 1.1rem; }
      .ct-partial { font-size: 0.8rem; font-weight: 700; color: var(--blue); }
      .ct-col-highlight { background: var(--sky) !important; }
      .ct-head-highlight { background: var(--blue) !important; }

      /* Recurring Banner (Navy Card) */
      #rec-banner-sec { background: var(--white); }
      .rec-banner-card {
        background: var(--navy); border-radius: var(--r-xl);
        padding: 4.5rem; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: center;
        position: relative; overflow: hidden; box-shadow: var(--shadow-premium);
        color: var(--white);
      }
      .rec-banner-card::before {
        content: ""; position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 60% at 80% 50%, rgba(29, 111, 168, 0.15) 0%, transparent 70%);
        pointer-events: none;
      }
      .rec-banner-card .h6 { display: block;
        margin: 0;
        font-family: var(--font);
color: var(--white); }
      .rec-banner-card .lead6 { color: rgba(255,255,255,0.6); }
      
      .rec-discount-stack { display: flex; flex-direction: column; gap: 0.65rem; align-items: stretch; flex-shrink: 0; position: relative; z-index: 2; }
      .rec-disc {
        display: flex; align-items: center; justify-content: space-between; gap: 2rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: var(--r); padding: 0.95rem 1.35rem;
      }
      .rec-disc-freq { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.8); }
      .rec-disc-save { font-size: 0.85rem; font-weight: 800; color: var(--green); background: var(--green-l); padding: 0.25rem 0.65rem; border-radius: 100px; }
      .rec-disc.featured-disc {
        background: rgba(246, 193, 51, 0.08);
        border-color: rgba(246, 193, 51, 0.18);
      }
      .rec-disc.featured-disc .rec-disc-freq { color: var(--yellow); font-weight: 700; }
      .rec-disc.featured-disc .rec-disc-save { color: var(--navy); background: var(--yellow); }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 { background: var(--navy); padding: 4.5rem 2.5rem 2.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
      .ft6-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3.5rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .ft6-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.7; margin-top: 0.85rem; max-width: 280px; }
      .ft6-logo { font-size: 1.2rem; font-weight: 800; color: rgba(255,255,255,0.85); letter-spacing: -0.02em; }
      .ft6-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
      .ft6-col a { display: block; font-size: 0.88rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.2s; }
      .ft6-col a:hover { color: rgba(255,255,255,0.85); }
      .ft6-bottom { max-width: 1180px; margin: 1.75rem auto 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      .ft6-bottom span, .ft6-bottom a { font-size: 0.78rem; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
      .ft6-bottom a:hover { color: rgba(255,255,255,0.6); }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .services-hero-body { grid-template-columns: 1fr; gap: 3rem; }
        .services-hero-right { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
        .svc-layout { grid-template-columns: 1fr; gap: 3rem; }
        .movein-cards { grid-template-columns: 1fr 1fr; }
        .movein-bottom { grid-template-columns: 1fr; gap: 2.5rem; }
        .addons-grid { grid-template-columns: repeat(2, 1fr); }
        .addon-item:nth-child(4n) { border-right: 1px solid var(--border-subtle); }
        .addon-item:nth-child(2n) { border-right: none; }
        .addon-item:nth-child(n+5) { border-bottom: 1px solid var(--border-subtle); }
        .addon-item:nth-last-child(-n+2) { border-bottom: none; }
        .addons-intro { grid-template-columns: 1fr; gap: 1rem; }
        .rec-banner-card { grid-template-columns: 1fr; gap: 2.5rem; padding: 3rem; }
        .rec-discount-stack { align-items: stretch; flex-direction: row; flex-wrap: wrap; }
        .rec-disc { flex: 1 1 calc(50% - 0.5rem); min-width: 200px; }
        .cta6-grid { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-right { height: 320px; }
        .ft6-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      }
      @media (max-width: 768px) {
        .services-hero-body { padding: 4rem 1.5rem 3rem; }
        .cta6-left { padding: 2.5rem 1.5rem; }
        .c6 { padding: 0 1.5rem; }
        .pad { padding: 4.5rem 0; }
        .ft6-inner { grid-template-columns: 1fr; gap: 2rem; }
      }
      /* Dropdown style system */
      .hd6-nav-item-dropdown {
        position: relative;
        display: inline-block;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: var(--white);
        min-width: 220px;
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-lg);
        padding: 0.65rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250;
        display: flex;
        flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .hd6-dropdown-menu a {
        display: block !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        color: var(--grey-d) !important;
        padding: 0.6rem 1.25rem !important;
        border-radius: 0 !important;
        transition: background 0.2s, color 0.2s !important;
        text-align: left;
      }
      .hd6-dropdown-menu a:hover {
        background: var(--sky) !important;
        color: var(--blue) !important;
      }

      /* Mobile sub-menu styling */
      .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .hd6-mob-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--grey);
        letter-spacing: 0.08em;
        margin-top: 0.75rem;
        margin-bottom: 0.25rem;
      }

      @media (max-width: 640px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .services-hero-h1 { font-size: 2.4rem; }
        .services-hero-right { grid-template-columns: 1fr; }
        .movein-cards { grid-template-columns: 1fr; }
        .addons-grid { grid-template-columns: 1fr; }
        .addon-item { border-right: none !important; border-bottom: 1px solid var(--border-subtle) !important; }
        .addon-item:last-child { border-bottom: none !important; }
        .compare-table th, .compare-table td { padding: 0.8rem 0.65rem; font-size: 0.78rem; }
        .rec-disc { flex: 1 1 100%; }
      }
      @media (max-width: 768px) {
        #service-nav + #standard { padding-top: 5.5rem; }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
        max-width: 1180px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 2.5rem !important;
        padding-right: 2.5rem !important;
      }
      @media (max-width: 768px) {
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
          padding-top: 4.5rem !important;
          padding-bottom: 4.5rem !important;
        }
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
      @media (max-width: 768px), (hover: none), (pointer: coarse) {
        #hd6.scrolled,
        nav[id$="-nav"]:not(#hd6-mob),
        .eol6-strip-img span {
          backdrop-filter: none;
          -webkit-backdrop-filter: none;
        }
        .srv6-card-blur {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <!-- ─ HEADER ─────────────────────────────────── -->
    <header id="hd6" aria-label="Site header">
      <a href={withBase("index")} class="hd6-logo" aria-label="Maid at Home">
        <div class="hd6-mark" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 2L11 7H16L12 10.5L13.5 16L9 12.5L4.5 16L6 10.5L2 7H7L9 2Z" fill="white" fill-opacity="0.9"/>
          </svg>
        </div>
        <span class="hd6-name">Maid at Home</span>
      </a>
      <nav class="hd6-nav" aria-label="Main navigation">
        <div class="hd6-nav-item-dropdown">
          <a href={withBase("services")} class="hd6-nav-dropdown-toggle">
            Our Services
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="hd6-dropdown-menu">
            <a href={withBase("services/standard-cleaning")}>Standard Cleaning</a>
            <a href={withBase("services/deep-cleaning")}>Deep Cleaning</a>
            <a href={withBase("services/end-of-lease-cleaning")}>End of Lease</a>
            <a href={withBase("services/move-in-cleaning")}>Move In Cleaning</a>
            <a href={withBase("services/oven-cleaning")}>Oven Cleaning</a>
            <a href={withBase("services/window-cleaning")}>Window Cleaning</a>
            <a href={withBase("services/balcony-cleaning")}>Balcony Cleaning</a>
          </div>
        </div>
        <a href={withBase("carpet-cleaning")}>Carpet Cleaning</a>
        <a href={withBase("pricing")}>Pricing</a>
        <a href={withBase("areas")}>Areas We Serve</a>
        <a href={withBase("about")}>About Us</a>
        <a href={withBase("careers")}>Join Our Team</a>
        <div class="hd6-nav-item-dropdown">
          <a href="#" class="hd6-nav-dropdown-toggle" onclick="event.preventDefault()">
            Help
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="hd6-dropdown-menu">
            <a href={withBase("faqs")}>FAQs</a>
            <a href={withBase("contact")}>Contact Us</a>
          </div>
        </div>
        <a href={withBase("blog")}>Blog</a>
        <a href={withBase("booking")} class="hd6-cta">Book Now</a>
      </nav>
      <button class="hd6-toggle" id="hd6Toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
