---
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loading… — Maid at Home Blog</title>
    <meta name="description" content="" />

    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-italic.woff2") format("woff2");
      }
      @font-face {
        font-family: "Lora";
        font-style: normal;
        font-weight: 400 600;
        font-display: swap;
        src: url("../fonts/lora-latin-normal.woff2") format("woff2");
      }

      @font-face {
        font-family: "Lora";
        font-style: italic;
        font-weight: 400 500;
        font-display: swap;
        src: url("../fonts/lora-latin-italic.woff2") format("woff2");
      }      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --font-serif: 'Lora', Georgia, serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
        --article-width: 720px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── READING PROGRESS BAR ────────────────── */
      #progress-bar {
        position: fixed; top: 0; left: 0; z-index: 210;
        height: 4px; width: 0%;
        background: linear-gradient(90deg, var(--blue), var(--blue-l));
        transition: width 0.1s linear;
        border-radius: 0 2px 2px 0;
      }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }
      .mob6-close { position: absolute; top: 1.25rem; right: 2rem; background: none; border: none; font-size: 1.5rem; color: var(--navy); cursor: pointer; }

      /* Dropdown styling */
      .hd6-nav-item-dropdown { position: relative; display: inline-block; }
      .hd6-nav-dropdown-toggle { display: inline-flex; align-items: center; gap: 0.35rem; cursor: pointer; }
      .hd6-nav-dropdown-toggle svg { transition: transform 0.2s var(--ease); }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg { transform: rotate(180deg); }
      .hd6-dropdown-menu {
        position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(8px);
        background: var(--white); min-width: 220px; border-radius: var(--r);
        border: 1px solid var(--border-subtle); box-shadow: var(--shadow-lg);
        padding: 0.65rem 0; opacity: 0; visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250; display: flex; flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
      .hd6-dropdown-menu a {
        display: block !important; font-size: 0.88rem !important; font-weight: 600 !important;
        color: var(--grey-d) !important; padding: 0.6rem 1.25rem !important; border-radius: 0 !important;
        transition: background 0.2s, color 0.2s !important; text-align: left;
      }
      .hd6-dropdown-menu a:hover { background: var(--sky) !important; color: var(--blue) !important; }

      /* ─── HERO ────────────────────────────────── */
      #post-hero { padding-top: 72px; background: var(--sky); position: relative; overflow: hidden; }
      .ph-bg {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      
      .ph-inner { position: relative; z-index: 2; max-width: var(--article-width); margin: 0 auto; padding: 4rem 2.5rem 3.5rem; }
      .ph-breadcrumb { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; color: var(--grey); margin-bottom: 1.5rem; flex-wrap: wrap; }
      .ph-breadcrumb a {
        color: var(--grey);
        text-decoration: none;
        transition: color 0.2s;
      }
      .ph-breadcrumb a:hover { color: var(--navy); }
      .ph-breadcrumb .sep {
        color: var(--grey);
        display: inline-block;
      }
      
      .ph-cat { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.1rem; }
      .ph-cat-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--yellow); }
      
      #post-title {
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4.5vw, 3rem);
        font-weight: 600; line-height: 1.2; letter-spacing: -0.01em;
        color: var(--navy); margin-bottom: 1.35rem;
      }
      .ph-excerpt { font-size: 1.08rem; color: var(--grey); line-height: 1.75; max-width: 600px; margin-bottom: 2rem; }
      
      .ph-meta { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid var(--border-subtle); }
      .ph-author { display: flex; align-items: center; gap: 0.6rem; }
      .ph-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; color: var(--white); flex-shrink: 0; }
      .ph-author-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
      .ph-author-role { font-size: 0.72rem; color: var(--grey); margin-top: 0.05rem; }
      .ph-divider { width: 1px; height: 28px; background: var(--border-subtle); }
      .ph-date { font-size: 0.82rem; color: var(--grey); }
      .ph-read { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.82rem; color: var(--grey); }
      
      /* Hero wave divider matching rest of theme */
      .ph-wave { height: 48px; background: var(--white); clip-path: ellipse(55% 100% at 50% 100%); margin-top: -1px; position: relative; z-index: 2; }

      /* ─── ARTICLE LAYOUT ──────────────────────── */
      #article-wrap { background: var(--white); padding: 6.5rem 0; }
      .article-layout { display: grid; grid-template-columns: var(--article-width) 260px; gap: 4.5rem; max-width: 1080px; margin: 0 auto; padding: 0 2.5rem; align-items: start; }

      /* ─── ARTICLE CONTENT ─────────────────────── */
      #article-body { min-height: 400px; }

      /* Portable Text Styling with Lora Serif */
      .pt-content { font-family: var(--font-serif); font-size: 1.1rem; line-height: 1.85; color: var(--grey-d); }
      .pt-content p { margin-bottom: 1.6rem; }
      .pt-content p:last-child { margin-bottom: 0; }
      .pt-content h2 {
        font-family: var(--font-serif); font-size: 1.75rem; font-weight: 600; line-height: 1.3;
        letter-spacing: -0.015em; color: var(--navy); margin: 3rem 0 1.25rem; padding-top: 0.25rem;
        scroll-margin-top: 120px;
      }
      .pt-content h3 {
        font-family: var(--font-serif); font-size: 1.35rem; font-weight: 600; line-height: 1.35;
        color: var(--navy); margin: 2.5rem 0 1rem; scroll-margin-top: 120px;
      }
      .pt-content h4 {
        font-family: var(--font); font-size: 0.95rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
        color: var(--blue); margin: 2rem 0 0.75rem;
      }
      .pt-content strong { font-weight: 700; color: var(--navy); }
      .pt-content em { font-style: italic; }
      .pt-content a { color: var(--blue); text-decoration: underline; text-decoration-color: rgba(29, 111, 168, 0.2); text-underline-offset: 3px; transition: color 0.2s; }
      .pt-content a:hover { color: var(--navy); }
      
      .pt-content ul, .pt-content ol { margin: 0.75rem 0 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
      .pt-content li { padding-left: 0.25rem; }
      .pt-content ul li::marker { color: var(--blue-l); }
      .pt-content ol li::marker { color: var(--blue); font-weight: 700; font-family: var(--font); font-size: 0.9rem; }
      
      .pt-content blockquote {
        margin: 2rem 0; padding: 1.5rem 2rem;
        border-left: 4px solid var(--yellow);
        background: var(--yellow-l);
        border-radius: 0 var(--r) var(--r) 0;
        font-style: italic; color: var(--navy);
      }
      .pt-content blockquote p { margin: 0; font-size: 1.15rem; line-height: 1.75; }
      .pt-content hr { border: none; border-top: 1.5px solid var(--grey-l); margin: 3rem 0; }
      .pt-content figure { margin: 2.5rem 0; }
      .pt-content figure img { width: 100%; border-radius: var(--r-xl); display: block; border: 1px solid var(--border-subtle); }
      .pt-content figcaption { font-family: var(--font); font-size: 0.8rem; color: var(--grey); margin-top: 0.6rem; text-align: center; }
      .pt-content code { font-family: monospace; font-size: 0.9em; background: var(--sky); color: var(--blue); padding: 0.1em 0.35em; border-radius: 4px; }

      .pt-callout {
        margin: 2.25rem 0; padding: 1.5rem 1.75rem;
        background: var(--sky); border: 1.5px solid var(--border-subtle);
        border-radius: var(--r-xl); display: flex; gap: 1rem;
        font-family: var(--font); font-size: 0.95rem; color: var(--navy); line-height: 1.6;
      }
      .pt-callout-icon { font-size: 1.25rem; flex-shrink: 0; }
      .pt-callout strong { color: var(--navy); display: block; margin-bottom: 0.3rem; }

      /* ─── ARTICLE FOOTER ──────────────────────── */
      .article-footer { margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--grey-l); }
      .af-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
      .af-tag { font-size: 0.78rem; font-weight: 700; padding: 0.35rem 0.85rem; border-radius: 100px; background: var(--sky); border: 1px solid var(--border-subtle); color: var(--blue); text-decoration: none; transition: all 0.2s; }
      .af-tag:hover { border-color: var(--border-hover); background: var(--blue-xl); }
      
      .author-card { background: var(--sky); border: 1px solid var(--border-subtle); border-radius: var(--r-xl); padding: 2rem; display: flex; gap: 1.5rem; align-items: flex-start; }
      .ac-avatar { width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.15rem; font-weight: 800; color: var(--white); flex-shrink: 0; }
      .ac-name { font-size: 1.1rem; font-weight: 800; color: var(--navy); margin-bottom: 0.2rem; }
      .ac-role { font-size: 0.75rem; font-weight: 800; color: var(--blue); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.6rem; }
      .ac-bio { font-size: 0.88rem; color: var(--grey); line-height: 1.65; }
      
      .share-row { display: flex; align-items: center; gap: 0.85rem; margin-top: 2.5rem; flex-wrap: wrap; }
      .share-label { font-size: 0.8rem; font-weight: 800; color: var(--grey); text-transform: uppercase; letter-spacing: 0.08em; }
      .share-btn { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.82rem; font-weight: 700; padding: 0.55rem 1.15rem; border-radius: 100px; border: 1px solid var(--grey-l); background: var(--white); color: var(--navy); cursor: pointer; font-family: var(--font); text-decoration: none; transition: all 0.2s; }
      .share-btn:hover { border-color: var(--navy); background: var(--sky); }

      /* ─── TOC SIDEBAR ─────────────────────────── */
      #toc-wrap { position: sticky; top: calc(72px + 2rem); }
      #hd6.scrolled ~ #article-wrap #toc-wrap { top: calc(64px + 2rem); }
      .toc-box { background: var(--sky); border: 1px solid var(--border-subtle); border-radius: var(--r-xl); padding: 1.75rem; }
      .toc-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--grey); margin-bottom: 1.1rem; display: flex; align-items: center; gap: 0.45rem; }
      .toc-title::before { content: ''; display: block; width: 12px; height: 2px; background: var(--yellow); border-radius: 2px; }
      #toc-list { list-style: none; display: flex; flex-direction: column; gap: 0.15rem; }
      .toc-link {
        display: block; font-size: 0.85rem; font-weight: 600; color: var(--grey);
        text-decoration: none; padding: 0.45rem 0.5rem 0.45rem 0.75rem;
        border-left: 2px solid transparent; border-radius: 0 8px 8px 0;
        transition: all 0.2s; line-height: 1.45;
      }
      .toc-link:hover { color: var(--blue); background: var(--white); }
      .toc-link.active { color: var(--blue); border-left-color: var(--blue); font-weight: 700; background: var(--white); }
      .toc-link.toc-h3 { padding-left: 1.5rem; font-size: 0.8rem; }
      
      .toc-progress-wrap { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--border-subtle); }
      .toc-progress-label { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--grey); margin-bottom: 0.4rem; font-weight: 700; }
      .toc-progress-bar-bg { height: 4px; background: var(--grey-l); border-radius: 2px; overflow: hidden; }
      .toc-progress-bar-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--blue), var(--blue-l)); border-radius: 2px; transition: width 0.15s linear; }
      .toc-back { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.82rem; font-weight: 700; color: var(--grey); text-decoration: none; margin-top: 1.5rem; transition: color 0.2s; }
      .toc-back:hover { color: var(--blue); }

      /* Loading & Error States */
      .skel { background: linear-gradient(90deg, var(--sky) 25%, #e9eaeb 50%, var(--sky) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 6px; }
      @keyframes shimmer { 0% { background-position:200% 0; } 100% { background-position:-200% 0; } }
      .skel-h { height: 18px; margin-bottom: 0.75rem; }
      .skel-p { height: 14px; margin-bottom: 0.5rem; }

      #error-state { display: none; text-align: center; padding: 6rem 2rem; }
      .err-icon { font-size: 3rem; margin-bottom: 1rem; }
      #error-state h2 { font-size: 1.5rem; font-weight: 800; color: var(--navy); margin-bottom: 0.5rem; }
      #error-state p { color: var(--grey); margin-bottom: 1.5rem; }

      /* ─── RELATED POSTS ───────────────────────── */
      #related { padding: 6.5rem 0; background: var(--white); border-top: 1px solid var(--border-subtle); }
      .related-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; gap: 1rem; max-width: 1080px; margin-left: auto; margin-right: auto; padding: 0 2.5rem; }
      .related-header h2 { font-size: 1.5rem; font-weight: 800; color: var(--navy); letter-spacing: -0.03em; }
      .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1080px; margin: 0 auto; padding: 0 2.5rem; }
      
      .rc { border: 1px solid var(--border-subtle); border-radius: var(--r-xl); overflow: hidden; background: var(--white); text-decoration: none; display: flex; flex-direction: column; transition: all 0.3s; box-shadow: var(--shadow-sm); }
