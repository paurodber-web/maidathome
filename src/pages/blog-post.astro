      const AUTHOR_BIOS = {
        'Pau Rodriguez':    'Pau co-founded Maid at Home after working in professional cleaning across Melbourne. His writing focuses on the operational side of home care — what actually works, and why.',
        'Stefania Ramirez': 'Stefania co-founded Maid at Home with a background in communications. She writes about practical home care, client experience, and the details that make a clean home feel right.',
        'Maid at Home Team':      'Tips, guides, and honest advice from the Maid at Home cleaning team — written by people who do this professionally, every day.',
      };

      function getSlug() {
        const path = window.location.pathname;
        const pathMatch = path.match(/\/blog\/([^/]+?)(?:\.html)?$/i);
        if (pathMatch) return pathMatch[1];

        const params = new URLSearchParams(window.location.search);
        if (params.get('slug')) return params.get('slug');
        if (params.get('post')) return params.get('post');

        return null;
      }

      function buildPostQuery(slug) {
        const q = `*[_type == "post" && slug.current == "${slug}"][0] {
          _id, title, "slug": slug.current,
          publishedAt, excerpt, category, readTime, featured,
          "author": author->{ name, initials, color },
          "imageUrl": mainImage.asset->url,
          tags,
          body[] {
            ...,
            _type == "image" => { ..., "url": asset->url },
            children[] { ..., marks }
          }
        }`;
        return encodeURIComponent(q);
      }

      function buildRelatedQuery(category, excludeId) {
        const q = `*[_type == "post" && category == "${category}" && _id != "${excludeId}"] | order(publishedAt desc) [0..2] {
          _id, title, "slug": slug.current,
          publishedAt, category, readTime, excerpt,
          "author": author->{ name },
          "imageUrl": mainImage.asset->url
        }`;
        return encodeURIComponent(q);
      }

      function buildFallbackRelatedQuery(excludeId) {
        const q = `*[_type == "post" && _id != "${excludeId}"] | order(publishedAt desc) [0..2] {
          _id, title, "slug": slug.current,
          publishedAt, category, readTime, excerpt,
          "author": author->{ name },
          "imageUrl": mainImage.asset->url
        }`;
        return encodeURIComponent(q);
      }

      async function sanityFetch(query) {
        const url = `https://${SANITY_PROJECT_ID}.api.sanity.io/v${SANITY_API_VER}/data/query/${SANITY_DATASET}?query=${query}`;
        const res = await fetch(url);
        const data = await res.json();
        return data.result;
      }

      function renderMark(text, mark, markDefs = []) {
        if (mark === 'strong')    return `<strong>${text}</strong>`;
        if (mark === 'em')        return `<em>${text}</em>`;
        if (mark === 'underline') return `<span style="text-decoration:underline">${text}</span>`;
        if (mark === 'strike')    return `<s>${text}</s>`;
        if (mark === 'code')      return `<code>${text}</code>`;
        const def = markDefs.find(d => d._key === mark);
        if (def && def._type === 'link') {
          const target = def.href?.startsWith('http') ? ' target="_blank" rel="noopener"' : '';
          return `<a href="${def.href || '#'}"${target}>${text}</a>`;
        }
        return text;
      }

      function renderSpans(spans = [], markDefs = []) {
        return spans.map(span => {
          if (span._type !== 'span') return '';
          let text = escHtml(span.text || '');
          text = text.replace(/\n/g, '<br>');
          if (span.marks?.length) {
            span.marks.forEach(m => { text = renderMark(text, m, markDefs); });
          }
          return text;
        }).join('');
      }

      function escHtml(str) {
        return str
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function portableTextToHtml(blocks = []) {
        let html = '';
        let listType = null;

        const closeList = () => {
          if (listType === 'bullet')  { html += '</ul>'; }
          if (listType === 'number')  { html += '</ol>'; }
          listType = null;
        };

        blocks.forEach(block => {
          if (block._type === 'image' && block.url) {
            closeList();
            const alt = block.alt || '';
            const caption = block.caption || '';
            html += `<figure>
              <img src="${block.url}?w=1200&auto=format&q=85" alt="${escHtml(alt)}" loading="lazy">
              ${caption ? `<figcaption>${escHtml(caption)}</figcaption>` : ''}
            </figure>`;
            return;
          }

          if (block._type === 'callout') {
            closeList();
            html += `<div class="pt-callout">
              <span class="pt-callout-icon">${block.icon || '💡'}</span>
              <div>${block.title ? `<strong>${escHtml(block.title)}</strong>` : ''}${escHtml(block.text || '')}</div>
            </div>`;
            return;
          }

          if (block._type !== 'block') return;

          const content = renderSpans(block.children, block.markDefs);

          if (block.listItem === 'bullet') {
            if (listType !== 'bullet') { closeList(); html += '<ul>'; listType = 'bullet'; }
            html += `<li>${content}</li>`;
            return;
          }
          if (block.listItem === 'number') {
            if (listType !== 'number') { closeList(); html += '<ol>'; listType = 'number'; }
            html += `<li>${content}</li>`;
            return;
          }
          closeList();

          switch (block.style) {
            case 'h2':         html += `<h2 id="${slugify(block.children)}">${content}</h2>`; break;
            case 'h3':         html += `<h3 id="${slugify(block.children)}">${content}</h3>`; break;
            case 'h4':         html += `<h4>${content}</h4>`; break;
            case 'blockquote': html += `<blockquote><p>${content}</p></blockquote>`; break;
            case 'normal':
            default:
              if (content.trim()) html += `<p>${content}</p>`;
              else html += `<hr>`;
          }
        });

        closeList();
        return html;
      }

      function slugify(children = []) {
        const text = children.map(c => c.text || '').join('');
        return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      }

      function buildTOC() {
        const content  = document.getElementById('pt-content');
        const tocList  = document.getElementById('toc-list');
        const headings = content.querySelectorAll('h2, h3');

        if (headings.length < 2) {
          document.getElementById('toc-wrap').style.display = 'none';
          return;
        }

        tocList.innerHTML = '';
        headings.forEach(h => {
          if (!h.id) h.id = slugify([{ text: h.textContent }]);
          const li = document.createElement('li');
          li.className = 'toc-item';
          const a = document.createElement('a');
          a.className = `toc-link${h.tagName === 'H3' ? ' toc-h3' : ''}`;
          a.href = `#${h.id}`;
          a.textContent = h.textContent;
          a.addEventListener('click', e => {
            e.preventDefault();
            h.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          li.appendChild(a);
          tocList.appendChild(li);
        });
      }

      function initProgress() {
        const bar      = document.getElementById('progress-bar');
        const tocFill  = document.getElementById('toc-bar-fill');
        const tocPct   = document.getElementById('toc-pct');
        const article  = document.getElementById('article-body');
        const tocLinks = () => document.querySelectorAll('.toc-link');
        const headings = () => document.querySelectorAll('.pt-content h2, .pt-content h3');

        window.addEventListener('scroll', () => {
          const rect    = article.getBoundingClientRect();
          const total   = article.offsetHeight - window.innerHeight;
          const scrolled = Math.max(0, -rect.top);
          const pct     = total > 0 ? Math.min(100, Math.round((scrolled / total) * 100)) : 0;

          bar.style.width = pct + '%';
          bar.setAttribute('aria-valuenow', pct);

          tocFill.style.width = pct + '%';
          tocPct.textContent  = pct + '%';

          const hds = headings();
          let activeId = null;
          hds.forEach(h => {
            if (h.getBoundingClientRect().top < 120) activeId = h.id;
          });
          tocLinks().forEach(l => {
            l.classList.toggle('active', l.getAttribute('href') === `#${activeId}`);
          });

        }, { passive: true });
      }

      function copyLink() {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const btn = document.getElementById('copy-link-btn');
          btn.innerHTML = '✓ Copied!';
          btn.style.background = 'var(--green)';
          btn.style.borderColor = 'var(--green)';
          btn.style.color = '#white';
          setTimeout(() => {
            btn.innerHTML = `
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Copy link`;
            btn.style.background = 'var(--white)';
            btn.style.borderColor = 'var(--grey-l)';
            btn.style.color = 'var(--navy)';
          }, 2000);
        });
      }

      document.getElementById('copy-link-btn').onclick = copyLink;

      function renderRelatedPost(post) {
        const emoji = categoryEmoji(post.category);
        const imgHtml = post.imageUrl
          ? `<img src="${post.imageUrl}?w=600&auto=format&q=80" alt="${post.title}" loading="lazy">`
          : `<div class="rc-img-placeholder">${emoji}</div>`;

        return `
          <a href="${BASE_POST_URL}${post.slug}" class="rc" aria-label="${post.title}">
            <div class="rc-img">${imgHtml}</div>
            <div class="rc-body">
              <div class="rc-cat">${post.category || 'Article'}</div>
              <div class="rc-title">${post.title}</div>
              <span class="rc-meta">${fmtDate(post.publishedAt)} · ${post.readTime ? `${post.readTime} min read` : ''}</span>
            </div>
          </a>`;
      }

      function categoryEmoji(cat = '') {
        const map = {
          'Cleaning Tips':    '🧹',
          'Deep Cleaning':    '🔍',
          'Organisation':     '📦',
          'Eco Cleaning':     '♻️',
          'Melbourne':        '🌆',
          'Seasonal':         '🍂',
          'Kitchen':          '🍳',
          'Bathroom':         '🚿',
          'Move In / Out':    '📋',
          'Product Reviews':  '⭐',
        };
        return map[cat] || '📰';
      }

      const DEMO_POSTS = [
        {
          _id: 'demo-1', featured: true,
          title: 'The 10-Minute Tidy: How to Keep Your Home Clean Between Professional Visits',
          slug: 'ten-minute-tidy', category: 'Cleaning Tips',
          publishedAt: '2026-05-15T09:00:00Z', readTime: 6,
          excerpt: 'A quick daily routine that prevents buildup and means your professional clean always starts from a better baseline — saving you time and money.',
          author: { name: 'Stefania Ramirez', initials: 'SR', color: 'linear-gradient(135deg,#7c3aed,#4c1d95)' },
          imageUrl: null,
          tags: ['Tidy', 'Quick Clean', 'Home Hacks'],
          body: [
            { _type: 'block', style: 'normal', children: [{ _type: 'span', text: 'Keeping a home tidy between professional cleaning visits doesn\'t require hours of scrubbing. In fact, we tell our clients that a simple 10-minute daily routine can transform their space and preserve their sanity.' }] },
            { _type: 'block', style: 'h2', children: [{ _type: 'span', text: '1. Focus on High-Impact Zones' }] },
            { _type: 'block', style: 'normal', children: [{ _type: 'span', text: 'Don\'t try to clean the whole apartment. Concentrate on the entry hallway, kitchen bench, and living room coffee table. Clearing these surfaces immediately makes the entire home feel ordered.' }] },
            { _type: 'callout', icon: '💡', title: 'Our Pro Tip', text: 'Keep a neat decorative tray or basket by the entrance for keys, mail, and pocket items to prevent them from scattering across the counter.' }
          ]
        },
        {
          _id: 'demo-2', featured: false,
          title: 'Oven Cleaning Without Harsh Chemicals: What Actually Works',
          slug: 'oven-cleaning-natural', category: 'Eco Cleaning',
          publishedAt: '2026-05-08T09:00:00Z', readTime: 5,
          excerpt: 'Our cleaners tackle ovens professionally every day. Here\'s the baking soda and vinegar method that genuinely removes grease without toxic fumes.',
          author: { name: 'Pau Rodriguez', initials: 'PR', color: 'linear-gradient(135deg,#1e4d78,#0a1d33)' },
          imageUrl: null,
          tags: ['Kitchen', 'Eco-friendly', 'Oven'],
          body: []
        },
        {
          _id: 'demo-3', featured: false,
          title: 'End of Lease Cleaning Checklist: What Melbourne Agents Actually Inspect',
          slug: 'end-of-lease-checklist-melbourne', category: 'Move In / Out',
          publishedAt: '2026-04-28T09:00:00Z', readTime: 8,
          excerpt: 'The 47-point checklist used by Melbourne real estate agents during exit inspections — and how to make sure you tick every single box.',
          author: { name: 'Stefania Ramirez', initials: 'SR', color: 'linear-gradient(135deg,#7c3aed,#4c1d95)' },
          imageUrl: null,
          tags: ['Bond Clean', 'Melbourne Rent', 'Tenant Guide'],
          body: []
        }
      ];

      async function loadPost() {
        const slug = getSlug();
        if (!slug) {
          showError();
          return;
        }

        let post = null;

        if (SANITY_PROJECT_ID === 'YOUR_PROJECT_ID') {
          await new Promise(r => setTimeout(r, 400));
          post = DEMO_POSTS.find(p => p.slug === slug) || DEMO_POSTS[0];
        } else {
          try {
            post = await sanityFetch(buildPostQuery(slug));
            if (!post) {
              post = DEMO_POSTS.find(p => p.slug === slug);
            }
          } catch (err) {
            console.error('[Maid at Home Blog] Failed to fetch article:', err);
            post = DEMO_POSTS.find(p => p.slug === slug) || DEMO_POSTS[0];
          }
        }

        if (!post) {
          showError();
          return;
        }

        renderPost(post);
        loadRelated(post);
      }

      function renderPost(post) {
        document.title = `${post.title} — Maid at Home Blog`;

        // Breadcrumb article title
        document.getElementById('breadcrumb-cat').textContent = post.title || 'Article';

        // Hero Category
        const colour = catColour(post.category || 'General');
        document.getElementById('ph-cat-label').textContent = post.category || 'Article';
        document.getElementById('ph-cat-label').style.color = colour;

        // Title & Excerpt
        document.getElementById('post-title').textContent = post.title;
        document.getElementById('ph-excerpt').textContent = post.excerpt || '';

        // Meta
        document.getElementById('ph-date').textContent = fmtDate(post.publishedAt);
        document.getElementById('ph-read').textContent = post.readTime ? `${post.readTime} min read` : '';

        // Author
        const authorName = post.author?.name || 'Maid at Home Team';
        const authorInits = post.author?.initials || initials(authorName);
        const authorCol = post.author?.color || AUTHOR_COLOURS[authorName] || AUTHOR_COLOURS['Maid at Home Team'];
        const authorRole = AUTHOR_ROLES[authorName] || AUTHOR_ROLES['Maid at Home Team'];
        const authorBio  = AUTHOR_BIOS[authorName] || AUTHOR_BIOS['Maid at Home Team'];

        document.getElementById('ph-author-name').textContent = authorName;
        const ava = document.getElementById('ph-avatar');
        ava.textContent = authorInits;
        ava.style.background = authorCol;

        // Cover Image
        if (post.imageUrl) {
          const wrap = document.getElementById('hero-cover-wrap');
          const img = document.getElementById('hero-cover-img');
          img.src = imgUrl(post.imageUrl, 1200);
          img.alt = post.title;
          wrap.style.display = 'block';
        }

        // Portable Text Content
        const html = portableTextToHtml(post.body || []);
        document.getElementById('pt-content').innerHTML = html;

        // Tags
        const tagsWrap = document.getElementById('af-tags');
        if (post.tags && post.tags.length) {
          tagsWrap.innerHTML = post.tags.map(t => `<a href="${BLOG_INDEX_URL}" class="af-tag">${t}</a>`).join('');
        } else {
          tagsWrap.style.display = 'none';
        }

        // Author card
        document.getElementById('author-card').innerHTML = `
          <div class="ac-avatar" style="background:${authorCol}">${authorInits}</div>
          <div class="ac-body">
            <h3 class="ac-name">${authorName}</h3>
            <div class="ac-role">${authorRole}</div>
            <p class="ac-bio">${authorBio}</p>
          </div>
        `;

        // Share links
        document.getElementById('share-twitter').href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(window.location.href)}`;
        document.getElementById('share-facebook').href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(window.location.href)}`;

        // Display Content
        document.getElementById('article-skeleton').style.display = 'none';
        document.getElementById('article-content').style.display = 'block';

        // Initialize Table of Contents and Progress
        buildTOC();
        initProgress();
      }

      async function loadRelated(post) {
        let related = [];
        if (SANITY_PROJECT_ID === 'YOUR_PROJECT_ID') {
          related = DEMO_POSTS.filter(p => p._id !== post._id).slice(0, 3);
        } else {
          try {
            related = await sanityFetch(buildRelatedQuery(post.category || 'General', post._id));
            if (!related || related.length === 0) {
              related = await sanityFetch(buildFallbackRelatedQuery(post._id));
            }
          } catch (err) {
            related = DEMO_POSTS.filter(p => p._id !== post._id).slice(0, 3);
          }
        }

        if (related && related.length) {
          const grid = document.getElementById('related-grid');
          grid.innerHTML = related.map(renderRelatedPost).join('');
          document.getElementById('related').style.display = 'block';
        }
      }

      function showError() {
        document.getElementById('article-skeleton').style.display = 'none';
        document.getElementById('error-state').style.display = 'block';
      }

      const CAT_COLOURS = ['#1d6fa8','#7c3aed','#0a1d33','#16a34a','#e0ab1d','#dc2626','#db2777','#6366f1'];
      const catColourMap = {};
      function catColour(cat) {
        if (!catColourMap[cat]) {
          const keys = Object.keys(catColourMap);
          catColourMap[cat] = CAT_COLOURS[keys.length % CAT_COLOURS.length];
        }
        return catColourMap[cat];
      }

      const hd6 = document.getElementById("hd6");
      const onScroll6 = () => hd6.classList.toggle("scrolled", window.scrollY > 20);
      window.addEventListener("scroll", onScroll6, { passive: true });
      onScroll6();

      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      const cls6 = document.getElementById("hd6MobClose");
      tog6.addEventListener("click", () => { mob6.classList.add("open"); tog6.setAttribute("aria-expanded","true"); });
      cls6.addEventListener("click", () => { mob6.classList.remove("open"); tog6.setAttribute("aria-expanded","false"); });
      mob6.querySelectorAll("a").forEach(a => a.addEventListener("click", () => mob6.classList.remove("open")));

      loadPost();
    </script>
  </body>
</html>
