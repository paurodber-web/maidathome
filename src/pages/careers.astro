        box-shadow: 0 0 0 3px rgba(29, 111, 168, 0.12);
      }
      .form-submit-btn {
        width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy); font-weight: 700; font-size: 1rem;
        padding: 1rem; border: none; border-radius: 100px; cursor: pointer;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246,193,51,0.25);
        margin-top: 1.5rem; font-family: var(--font);
      }
      .form-submit-btn:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246,193,51,0.4); }

      /* ─── FAQ ─────────────────────────────────── */
      #faq6 { background: var(--sky) !important; border-top: 1px solid var(--border-subtle); }
      .faq6-layout { display: grid; grid-template-columns: 4fr 8fr; gap: 5rem; align-items: start; }
      .compact-contact-card {
        padding: 2rem 2.25rem;
        background: var(--sky);
        border-radius: 20px;
        border: 1px solid var(--border-subtle);
        width: fit-content;
        max-width: 100%;
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        box-shadow: var(--shadow-sm);
      }
      .compact-card-line {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.88rem;
        line-height: 1.2;
        color: var(--blue);
        font-weight: 700;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .compact-card-line span:last-child { font-size: 0.88rem; line-height: 1.2; }
      .compact-card-line:hover { opacity: 0.85; }
      .compact-card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .faq6-list { border-top: 1px solid var(--border-subtle); }
      .faq6-item { border-bottom: 1px solid var(--border-subtle); }
      .faq6-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.35rem 0; cursor: pointer; background: none; border: none; width: 100%; font-family: var(--font); font-size: 0.95rem; font-weight: 700; color: var(--navy); text-align: left; transition: color 0.2s; }
      .faq6-q:hover { color: var(--blue); }
      .faq6-ico { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--grey-l); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--grey); font-weight: 400; flex-shrink: 0; transition: all 0.3s var(--ease); line-height: 1; }
      .faq6-item.open .faq6-ico { background: var(--yellow); border-color: var(--yellow); color: var(--navy); transform: rotate(45deg); }
      .faq6-a { font-size: 0.9rem; color: var(--grey); line-height: 1.75; max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease), padding 0.3s; }
      .faq6-item.open .faq6-a { max-height: 280px; padding-bottom: 1.35rem; }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky) !important;
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      #cta6.cta-white {
        background: var(--white) !important;
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 { background: var(--navy); padding: 4.5rem 2.5rem 2.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
      .ft6-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3.5rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .ft6-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.7; margin-top: 0.85rem; max-width: 280px; }
      .ft6-logo { font-size: 1.2rem; font-weight: 800; color: rgba(255,255,255,0.85); letter-spacing: -0.02em; }
      .ft6-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
      .ft6-col a { display: block; font-size: 0.88rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.2s; }
      .ft6-col a:hover { color: rgba(255,255,255,0.85); }
      .ft6-bottom { max-width: 1180px; margin: 1.75rem auto 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      .ft6-bottom span, .ft6-bottom a { font-size: 0.78rem; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
      .ft6-bottom a:hover { color: rgba(255,255,255,0.6); }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .std-hero-body { grid-template-columns: 1fr; gap: 3rem; }
        .benefits-grid, .req-grid, .apply-layout, .faq6-layout { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-grid { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-right { height: 320px; }
        .ft6-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      }
      @media (max-width: 768px) {
        .std-hero-body { padding: 4rem 1.5rem 3rem; }
        .cta6-left { padding: 2.5rem 1.5rem; }
        .c6 { padding: 0 1.5rem; }
        .pad { padding: 4.5rem 0; }
        .ft6-inner { grid-template-columns: 1fr; gap: 2rem; }
        .apply-form-card { padding: 2rem 1.5rem; }
        .form-grid { grid-template-columns: 1fr; }
      }
