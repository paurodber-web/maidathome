      }

      /* Dropdown style system */
      .hd6-nav-item-dropdown { position: relative; display: inline-block; }
      .hd6-nav-dropdown-toggle { display: inline-flex; align-items: center; gap: 0.35rem; cursor: pointer; }
      .hd6-nav-dropdown-toggle svg { transition: transform 0.2s var(--ease); }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg { transform: rotate(180deg); }
      .hd6-dropdown-menu {
        position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(8px);
        background: var(--white); min-width: 220px; border-radius: var(--r);
        border: 1px solid var(--border-subtle); box-shadow: var(--shadow-lg);
        padding: 0.65rem 0; opacity: 0; visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250; display: flex; flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
      .hd6-dropdown-menu a {
        display: block !important; font-size: 0.88rem !important; font-weight: 600 !important;
        color: var(--grey-d) !important; padding: 0.6rem 1.25rem !important; border-radius: 0 !important;
        transition: background 0.2s, color 0.2s !important; text-align: left;
      }
      .hd6-dropdown-menu a:hover { background: var(--sky) !important; color: var(--blue) !important; }

      /* Mobile sub-menu styling */
      .mob6-sub-menu { display: flex; flex-direction: column; padding-left: 1.25rem; border-left: 2px solid var(--border-subtle); margin: 0.25rem 0 0.75rem; gap: 0.35rem; }
      .mob6-sub-menu a { font-size: 0.95rem !important; color: var(--grey) !important; padding: 0.5rem 0 !important; border-bottom: none !important; }
      .mob6-sub-menu a:hover { color: var(--blue) !important; }
      .hd6-mob-section-title { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: var(--grey); letter-spacing: 0.08em; margin-top: 0.75rem; margin-bottom: 0.25rem; }
    
      /* ─── STICKY SECTION NAV ─────────────────── */
      #service-nav {
        position: sticky;
        top: 64px;
        z-index: 100;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border-subtle);
        box-shadow: 0 4px 20px rgba(10,29,51,0.02);
      }
      .pnav-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pnav-inner::-webkit-scrollbar { display: none; }
      .pnav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 1rem 0.25rem;
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--grey);
        text-decoration: none;
        white-space: nowrap;
        border-bottom: 2px solid transparent;
        transition: all 0.2s var(--ease);
      }
      .pnav-link:hover, .pnav-link.active {
        color: var(--blue);
        border-bottom-color: var(--blue);
      }
      .snav-icon { font-size: 1rem; }
      
      /* Target section spacing overrides for sticky header */
      #why-us, #requirements, #apply-section, #faq6 {
        scroll-margin-top: 120px;
        
      }
      @media (max-width: 768px) {
        #service-nav + #why-us { padding-top: 5.5rem; }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
