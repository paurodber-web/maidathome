---
import SiteFooter from "../components/SiteFooter.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { brightCleanLivingRoom } from "../data/site-images";
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join Our Team — Maid at Home Melbourne</title>
    <meta name="description" content="Work with Melbourne's premier home cleaning team. Industry-leading pay rates, fully flexible schedules, and supportive management. Apply online today." />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href={withBase("fonts.css")} />
    <style is:global>
      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: none; }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .si[data-d="l"] { transform: translateX(-24px); }
      .si[data-d="r"] { transform: translateX(24px); }
      .si.in { opacity: 1; transform: none; }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6     { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; }
      .pad    { padding: 6.5rem 0; }
      .pad-sm { padding: 4.5rem 0; }
      #service-nav + #why-us { padding-top: 8rem; }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--blue); margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: ""; width: 16px; height: 2.5px;
        background: var(--yellow); border-radius: 2px; flex-shrink: 0;
      }
      .h6 {
        display: block;
        margin: 0;
        font-family: var(--font);
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--navy); line-height: 1.15;
      }
      .h6 .ac { color: var(--blue); }
      .lead6 {
        font-size: 1.05rem; color: var(--grey);
        line-height: 1.75; max-width: 520px;
        margin-top: 0.75rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.95rem;
        padding: 0.95rem 2rem; border-radius: 100px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: var(--font); white-space: nowrap;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4); }
      .btn6-outline {
        display: inline-flex; align-items: center; gap: 0.45rem;
        color: var(--navy); font-weight: 600; font-size: 0.9rem;
        padding: 0.9rem 1.75rem; border-radius: 100px;
        border: 1px solid var(--grey-l); background: transparent;
        text-decoration: none; cursor: pointer; font-family: var(--font); white-space: nowrap;
        transition: border-color 0.25s, background 0.25s, color 0.25s;
      }
      .btn6-outline:hover { border-color: var(--navy); background: var(--sky); }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }

      /* ─── PAGE HERO ───────────────────────────── */
      #std-hero { background: var(--sky); padding-top: 72px; position: relative; overflow: hidden; }
      .std-hero-sun {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      .std-hero-body {
        max-width: 1180px; margin: 0 auto; padding: 4rem 2.5rem 5rem;
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem; align-items: start; position: relative; z-index: 2;
      }
      .std-hero-pill {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.75rem; font-weight: 700; color: var(--blue); letter-spacing: 0.05em;
        margin-bottom: 1.75rem; width: fit-content;
        background: var(--white); padding: 0.4rem 0.9rem; border-radius: 100px;
        box-shadow: var(--shadow-sm); animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .std-hero-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
      .std-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 800; letter-spacing: -0.04em;
        line-height: 1.08; color: var(--navy); margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .std-hero-h1 .ac { color: var(--blue); }
      .std-hero-desc {
        font-size: 1.1rem; color: var(--grey); line-height: 1.75; max-width: 500px;
        margin-bottom: 2.25rem; animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .std-hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; animation: fadeUp 0.65s var(--ease) 0.4s both; }

      /* Summary / Apply Card */
      /* Quiz Card Style */
      .quiz-card {
        background: var(--white); border-radius: var(--r-xl); padding: 1.5rem;
        border: 1px solid var(--border-subtle); box-shadow: var(--shadow-premium);
        animation: fadeUp 0.8s var(--ease) 0.1s both;
        display: flex; flex-direction: column; gap: 1.1rem;
      }
      .quiz-card-header { display: flex; flex-direction: column; gap: 0.15rem; }
      .quiz-card-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); }
      .quiz-card h3 { font-size: 1.25rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      
      .quiz-questions-list { display: flex; flex-direction: column; gap: 0.75rem; }
      .quiz-row {
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        background: var(--sky); padding: 0.65rem 0.95rem; border-radius: var(--r);
        border: 1px solid transparent; transition: all 0.2s var(--ease);
      }
      .quiz-row-text { font-size: 0.82rem; font-weight: 650; color: var(--navy); line-height: 1.35; }
      .quiz-row-buttons { display: flex; gap: 0.4rem; }
      .quiz-btn-choice {
        background: var(--white); border: 1px solid var(--border-subtle);
        font-family: var(--font); font-size: 0.78rem; font-weight: 700; color: var(--navy);
        padding: 0.35rem 0.85rem; border-radius: 6px; cursor: pointer;
        transition: all 0.25s var(--ease);
      }
      .quiz-btn-choice:hover { border-color: var(--blue); color: var(--blue); }
      
      /* Active states for choices */
      .quiz-btn-choice.selected-yes {
        background: var(--blue); border-color: var(--blue); color: var(--white);
      }
      .quiz-btn-choice.selected-no {
        background: var(--navy); border-color: var(--navy); color: var(--white);
      }
      
      /* Result Area */
      .quiz-result-area {
        border-top: 1px dashed var(--border-subtle); padding-top: 1rem;
        min-height: 70px; display: flex; align-items: center; justify-content: center;
      }
      .quiz-result-placeholder {
        font-size: 0.78rem; color: var(--grey); font-weight: 600; text-align: center;
      }
      .quiz-result-state {
        display: flex; flex-direction: column; gap: 0.65rem; width: 100%;
        animation: fadeIn 0.35s var(--ease) forwards;
      }
      .quiz-result-state.hidden { display: none; }
      .quiz-result-text { font-size: 0.8rem; font-weight: 700; text-align: center; line-height: 1.4; }
      .quiz-result-text.success { color: var(--green); }
      .quiz-result-text.warning { color: var(--yellow-d); }
      
      .quiz-action-btn {
        display: block; text-align: center; font-weight: 700; font-size: 0.9rem;
        padding: 0.8rem; border-radius: 100px; text-decoration: none;
        transition: all 0.25s var(--ease); width: 100%; box-sizing: border-box;
      }
      .quiz-action-btn.success {
        background: var(--yellow); color: var(--navy);
        box-shadow: 0 4px 14px rgba(246,193,51,0.25);
      }
      .quiz-action-btn.success:hover {
        background: var(--yellow-d); transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4);
      }
      .quiz-action-btn.fallback {
        background: transparent; border: 1px solid var(--grey-l); color: var(--navy);
      }
      .quiz-action-btn.fallback:hover {
        border-color: var(--navy); background: var(--sky);
      }

      /* Fit Check Card */
      .fit-card {
        background: var(--white);
        border-radius: var(--r-xl);
        padding: 2.25rem 2rem;
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-premium);
        animation: fadeUp 0.8s var(--ease) 0.15s both;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .fit-card-header {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .fit-card-label {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
      }
      .fit-card h3 {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
        line-height: 1.25;
      }
      .fit-list {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .fit-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--sky);
        padding: 1rem 1.25rem;
        border-radius: var(--r);
        border: 1px solid transparent;
        cursor: pointer;
        user-select: none;
        transition: all 0.2s var(--ease);
      }
      .fit-item:hover {
        background: var(--blue-xl);
        border-color: rgba(29, 111, 168, 0.15);
      }
      .fit-item.checked {
        background: var(--green-l);
        border-color: rgba(22, 163, 74, 0.2);
      }
      .fit-checkbox-custom {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        border: 2px solid var(--grey-l);
        background: var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s var(--ease);
        flex-shrink: 0;
      }
      .fit-checkbox-custom svg {
        width: 14px;
        height: 14px;
        color: transparent;
        transition: color 0.2s var(--ease);
      }
      .fit-item.checked .fit-checkbox-custom {
        background: var(--green);
        border-color: var(--green);
      }
      .fit-item.checked .fit-checkbox-custom svg {
        color: var(--white);
      }
      .fit-text {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.4;
        transition: color 0.2s var(--ease);
      }
      .fit-item.checked .fit-text {
        color: #0f5132;
      }
      .fit-cta {
        display: block;
        text-align: center;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 1rem;
        border-radius: 100px;
        text-decoration: none;
        background: var(--grey-l);
        color: var(--grey);
        border: 1px solid transparent;
        transition: all 0.25s var(--ease);
        width: 100%;
        box-sizing: border-box;
      }
      .fit-cta.active {
        background: var(--yellow);
        color: var(--navy);
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.25);
      }
      .fit-cta.active:hover {
        background: var(--yellow-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4);
      }

      /* ─── BENEFITS SECTION ─────────────────────── */
      #why-us { background: var(--white) !important; }
      .benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .benefit-card {
        padding: 2.25rem 2rem; background: var(--sky); border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl); display: flex; flex-direction: column; gap: 1rem;
        transition: transform 0.3s, box-shadow 0.3s;
      }
      .benefit-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
      .benefit-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--white); border: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
      .benefit-card h3 { font-size: 1.15rem; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
      .benefit-card p { font-size: 0.9rem; color: var(--grey); line-height: 1.6; }

      /* ─── REQUIREMENTS SECTION ─────────────────── */
      #requirements { background: var(--sky) !important; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
      .req-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
      .req-list { display: flex; flex-direction: column; gap: 1.15rem; margin-top: 1.5rem; }
      .req-item { display: flex; align-items: flex-start; gap: 0.85rem; font-size: 0.95rem; color: var(--grey-d); line-height: 1.6; }
      .req-item::before { content: "✓"; color: var(--blue); font-weight: 800; font-size: 0.85rem; flex-shrink: 0; width: 20px; height: 20px; background: var(--white); border: 1px solid var(--border-subtle); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-top: 2px; }

      /* ─── APPLICATION FORM SECTION ────────────── */
      #apply-section { background: var(--white) !important; }
      .apply-layout { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 5rem; align-items: start; }
      .apply-form-card {
        background: var(--white); border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl); padding: 3rem; box-shadow: var(--shadow-premium);
      }
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .form-full { grid-column: 1 / -1; }
      .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
      .form-group label { font-size: 0.8rem; font-weight: 700; color: var(--navy); text-transform: uppercase; letter-spacing: 0.05em; }
      .form-group input, .form-group select, .form-group textarea {
        font-family: var(--font); font-size: 0.92rem; color: var(--navy);
        padding: 0.85rem 1.15rem; border: 1px solid var(--grey-l); border-radius: var(--r);
        background: var(--sky); transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
      }
      .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
