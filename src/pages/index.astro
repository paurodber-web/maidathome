      /* ─────────────────────────────────────────── */
      /* HOW IT WORKS — Authentic Service Style      */
      /* ─────────────────────────────────────────── */
      #how6 {
        background: var(--white);
      }
      .how6-steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-top: 4rem;
        position: relative;
      }
      .how6-steps::before {
        content: "";
        position: absolute;
        top: 36px;
        left: calc(12.5% + 36px);
        right: calc(12.5% + 36px);
