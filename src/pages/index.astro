         Area tabs and suburb search
         -------------------------------------------------------------- */
      const areaTabs = [...document.querySelectorAll(".area-tab")];
      const areaPanels = [...document.querySelectorAll(".area-panel")];
      const suburbSearch = document.getElementById("suburbSearch");
      const areaSearchResult = document.getElementById("areaSearchResult");

      const activateArea = (zone, focus = false) => {
        areaTabs.forEach((tab) => {
          const active = tab.dataset.zone === zone;
          tab.setAttribute("aria-selected", String(active));
          tab.tabIndex = active ? 0 : -1;
          if (active && focus) tab.focus();
        });
        areaPanels.forEach((panel) => {
          const active = panel.dataset.zone === zone;
          panel.classList.toggle("is-active", active);
          panel.hidden = !active;
        });
      };

      areaTabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activateArea(tab.dataset.zone));
        tab.addEventListener("keydown", (event) => {
          if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
          event.preventDefault();
          let nextIndex = index;
          if (event.key === "ArrowRight") nextIndex = (index + 1) % areaTabs.length;
          if (event.key === "ArrowLeft") nextIndex = (index - 1 + areaTabs.length) % areaTabs.length;
          if (event.key === "Home") nextIndex = 0;
          if (event.key === "End") nextIndex = areaTabs.length - 1;
          activateArea(areaTabs[nextIndex].dataset.zone, true);
        });
      });

      const allSuburbs = areaPanels.flatMap((panel) => [...panel.querySelectorAll("li")].map((item) => ({ name: item.textContent.trim(), item, zone: panel.dataset.zone })));

      suburbSearch.addEventListener("input", () => {
        const term = suburbSearch.value.trim().toLowerCase();
        allSuburbs.forEach(({ item }) => item.classList.remove("is-match"));
        areaSearchResult.className = "area-search-result";

        if (term.length < 2) {
          areaSearchResult.textContent = "Type at least two letters to search our service areas.";
          return;
        }

        const exact = allSuburbs.find(({ name }) => name.toLowerCase() === term);
        const partial = allSuburbs.find(({ name }) => name.toLowerCase().includes(term));
        const match = exact || partial;

        if (match) {
          activateArea(match.zone);
          match.item.classList.add("is-match");
          areaSearchResult.textContent = \`Yes, we service \${match.name}.\`;
          areaSearchResult.classList.add("is-found");
          window.setTimeout(() => match.item.scrollIntoView({ behavior: "smooth", block: "nearest" }), 80);
        } else {
          areaSearchResult.textContent = "That suburb is not on our current list. Contact us to check nearby availability.";
          areaSearchResult.classList.add("is-missing");
        }
      });

