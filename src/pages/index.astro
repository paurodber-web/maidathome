    <script is:inline>
      /* ─ HEADER ───────────────────────────────────── */
      const hd6 = document.getElementById("hd6");
      const pnavLinks = document.querySelectorAll(".pnav-link");
      const pnavSections = ["srv6", "rec6", "how6", "tst6", "team6", "eol6", "faq6"].map(
        (id) => document.getElementById(id),
      );
      let pnavSectionOffsets = [];
      let lastActiveIndex = -1;
      let scrollTicking = false;
      let resizeTicking = false;

      const measurePnavSections6 = () => {
        resizeTicking = false;
        pnavSectionOffsets = pnavSections.map((sec) => (sec ? sec.offsetTop : 0));
      };

      const updateScrollUi6 = () => {
        scrollTicking = false;
        const isScrolled = window.scrollY > 20;
        if (hd6) {
          hd6.classList.toggle("scrolled", isScrolled);
        }

        const offset = isScrolled ? 64 : 72;
        const scrollY = window.scrollY + offset + 48 + 40;
        let current = 0;
        pnavSectionOffsets.forEach((secTop, i) => {
          if (secTop <= scrollY) current = i;
        });

        if (current === lastActiveIndex) return;
        lastActiveIndex = current;
        pnavLinks.forEach((link, i) => link.classList.toggle("active", i === current));
      };

      const onScroll6 = () => {
        if (scrollTicking) return;
        scrollTicking = true;
        window.requestAnimationFrame(updateScrollUi6);
      };

      const onResize6 = () => {
        if (resizeTicking) return;
        resizeTicking = true;
        window.requestAnimationFrame(() => {
          measurePnavSections6();
          updateScrollUi6();
        });
      };

      window.addEventListener("scroll", onScroll6, { passive: true });
      window.addEventListener("resize", onResize6, { passive: true });
      window.addEventListener("load", onResize6, { once: true });
      measurePnavSections6();
      updateScrollUi6();

            /* ─ MOBILE NAV / MENU ────────────────────────── */
      const tog6 = document.getElementById("hd6Toggle");
      const mob6 = document.getElementById("hd6-mob");
      const cls6 = document.getElementById("hd6MobClose");
      
      if (tog6 && mob6) {
        tog6.addEventListener("click", () => {
          const isOpen = mob6.classList.toggle("open");
          if (hd6) hd6.classList.toggle("menu-open", isOpen);
          tog6.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });
      }
      
      if (cls6 && mob6 && tog6) {
        cls6.addEventListener("click", () => {
          mob6.classList.remove("open");
          if (hd6) hd6.classList.remove("menu-open");
          tog6.setAttribute("aria-expanded", "false");
        });
      }
      
      if (mob6) {
        mob6.querySelectorAll("a").forEach(a => {
          a.addEventListener("click", () => {
            mob6.classList.remove("open");
            if (hd6) hd6.classList.remove("menu-open");
            if (tog6) tog6.setAttribute("aria-expanded", "false");
          });
        });
      }

      /* ─ MOBILE DROPDOWN ACCORDION ────────────────── */
      if (mob6) {
        mob6.querySelectorAll('.mob6-dropdown-toggle').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const targetId = btn.getAttribute('data-target');
            const submenu = document.getElementById(targetId);
            if (submenu) {
              const isCollapsed = submenu.classList.contains('collapsed');
              if (isCollapsed) {
                submenu.classList.remove('collapsed');
                btn.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
              } else {
                submenu.classList.add('collapsed');
                btn.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
              }
            }
          });
        });
      }

      /* ─ STAGGER OBSERVER ─────────────────────────── */
      const sObs6 = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const items = Array.from(
              entry.target.querySelectorAll(".si"),
            ).filter((el) => !el.classList.contains("in"));
            items.forEach((item, i) =>
              setTimeout(() => item.classList.add("in"), i * 110),
            );
            sObs6.unobserve(entry.target);
          });
        },
        { threshold: 0.05, rootMargin: "0px 0px -20px 0px" },
      );
      document.querySelectorAll(".sg").forEach((g) => sObs6.observe(g));

      /* ─ FAQ ──────────────────────────────────────── */
      document.querySelectorAll(".faq6-item").forEach((item) => {
        item.querySelector(".faq6-q").addEventListener("click", () => {
          const open = item.classList.contains("open");
          document.querySelectorAll(".faq6-item.open").forEach((o) => {
            o.classList.remove("open");
            o.querySelector(".faq6-q").setAttribute("aria-expanded", "false");
          });
          if (!open) {
            item.classList.add("open");
            item.querySelector(".faq6-q").setAttribute("aria-expanded", "true");
          }
        });
      });

      /* ─ ACTIVE HOME NAV LINK LOGIC ─────────────── */
      /* ─ CALCULATOR ───────────────────────────────── */
      const BASE = { standard: 120, deep: 175, eol: 260, movein: 160 };
      const BED = { standard: 35, deep: 50, eol: 65, movein: 40 };
      const BATH = { standard: 25, deep: 35, eol: 50, movein: 30 };
      const DISC = { once: 1, weekly: 0.9, monthly: 0.95 };
      const INCL = {
        standard: [
          "All bedrooms",
          "Living areas",
          "Kitchen surfaces",
          "Bathrooms",
          "Vacuum & mop",
          "Dusting",
        ],
        deep: [
          "Everything in Standard",
          "Oven interior",
          "Fridge interior",
          "Grout lines",
          "Skirting boards",
          "Windows (interior)",
        ],
        eol: [
          "Full REIV checklist",
          "Oven, range & cupboards",
          "Bathrooms, tiles & grout",
          "Floors & skirting boards",
          "Windows & blinds",
          "72h re-clean guarantee",
        ],
        movein: [
          "Full REIV checklist",
          "Oven, range & cupboards",
          "Bathrooms, tiles & grout",
          "Floors & skirting boards",
          "Windows & blinds",
          "72h re-clean guarantee",
        ],
      };
      let C6 = { svc: "standard", beds: 2, baths: 1, freq: "once" };

      function renderCalc6() {
        const raw =
          BASE[C6.svc] +
          (C6.beds - 1) * BED[C6.svc] +
          (C6.baths - 1) * BATH[C6.svc];
        const price = Math.round(raw * DISC[C6.freq]);
        document.getElementById("c6-price").innerHTML = `<sup>$</sup>${price}`;
        const el = document.getElementById("c6-includes");
        el.innerHTML = INCL[C6.svc]
          .map((i) => `<div class="calc6-incl-item">${i}</div>`)
          .join("");
      }

      // Tabs
      document.querySelectorAll(".calc6-tab").forEach((t) => {
        t.addEventListener("click", () => {
          document.querySelectorAll(".calc6-tab").forEach((x) => {
            x.classList.remove("on");
            x.setAttribute("aria-selected", "false");
          });
          t.classList.add("on");
          t.setAttribute("aria-selected", "true");
          C6.svc = t.dataset.svc;
          renderCalc6();
        });
      });

      // Steppers
      [
        ["c6-bed-m", "c6-bed-p", "c6-bed-v", "beds", 1, 6],
        ["c6-bath-m", "c6-bath-p", "c6-bath-v", "baths", 1, 4],
      ].forEach(([m, p, v, k, lo, hi]) => {
        document.getElementById(m).onclick = () => {
          if (C6[k] > lo) {
            C6[k]--;
            document.getElementById(v).textContent = C6[k];
            renderCalc6();
          }
        };
        document.getElementById(p).onclick = () => {
          if (C6[k] < hi) {
            C6[k]++;
            document.getElementById(v).textContent = C6[k];
            renderCalc6();
          }
        };
      });

      // Frequency
      document.querySelectorAll("[data-freq]").forEach((b) => {
        b.addEventListener("click", () => {
          document
            .querySelectorAll("[data-freq]")
            .forEach((x) => x.classList.remove("on"));
          b.classList.add("on");
          C6.freq = b.dataset.freq;
          renderCalc6();
        });
      });

      renderCalc6();
    </script>
  </body>
