:fixed;z-index:200;top:0;left:0;width:0;height:3px;background:var(--beige,#f4df9f);transition:width 0.08s linear}.nav-item-dropdown{position:relative;display:inline-block}.dropdown-menu{position:absolute;top:100%;left:50%;transform:translateX(-50%) translateY(10px);background:var(--white,#fff);border:1px solid var(--grey-200,#dbe4e8);border-radius:12px;box-shadow:0 10px 30px rgba(29,80,119,0.08);padding:10px;min-width:160px;opacity:0;visibility:hidden;transition:opacity 0.25s cubic-bezier(.22,1,.36,1),transform 0.25s cubic-bezier(.22,1,.36,1),visibility 0.25s;z-index:1000;display:flex;flex-direction:column;gap:6px}.nav-item-dropdown:hover .dropdown-menu{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0)}.dropdown-menu a{display:block;padding:8px 12px;border-radius:6px;font-size:0.8rem !important;font-weight:600;color:var(--ink,#183042) !important;white-space:nowrap;transition:background 0.2s,color 0.2s;text-align:left}.dropdown-menu a::after{display:none !important}.dropdown-menu a:hover{background:var(--blue-50,#f4fafc) !important;color:var(--blue-700,#286b9d) !important}`);
const scripts = `<script>
    (() => {
      "use strict";

      /* --------------------------------------------------------------
         Navigation and mobile menu
         -------------------------------------------------------------- */
      const header = document.getElementById("siteHeader");
      const menuToggle = document.getElementById("menuToggle");
      const mobileMenu = document.getElementById("mobileMenu");
      const mobileLinks = [...mobileMenu.querySelectorAll("a")];
      let lastFocusedElement = null;

      let headerFrame = 0;
      const updateHeader = () => {
        if (headerFrame) return;
        headerFrame = requestAnimationFrame(() => {
          header.classList.toggle("is-scrolled", window.scrollY > 24);
          headerFrame = 0;
        });
      };
      window.addEventListener("scroll", updateHeader, { passive: true });

      const setMenu = (open) => {
        menuToggle.setAttribute("aria-expanded", String(open));
        menuToggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        mobileMenu.setAttribute("aria-hidden", String(!open));
        mobileMenu.classList.toggle("is-open", open);
        header.classList.toggle("menu-active", open);
        document.body.classList.toggle("menu-open", open);

        if (open) {
          lastFocusedElement = document.activeElement;
          window.setTimeout(() => mobileLinks[0]?.focus(), 350);
        } else if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus({ preventScroll: true });
        }
      };

      menuToggle.addEventListener("click", () => setMenu(menuToggle.getAttribute("aria-expanded") !== "true"));
      mobileLinks.forEach((link) => link.addEventListener("click", () => setMenu(false)));

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && menuToggle.getAttribute("aria-expanded") === "true") setMenu(false);
        if (event.key !== "Tab" || menuToggle.getAttribute("aria-expanded") !== "true") return;

        const focusable = [menuToggle, ...mobileMenu.querySelectorAll("a, button, input, [tabindex]:not([tabindex='-1'])")].filter((el) => !el.hasAttribute("disabled"));
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last.focus(); }
        if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first.focus(); }
      });

      const desktopMedia = window.matchMedia("(min-width: 821px)");
      const closeMenuOnDesktop = (event) => { if (event.matches) setMenu(false); };
      desktopMedia.addEventListener?.("change", closeMenuOnDesktop);

      /* --------------------------------------------------------------
         Reveal motion
         -------------------------------------------------------------- */
      const revealItems = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const revealObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        }, { threshold: .1, rootMargin: "0px 0px -35px" });
        revealItems.forEach((item) => revealObserver.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      /* --------------------------------------------------------------
         Interactive calculator
         -------------------------------------------------------------- */
      const serviceConfig = {
        standard: { name: "Standard clean", prices: [155, 175, 195, 235, 285, 315] },
        deep: { name: "Deep clean", prices: [215, 245, 275, 315, 375, 415] },
        lease: { name: "End of lease clean", prices: [410, 440, 500, 570, 670, 710] },
        move: { name: "Move in clean", prices: [410, 440, 500, 570, 670, 710] },
        hourly: { name: "Hourly clean", rate: 60 }
      };

      const frequencyConfig = {
        once: { name: "One-off", discount: 0 },
        weekly: { name: "Weekly", discount: .10 },
        fortnightly: { name: "Fortnightly", discount: .10 },
        three: { name: "Every 3 weeks", discount: .05 },
        monthly: { name: "Every 4 weeks", discount: .05 }
      };

      const extraConfig = {
        oven: { name: "Inside oven", price: 65 },
        fridge: { name: "Inside fridge", price: 30 },
        windows: { name: "Interior windows", price: 70 },
        balcony: { name: "Balcony", price: 35 },
        walls: { name: "Clean walls", price: 25, quantity: true },
        blinds: { name: "Wet wipe blinds", price: 20, quantity: true },
        cabinets: { name: "Inside cabinets", price: 45 },
        linen: { name: "Change bed linen", price: 15, quantity: true },
        carpet: { name: "Carpet steam clean", price: 55, quantity: true }
      };

      const calcState = {
        bedrooms: 1,
        hours: 2,
        walls: 1,
        blinds: 1,
        linen: 1,
        carpet: 2
      };

      const limits = {
        bedrooms: [1, 6, 1],
        hours: [2, 12, .5],
        walls: [1, 20, 1],
        blinds: [1, 20, 1],
        linen: [1, 6, 1],
        carpet: [2, 10, 1]
      };

      const priceForm = document.getElementById("priceForm");
      const propertyControls = document.getElementById("propertyControls");
      const bedroomRow = document.getElementById("bedroomRow");
      const hoursRow = document.getElementById("hoursRow");
      const propertyHint = document.getElementById("propertyHint");
      const frequencyInputs = [...priceForm.querySelectorAll("input[name='frequency']")];
      const frequencyNotice = document.getElementById("frequencyNotice");
      const extraOptions = [...document.querySelectorAll(".extra-option")];
      const hourlyExtrasNotice = document.createElement("p");
      hourlyExtrasNotice.className = "hourly-extras-notice";
      hourlyExtrasNotice.innerHTML = "<strong>Most extras use your booked time.</strong> They are included in your hourly booking, not charged separately. Carpet steam clean is charged separately. Please book enough hours for your regular clean <strong>plus every included extra</strong> you select. Without enough booked time, we may not be able to complete every task, including your extras.";
      document.getElementById("extrasGrid").after(hourlyExtrasNotice);
      const extraLabels = new Map(extraOptions.map((option) => [option.dataset.extra, option.querySelector("small").textContent]));

      const money = (amount) => new Intl.NumberFormat("en-AU", { style: "currency", currency: "AUD", minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(amount);
      const activeService = () => priceForm.querySelector("input[name='service']:checked").value;
      const activeFrequency = () => priceForm.querySelector("input[name='frequency']:checked").value;

      const updateStepper = (name) => {
        document.querySelectorAll(\`[data-stepper="\${name}"]\`).forEach((stepper) => {
          const output = stepper.querySelector("output");
          const [min, max] = limits[name];
          output.textContent = Number.isInteger(calcState[name]) ? calcState[name] : calcState[name].toFixed(1);
          const minus = stepper.querySelector("[data-action='minus']");
          const plus = stepper.querySelector("[data-action='plus']");
          minus.disabled = calcState[name] <= min;
          plus.disabled = calcState[name] >= max;
        });
      };

      document.querySelectorAll("[data-stepper]").forEach((stepper) => {
        const name = stepper.dataset.stepper;
        stepper.addEventListener("click", (event) => {
          const button = event.target.closest("button");
          if (!button) return;
          const [min, max, increment] = limits[name];
          const direction = button.dataset.action === "plus" ? 1 : -1;
          calcState[name] = Math.min(max, Math.max(min, calcState[name] + increment * direction));
          updateStepper(name);
          calculatePrice();
        });
        updateStepper(name);
      });

      const setIncludedExtra = (key, included) => {
        const option = document.querySelector(\`.extra-option[data-extra="\${key}"]\`);
        const input = option.querySelector("input");
        const priceText = option.querySelector("small");
        option.classList.toggle("is-included", included);
        input.disabled = included;
        if (included) {
          input.checked = false;
          priceText.textContent = "Included in service";
          priceText.classList.add("included-label");
        } else {
          priceText.textContent = key === "oven" ? "$65" : "$45";
          priceText.classList.remove("included-label");
        }
      };

      const updateHourlyExtrasUI = (isHourly) => {
        hourlyExtrasNotice.classList.toggle("is-visible", isHourly);
        extraOptions.forEach((option) => {
          const input = option.querySelector("input");
          if (input.disabled) return;
          const priceText = option.querySelector("small");
          priceText.textContent = isHourly && option.dataset.extra !== "carpet" ? "Included in booked hours" : extraLabels.get(option.dataset.extra);
        });
      };

      const updateServiceUI = () => {
        const service = activeService();
        const isHourly = service === "hourly";
        const canRepeat = service === "standard" || service === "deep" || service === "hourly";

        bedroomRow.hidden = isHourly;
        hoursRow.hidden = !isHourly;
        propertyControls.classList.toggle("is-hourly", isHourly);
        propertyHint.textContent = isHourly ? "Choose total time" : "Your home size";

        frequencyInputs.forEach((input) => {
          input.disabled = !canRepeat && input.value !== "once";
        });

        if (!canRepeat && activeFrequency() !== "once") {
          document.getElementById("freqOnce").checked = true;
        }

        frequencyNotice.classList.toggle("is-visible", !canRepeat);
        setIncludedExtra("oven", service === "lease" || service === "move");
        setIncludedExtra("cabinets", service === "lease" || service === "move");
        updateHourlyExtrasUI(isHourly);
      };

      function calculatePrice() {
        const service = activeService();
        const frequency = activeFrequency();
        const serviceData = serviceConfig[service];
        const frequencyData = frequencyConfig[frequency];
        const eligibleDiscount = service === "standard" || service === "deep" || service === "hourly";

        let basePrice;
        if (service === "hourly") {
          basePrice = serviceData.rate * calcState.hours;
        } else {
          basePrice = serviceData.prices[calcState.bedrooms - 1];
        }

        let extraTotal = 0;
        const selectedExtras = [];
        extraOptions.forEach((option) => {
          const key = option.dataset.extra;
          const input = option.querySelector("input");
          if (!input.checked || input.disabled) return;
          const item = extraConfig[key];
          const quantity = item.quantity ? calcState[key] : 1;
          const linePrice = service === "hourly" && key !== "carpet" ? 0 : item.price * quantity;
          extraTotal += linePrice;
          selectedExtras.push({ name: item.name, quantity, linePrice, showQuantity: item.quantity });
        });

        const discountRate = eligibleDiscount ? frequencyData.discount : 0;
        const discountAmount = Math.round((basePrice * discountRate + Number.EPSILON) * 100) / 100;
        const total = Math.round((basePrice + extraTotal - discountAmount + Number.EPSILON) * 100) / 100;

        document.getElementById("summaryService").textContent = serviceData.name;
        document.getElementById("summaryBase").textContent = money(basePrice);
        document.getElementById("summaryTotal").textContent = money(total);

        const propertyCopy = service === "hourly"
          ? \`\${calcState.hours} total hours · \${frequencyData.name}\`
          : \`\${calcState.bedrooms} bedroom\${calcState.bedrooms === 1 ? "" : "s"} · \${frequencyData.name}\`;
        document.getElementById("summaryProperty").textContent = propertyCopy;

        const extrasContainer = document.getElementById("summaryExtras");
        extrasContainer.replaceChildren(...selectedExtras.map((extra) => {
          const row = document.createElement("div");
          row.className = "summary-extra";
          const label = document.createElement("span");
          label.textContent = \`\${extra.name}\${extra.showQuantity ? \` × \${extra.quantity}\` : ""}\`;
          const price = document.createElement("strong");
          price.textContent = money(extra.linePrice);
          row.append(label, price);
          return row;
        }));

        const discountRow = document.getElementById("summaryDiscountRow");
        discountRow.hidden = discountAmount === 0;
        document.getElementById("summaryDiscountLabel").textContent = \`Recurring saving (\${Math.round(discountRate * 100)}%)\`;
        document.getElementById("summaryDiscount").textContent = \`−\${money(discountAmount)}\`;

        const params = new URLSearchParams({ service, frequency, estimate: String(total) });
        document.getElementById("bookingLink").href = \`booking.html?\${params.toString()}\`;
      }

      priceForm.addEventListener("change", (event) => {
        if (event.target.name === "service") updateServiceUI();
        calculatePrice();
      });

      updateServiceUI();
      calculatePrice();

      /* Service links select the matching calculator option when possible. */
      document.querySelectorAll("[aria-label^='Estimate a']").forEach((link) => {
        link.addEventListener("click", () => {
          const label = link.getAttribute("aria-label").toLowerCase();
          const value = label.includes("standard") ? "standard" : label.includes("deep") ? "deep" : null;
          if (!value) return;
          const input = priceForm.querySelector(\`input[name="service"][value="\${value}"]\`);
          if (input) { input.checked = true; updateServiceUI(); calculatePrice(); }
        });
      });

