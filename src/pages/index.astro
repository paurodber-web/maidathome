          transform 0.3s var(--ease),
          background-color 0.3s;
        border: 1px solid var(--border-subtle);
      }
      .srv6-card.cs .srv6-ico-ring {
        background: var(--sky);
      }
      .srv6-card.cd .srv6-ico-ring {
        background: var(--green-l);
      }
      .srv6-card.ceol .srv6-ico-ring {
        background: var(--yellow-l);
      }
      .srv6-card.cmi .srv6-ico-ring {
        background: #f5f3ff;
      }
      .srv6-card.ccp .srv6-ico-ring {
        background: #fff7ed;
      }
      .srv6-card.cex .srv6-ico-ring {
        background: var(--sky);
      }

      .srv6-card:hover .srv6-ico-ring {
        transform: scale(1.08) rotate(3deg);
      }
      .srv6-card.ceol:hover .srv6-ico-ring {
        background-color: var(--yellow);
      }
      .srv6-badge {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        background: var(--navy);
        color: var(--yellow);
        font-size: 0.65rem;
        font-weight: 800;
        padding: 0.25rem 0.75rem;
