        gap: 0.6rem;
      }
      .eol6-incl li::before {
        content: "✓";
        color: var(--green);
        font-weight: 800;
        flex-shrink: 0;
      }
      .eol6-guarantee-card {
        background: var(--navy);
        color: var(--white);
        border-radius: var(--r-xl);
        padding: 2.25rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        margin-bottom: 2rem;
      }
      .eol6-guarantee-card::before {
        content: "⭐";
        position: absolute;
        right: -15px;
        bottom: -15px;
        font-size: 6.5rem;
        opacity: 0.05;
        line-height: 1;
        user-select: none;
      }
      .eol6-g-eyebrow {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 0.75rem;
      }
      .eol6-g-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin-bottom: 1rem;
      }
      .eol6-g-items {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        margin-bottom: 1.5rem;
      }
      .eol6-g-item {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.5;
      }
      .eol6-g-check {
        color: var(--yellow);
        font-weight: 800;
        flex-shrink: 0;
      }
      .eol6-quote {
        background: rgba(255, 255, 255, 0.06);
        border-radius: var(--r);
        padding: 1.1rem;
        border-left: 3px solid var(--yellow);
      }
      .eol6-quote-text {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.8);
        font-style: italic;
        line-height: 1.6;
        margin-bottom: 0.5rem;
      }
      .eol6-quote-by {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.45);
        font-weight: 600;
      }
      .eol6-cta-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .eol6-urgency {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        font-size: 0.82rem;
        color: var(--grey-d);
        line-height: 1.45;
        background: var(--yellow-l);
        padding: 0.9rem 1.1rem;
        border-radius: var(--r);
        border: 1px solid rgba(246, 193, 51, 0.18);
      }

      /* ─── PRICING CALCULATOR (BASE) ───────────── */
      #calc6 {
        background: var(--sky);
      }
      .calc6-layout {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 5.5rem;
        align-items: center;
      }
      .calc6-label {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--blue);
        letter-spacing: 0.08em;
        margin-bottom: 0.75rem;
      }
      .calc6-trustpoints {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        margin-top: 2.25rem;
      }
      .calc6-tp {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        font-size: 0.92rem;
        color: var(--grey-d);
        font-weight: 600;
      }
      .calc6-tp-ico {
        font-size: 1.3rem;
        flex-shrink: 0;
      }
      .calc6-card {
        background: var(--white);
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-premium);
        overflow: hidden;
      }
      .calc6-tabs {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border-bottom: 1px solid var(--border-subtle);
        background: var(--sky);
      }
      .calc6-tab {
        padding: 1.25rem 0.5rem;
        border: none;
        background: transparent;
        font-family: var(--font);
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--grey);
        cursor: pointer;
        transition:
          color 0.25s,
          background-color 0.25s;
        text-align: center;
        border-right: 1px solid var(--border-subtle);
      }
      .calc6-tab:last-child {
        border-right: none;
      }
      .calc6-tab:hover {
        color: var(--blue);
        background-color: rgba(29, 111, 168, 0.02);
      }
      .calc6-tab.on {
        background: var(--white);
        color: var(--blue);
        box-shadow: inset 0 -2px 0 var(--blue);
      }
      .calc6-body {
        padding: 2.75rem;
      }
      .calc6-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .calc6-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .calc6-lbl {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--navy);
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .calc6-stepper {
        display: flex;
        align-items: center;
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        background: var(--sky);
        overflow: hidden;
        height: 48px;
      }
      .calc6-sbtn {
        flex: 1;
        height: 100%;
        border: none;
        background: transparent;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--navy);
        cursor: pointer;
        transition: background-color 0.2s;
      }
      .calc6-sbtn:hover {
        background-color: rgba(10, 29, 51, 0.05);
      }
      .calc6-sval {
        width: 55px;
        text-align: center;
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--navy);
      }
      .calc6-freq {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
      }
      .calc6-fopt {
        padding: 1rem 0.5rem;
        border: 1px solid var(--border-subtle);
        border-radius: var(--r);
        background: var(--white);
        font-family: var(--font);
        font-size: 0.82rem;
        font-weight: 800;
        color: var(--navy);
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.2rem;
        transition:
          border-color 0.25s,
          box-shadow 0.25s,
          background-color 0.25s;
        line-height: 1.2;
      }
      .calc6-fopt small {
        font-size: 0.65rem;
        color: var(--green);
        font-weight: 700;
        display: block;
      }
      .calc6-fopt[data-freq="once"] small {
        color: var(--grey);
        font-weight: 500;
      }
      .calc6-fopt:hover {
        border-color: var(--blue);
      }
      .calc6-fopt.on {
        border-color: var(--blue);
        background-color: var(--blue-xl);
        box-shadow: 0 4px 12px rgba(29, 111, 168, 0.06);
      }
      .calc6-result {
        margin-top: 2.25rem;
        border-top: 1px solid var(--border-subtle);
        padding-top: 2rem;
      }
      .calc6-result-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .calc6-price-lbl {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--grey);
      }
      .calc6-price {
        font-size: 3rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.04em;
        margin: 0.1rem 0;
        line-height: 1.1;
      }
      .calc6-price sup {
        font-size: 1.5rem;
        font-weight: 700;
        top: -1rem;
      }
      .calc6-price-note {
        font-size: 0.75rem;
        color: var(--grey);
      }
      .calc6-includes {
        margin-top: 1.5rem;
        border-radius: var(--r);
        background: var(--sky);
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        max-height: 150px;
        overflow-y: auto;
        border: 1px solid var(--border-subtle);
      }
      .calc6-inc-item {
        font-size: 0.85rem;
        color: var(--grey-d);
        display: flex;
        align-items: center;
        gap: 0.55rem;
        line-height: 1.4;
      }
      .calc6-inc-item::before {
        content: "✓";
        color: var(--blue);
        font-weight: 800;
        flex-shrink: 0;
      }
      .calc6-book-row {
        display: flex;
        gap: 1.25rem;
        margin-top: 2rem;
        align-items: center;
      }
      .btn6-book {
        flex: 1.2;
        text-align: center;
        text-decoration: none;
        padding: 1.1rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 800;
        font-size: 0.95rem;
        border-radius: 100px;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
        transition:
          background-color 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
      }
      .btn6-book:hover {
        background-color: var(--yellow-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.35);
      }
      .btn6-call {
        flex: 0.8;
        text-align: center;
        text-decoration: none;
        padding: 1.1rem;
        border: 1px solid var(--grey-l);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 100px;
        background-color: var(--white);
        transition:
          border-color 0.2s,
          background-color 0.2s,
          color 0.2s;
      }
      .btn6-call:hover {
        border-color: var(--navy);
        background-color: var(--sky);
        color: var(--navy);
      }

      /* ─── SERVICE AREA / COVERAGE (BASE) ──────── */
      #cov6 {
        background: var(--white);
      }
      .cov6-layout {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem;
        align-items: center;
      }
      .suburb-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.75rem;
      }
      .s-chip {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--navy);
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        padding: 0.5rem 1.1rem;
        border-radius: 100px;
        transition:
          border-color 0.25s,
          color 0.25s,
          background-color 0.25s,
          transform 0.25s,
          box-shadow 0.25s;
      }
      .s-chip:hover {
        border-color: var(--blue);
        color: var(--white) !important;
        background-color: var(--blue);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(29, 111, 168, 0.15);
      }
      .cov6-img {
        border-radius: var(--r-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        height: 440px;
        border: 1px solid var(--border-subtle);
      }
      .cov6-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FAQS (BASE) ─────────────────────────── */
      #faq6 {
        background: var(--sky);
      }
      .faq6-layout {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 5.5rem;
      }
      .faq6-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .faq6-item {
        background: var(--white);
        border-radius: var(--r-l);
        border: 1px solid var(--border-subtle);
        overflow: hidden;
        transition:
          border-color 0.3s var(--ease),
          box-shadow 0.3s var(--ease);
      }
      .faq6-item.open {
        border-color: var(--blue);
        box-shadow: var(--shadow-md);
      }
      .faq6-q {
        width: 100%;
        padding: 1.6rem 2rem;
        border: none;
        background: transparent;
        font-family: var(--font);
        font-size: 1rem;
        font-weight: 700;
        color: var(--navy);
        text-align: left;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        transition: color 0.2s;
      }
      .faq6-q:hover {
        color: var(--blue);
      }
      .faq6-ico {
        font-size: 1.3rem;
        color: var(--blue);
        font-weight: 600;
        transition: transform 0.35s var(--ease);
        flex-shrink: 0;
      }
      .faq6-item.open .faq6-ico {
        transform: rotate(45deg);
        color: var(--grey);
      }
      .faq6-a {
        padding: 0 2rem 1.6rem;
        font-size: 0.9rem;
        color: var(--grey);
        line-height: 1.65;
        display: none;
      }
      .faq6-item.open .faq6-a {
        display: block;
      }

      /* ─── FINAL CTA ───────────────────────────── */
      #cta6 {
        padding: 6.5rem 0;
        overflow: hidden;
      }
      #cta6.cta-white {
        background: var(--white);
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      #cta6.cta-sky {
        background: var(--sky);
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      #cta6.cta-navy {
        background: var(--navy);
        color: var(--white);
      }

      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      /* Theme styles for cta-navy vs light themes */
      #cta6.cta-navy #cta6-h2 {
        color: var(--white);
      }
      #cta6.cta-navy #cta6-h2 .ac {
        background: linear-gradient(135deg, var(--blue-l), #93c5fd);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      #cta6.cta-navy .cta6-sub {
        color: var(--blue-xl);
      }
      #cta6.cta-navy .cta6-trust-item {
        color: var(--blue-xl);
      }
      #cta6.cta-navy .cta6-trust-item::before {
        content: "✓";
        color: var(--yellow);
      }
      #cta6.cta-navy #cta6-call {
        color: var(--white);
        border-color: rgba(255, 255, 255, 0.25);
      }
      #cta6.cta-navy #cta6-call:hover {
        border-color: var(--white);
        background: rgba(255, 255, 255, 0.08);
      }
      #cta6.cta-navy .eyebrow6 {
        color: var(--blue-l);
      }

      /* Light themes (white & sky) */
      #cta6:not(.cta-navy) #cta6-h2 {
        color: var(--navy);
      }
      #cta6:not(.cta-navy) #cta6-h2 .ac {
        color: var(--blue);
      }
      #cta6:not(.cta-navy) .cta6-sub {
        color: var(--grey);
      }
      #cta6:not(.cta-navy) .cta6-trust-item {
        color: var(--grey-d);
      }
      #cta6:not(.cta-navy) .cta6-trust-item::before {
        content: "✓";
        color: var(--green);
      }
      #cta6:not(.cta-navy) #cta6-call {
        color: var(--navy);
        border-color: var(--grey-l);
      }
      #cta6:not(.cta-navy) #cta6-call:hover {
        border-color: var(--navy);
        background: var(--sky);
      }
      #cta6:not(.cta-navy) .eyebrow6 {
        color: var(--blue);
      }

      #cta6-h2 {
        font-size: clamp(2rem, 3.2vw, 2.7rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
      }
      .cta6-sub {
        font-size: 1.05rem;
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        border-top: 1px solid var(--border-subtle);
        padding-top: 1.5rem;
      }
      #cta6.cta-navy .cta6-trust {
        border-top-color: rgba(255, 255, 255, 0.08);
      }
      .cta6-trust-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.83rem;
        font-weight: 600;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER (BASE) ───────────────────────── */
      footer {
        background: var(--navy);
        color: var(--white);
        padding: 5.5rem 0 2.5rem;
      }
      .ft6-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-bottom: 3rem;
      }
      .ft6-brand {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .ft6-desc {
        font-size: 0.88rem;
        color: var(--blue-xl);
        line-height: 1.6;
        max-width: 280px;
      }
      .ft6-social {
        display: flex;
        gap: 0.75rem;
      }
      .ft6-soc-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: var(--white);
        text-decoration: none;
        transition:
          background-color 0.2s,
          transform 0.2s;
      }
      .ft6-soc-btn:hover {
        background-color: var(--blue);
        transform: translateY(-2px);
      }
      .ft6-col {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .ft6-col-title {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--blue-l);
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }
      .ft6-col a {
        font-size: 0.88rem;
        color: var(--blue-xl) !important;
        text-decoration: none;
        transition: color 0.2s;
      }
      .ft6-col a:hover {
        color: var(--white) !important;
      }
      .ft6-bottom {
        max-width: 1180px;
        margin: 2rem auto 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--grey);
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .ft6-bottom-links {
        display: flex;
        gap: 1.5rem;
      }
      .ft6-bottom span,
      .ft6-bottom a {
        color: rgba(255, 255, 255, 0.72) !important;
        text-decoration: none;
        transition: color 0.2s;
      }
      .ft6-bottom a:hover {
        color: var(--white) !important;
      }

      @media (max-width: 1024px) {
        .hd6-nav {
          display: none;
        }
        .hd6-toggle {
          display: flex;
        }
        #hero6 {
          height: auto;
          min-height: 100dvh;
          padding-bottom: 4rem;
        }
        .h6-body {
          grid-template-columns: 1fr;
          gap: 3.5rem;
          padding: 4.5rem 2.5rem 2rem;
          text-align: center;
        }
        .h6-text {
          align-items: center;
        }
        .h6-sub {
          margin-left: auto;
          margin-right: auto;
        }
        .h6-actions {
          justify-content: center;
        }
        .h6-trust {
          justify-content: center;
        }
        .tst6-grid {
          grid-template-columns: 1fr;
        }
        .how6-steps {
          grid-template-columns: repeat(2, 1fr);
          gap: 2.5rem;
        }
        .how6-steps::before {
          display: none;
        }
        .ft6-inner {
          grid-template-columns: 1fr 1fr;
          gap: 2.5rem;
        }
        .cta6-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
        .cta6-right {
          height: 320px;
        }
      }
      @media (max-width: 768px) {
        .c6 {
          padding: 0 1.5rem;
        }
        .pad {
          padding: 4.5rem 0;
        }
        .h6-display {
          font-size: 2.8rem;
        }
        .h6-photo-frame {
          width: 280px;
          height: 340px;
        }
        .h6-photo-bg {
          width: 300px;
          height: 360px;
        }
        .h6-badge {
          left: -10px;
          bottom: 10px;
          padding: 0.8rem 1.1rem;
        }
        .h6-rating-chip {
          right: -10px;
          top: 10px;
        }
        .srv6-grid {
          grid-template-columns: 1fr;
        }
        .sec-header6 {
          grid-template-columns: 1fr;
          gap: 1.5rem;
          margin-bottom: 2.5rem;
        }
        .rec6-grid {
          grid-template-columns: 1fr;
        }
        .rec6-layout-bottom {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .rec6-benefits {
          grid-template-columns: 1fr;
          gap: 1.1rem;
        }
        .rec6-right-info {
          padding: 1.5rem;
        }
        .how6-steps {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .team6-grid {
