---
import { suburbsData } from '../data/suburbs';
import { reviewsData } from '../data/reviews';

const selectedReviews = reviewsData.slice(0, 3);

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maid at Home — Premium House Cleaning Melbourne</title>
    <meta
      name="description"
      content="Melbourne's most trusted house cleaning service. Meet our local team of professional, police-checked cleaners. Standard, deep, end of lease & carpet cleaning with 100% bond guarantee."
    />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      /* ─── TOKENS ──────────────────────────────── */
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      :root {
        --navy: #0a1d33;
        --blue-d: #142d4c;
        --blue: #1d6fa8;
        --blue-l: #5aaee0;
        --blue-xl: #e8f4fd;
        --sky: #f0f7fd;
        --yellow: #f6c133;
        --yellow-d: #e0ab1d;
        --yellow-l: #fffbe6;
        --green: #16a34a;
        --green-l: #e8f7ee;
        --grey: #5e6a75;
        --grey-d: #2d3748;
        --grey-l: #e2e8f0;
        --white: #ffffff;

        /* Subtle premium border/shadow tokens instead of heavy lines */
        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover: rgba(29, 111, 168, 0.18);
        --shadow-sm: 0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md: 0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg: 0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium: 0 24px 60px rgba(10, 29, 51, 0.08);

        --font: "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s: 8px;
        --r: 12px;
        --r-l: 20px;
        --r-xl: 28px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img {
        display: block;
        max-width: 100%;
      }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes lineUp {
        from {
          transform: translateY(110%);
        }
        to {
          transform: translateY(0);
        }
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes imgReveal {
        from {
          opacity: 0;
          transform: scale(0.96) translateY(20px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes pulseDot {
        0% {
          transform: scale(1);
          opacity: 0.5;
        }
        100% {
          transform: scale(2);
          opacity: 0;
        }
      }
      @keyframes floatY {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-5px);
        }
      }
      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.7s var(--ease),
          transform 0.7s var(--ease);
      }
      .si[data-d="l"] {
        transform: translateX(-24px);
      }
      .si[data-d="r"] {
        transform: translateX(24px);
      }
      .si[data-d="sc"] {
        transform: scale(0.96);
      }
      .si.in {
        opacity: 1;
        transform: none;
      }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6 {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }
      .pad {
        padding: 6.5rem 0;
      }
      .pad-sm {
        padding: 4.5rem 0;
      }
      #home-nav + #srv6 {
        padding-top: 8rem;
      }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: "";
        width: 16px;
        height: 2.5px;
        background: var(--yellow);
        border-radius: 2px;
        flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--navy);
        line-height: 1.15;
      }
      h2.h6 .ac {
        color: var(--blue);
      }
      .lead6 {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.75;
        max-width: 500px;
        margin-top: 0.75rem;
      }
      .sec-header6 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: end;
        margin-bottom: 4rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.95rem 2rem;
        border-radius: 100px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover {
        background: var(--yellow-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4);
      }
      .btn6-navy {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--navy);
        color: var(--white);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.95rem 2rem;
        border-radius: 100px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(10, 29, 51, 0.15);
      }
      .btn6-navy:hover {
        background: var(--blue-d);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(10, 29, 51, 0.3);
      }
      .btn6-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--navy);
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.9rem 1.75rem;
        border-radius: 100px;
        border: 1px solid var(--grey-l);
        background: transparent;
        text-decoration: none;
        cursor: pointer;
        font-family: var(--font);
        white-space: nowrap;
        transition:
          border-color 0.25s,
          background 0.25s,
          color 0.25s;
      }
      .btn6-outline:hover {
        border-color: var(--navy);
        background: var(--sky);
        color: var(--navy);
      }
      .btn6-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--navy);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        transition:
          gap 0.2s,
          color 0.2s;
      }
      .btn6-ghost:hover {
        gap: 0.65rem;
        color: var(--blue);
      }

      /* ─────────────────────────────────────────── */
      /* HEADER                                      */
      /* ─────────────────────────────────────────── */
      #hd6 {
        position: fixed;
        inset: 0 0 auto;
        z-index: 200;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4vw;
        transition:
          background 0.3s var(--ease),
          box-shadow 0.3s var(--ease),
          height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px;
        border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
      }
      .hd6-mark {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: var(--blue);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark {
        background: var(--navy);
      }
      .hd6-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: -0.02em;
      }
      .hd6-nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .hd6-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--grey-d);
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition:
          color 0.2s,
          background 0.2s;
      }
      .hd6-nav a:hover {
        color: var(--blue);
        background: var(--sky);
      }
      .hd6-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--yellow);
        color: var(--navy);
        font-weight: 700;
        font-size: 0.9rem;
        padding: 0.55rem 1.35rem;
        border-radius: 100px;
        text-decoration: none;
        margin-left: 0.75rem;
        transition:
          background 0.2s,
          transform 0.2s,
          box-shadow 0.2s;
        white-space: nowrap;
      }
      .hd6-cta:hover {
        background: var(--yellow-d);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.35);
      }
      .hd6-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
        padding: 4px;
      }
      .hd6-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--navy);
        border-radius: 2px;
      }
      #hd6-mob {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 199;
        background: var(--white);
        flex-direction: column;
        padding: 6rem 2rem 2rem;
        gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open {
        display: flex;
      }
      #hd6-mob a {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-close {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        background: none;
        border: none;
        font-size: 1.6rem;
        cursor: pointer;
        color: var(--grey);
      }
      .mob6-cta {
        background: var(--yellow);
        color: var(--navy);
        text-align: center;
        border-radius: var(--r);
        padding: 1.1rem;
        margin-top: 1rem;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        display: block;
      }

      /* ─────────────────────────────────────────── */
      /* HERO (exact structure & visual)             */
      /* ─────────────────────────────────────────── */
      #hero6 {
        background: var(--sky);
        height: 100dvh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        padding-top: 72px;
      }
      .h6-sun {
        position: absolute;
        top: -140px;
        right: -120px;
        width: 650px;
        height: 650px;
        border-radius: 50%;
        background: radial-gradient(
          ellipse at center,
          rgba(246, 193, 51, 0.15) 0%,
          rgba(246, 193, 51, 0.03) 60%,
          transparent 80%
        );
        pointer-events: none;
      }
      .h6-arc {
        position: absolute;
        bottom: 80px;
        left: -80px;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        border: 40px solid rgba(255, 255, 255, 0.7);
        pointer-events: none;
      }
      .h6-body {
        flex: 1;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        max-width: 1180px;
        margin: 0 auto;
        padding: 5.5rem 2.5rem 4rem;
        gap: 4.5rem;
        align-items: center;
        position: relative;
        z-index: 2;
        width: 100%;
      }
      .h6-text {
        display: flex;
        flex-direction: column;
      }
      .h6-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--blue);
        letter-spacing: 0.05em;
        margin-bottom: 1.75rem;
        width: fit-content;
        background: var(--white);
        padding: 0.4rem 0.9rem;
        border-radius: 100px;
        box-shadow: var(--shadow-sm);
      }
      .h6-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        flex-shrink: 0;
        position: relative;
      }
      .h6-pill-dot::after {
        content: "";
        position: absolute;
        inset: -3px;
        border-radius: 50%;
        background: rgba(22, 163, 74, 0.25);
        animation: pulseDot 1.8s ease-out infinite;
      }
      .h6-display {
        font-size: clamp(3rem, 5.5vw, 4.4rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.05;
        color: var(--navy);
        margin-bottom: 1.5rem;
      }
      .h6-line {
        display: block;
        padding-bottom: 0.22em;
        margin-bottom: -0.17em;
      }
      .h6-line > span {
        display: block;
      }
      .h6-line.em > span {
        color: var(--blue);
      }
      .h6-sub {
        font-size: 1.1rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 480px;
        margin-bottom: 2.25rem;
      }
      .h6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
      }
      .h6-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .h6-trust-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--navy);
      }
      .h6-trust-check {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--blue-xl);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: var(--blue);
        font-weight: 800;
        flex-shrink: 0;
      }

      .h6-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .h6-photo-bg {
        position: absolute;
        width: 380px;
        height: 460px;
        border-radius: 200px 200px 180px 180px;
        background: var(--yellow);
        opacity: 0.15;
        top: 12px;
        left: 50%;
        transform: translateX(calc(-50% + 12px));
        pointer-events: none;
      }
      .h6-photo-frame {
        width: 360px;
        height: 440px;
        border-radius: 200px 200px 180px 180px;
        overflow: hidden;
        position: relative;
        z-index: 1;
        box-shadow: var(--shadow-lg);
      }
      .h6-photo-frame picture,
      .h6-photo-frame img {
        display: block;
        width: 100%;
        height: 100%;
      }
      .h6-photo-frame img {
        object-fit: cover;
        object-position: center top;
      }
      .h6-badge {
        position: absolute;
        bottom: 24px;
        left: -24px;
        background: var(--white);
        border-radius: var(--r-l);
        padding: 1.1rem 1.4rem;
        box-shadow: var(--shadow-lg);
        z-index: 2;
        animation: floatY 4.5s ease-in-out 1.2s infinite;
        border: 1px solid var(--border-subtle);
      }
      .h6-badge-stars {
        color: var(--yellow);
        font-size: 0.85rem;
        letter-spacing: 1.5px;
      }
      .h6-badge-quote {
        font-size: 0.82rem;
        color: var(--navy);
        font-weight: 700;
        margin-top: 0.25rem;
        line-height: 1.4;
        max-width: 180px;
      }
      .h6-badge-meta {
        font-size: 0.72rem;
        color: var(--grey);
        margin-top: 0.2rem;
      }
      .h6-rating-chip {
        position: absolute;
        top: 24px;
        right: -16px;
        background: var(--navy);
        color: var(--white);
        border-radius: 100px;
        padding: 0.5rem 1.1rem;
        font-size: 0.83rem;
        font-weight: 700;
        z-index: 2;
        white-space: nowrap;
        animation: floatY 5s ease-in-out 2s infinite;
        box-shadow: var(--shadow-md);
      }
      .h6-rating-chip span {
        color: var(--yellow);
      }

      /* ─────────────────────────────────────────── */
      /* HOME SECTION NAV                            */
      /* ─────────────────────────────────────────── */
      #home-nav {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 64px;
        z-index: 150;
      }
      .pnav-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pnav-inner::-webkit-scrollbar {
        display: none;
      }
      .pnav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--grey);
        padding: 1.1rem 1.15rem;
        text-decoration: none;
        white-space: nowrap;
        border-bottom: 3px solid transparent;
        margin-bottom: -1px;
        transition: color 0.25s, border-color 0.25s;
      }
      .pnav-link:hover {
        color: var(--blue);
      }
      .pnav-link.active {
        color: var(--navy);
        border-bottom-color: var(--blue);
      }

      /* ─────────────────────────────────────────── */
      /* SERVICES — Sleek Cards with Special Touch   */
      /* ─────────────────────────────────────────── */
      #srv6 {
        background: var(--white);
      }
      .srv6-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.75rem;
      }
      .srv6-card {
        background: var(--white);
        border-radius: var(--r-xl);
        padding: 2.25rem;
        border: 1px solid var(--border-subtle);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
          border-color 0.4s var(--ease),
          box-shadow 0.4s var(--ease),
          transform 0.4s var(--ease);
      }
      .srv6-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
      }
      /* Clean, thin top color strip */
      .srv6-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
      }
      .srv6-card.cs::before {
        background: var(--blue);
      }
      .srv6-card.cd::before {
        background: #10b981;
      }
      .srv6-card.ceol::before {
        background: var(--yellow);
      }
      .srv6-card.cmi::before {
        background: #8b5cf6;
      }
      .srv6-card.ccp::before {
        background: #f97316;
      }
      .srv6-card.cex::before {
        background: var(--grey);
      }

      /* Floating Accent Blur inside cards for a premium depth touch */
      .srv6-card-blur {
        position: absolute;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        filter: blur(24px);
        opacity: 0.025;
        pointer-events: none;
      }
      .srv6-card.cs .srv6-card-blur {
        background: var(--blue);
        top: -20px;
        right: -20px;
      }
      .srv6-card.cd .srv6-card-blur {
        background: #10b981;
        top: -20px;
        right: -20px;
      }
      .srv6-card.ceol .srv6-card-blur {
        background: var(--yellow);
        top: -20px;
        right: -20px;
      }

      /* Icon ring */
      .srv6-ico-ring {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 1.5rem;
        flex-shrink: 0;
