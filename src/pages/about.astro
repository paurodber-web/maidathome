    <!-- ─ 1. OUR STORY ──────────────────────────── -->
    <section id="story" class="pad" aria-labelledby="story-h2">
      <div class="c6">
        <div class="story-layout sg">

          <!-- Timeline (left) -->
          <div class="story-timeline si" data-d="l" aria-label="Maid at Home timeline">
            <div class="tl-item">
              <div class="tl-dot-wrap"><div class="tl-dot"></div></div>
              <div class="tl-content">
                <div class="tl-year">Pre-2017</div>
                <div class="tl-title">Two degrees, one decision</div>
                <div class="tl-text">Pau finishes his Business Administration degree in Spain. Stefania wraps up Communications and Journalism in Colombia. Both decide to move to Melbourne for a fresh start together.</div>
              </div>
            </div>
            <div class="tl-item hi">
              <div class="tl-dot-wrap"><div class="tl-dot"></div></div>
              <div class="tl-content">
                <div class="tl-year">2017</div>
                <div class="tl-title">Learning the job from the inside</div>
