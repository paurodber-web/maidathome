---
import SiteFooter from "../components/SiteFooter.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import {
  brightCleanLivingRoom,
  founderPau,
  founderStefania,
  miaTheCat,
} from "../data/site-images";
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const base = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
  const p = path.startsWith("/") ? path.slice(1) : path;
  return p ? `${base}${p}` : base;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About Us — Maid at Home Melbourne</title>
    <meta name="description" content="Meet Pau and Stefania, the founders of Maid at Home. From working as cleaners in Melbourne to building one of the city's most trusted residential cleaning services. Our story." />
    <link
      rel="preload"
      href={withBase("fonts/plus-jakarta-sans-latin-normal.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      @font-face {
        font-family: "Plus Jakarta Sans";
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url("../fonts/plus-jakarta-sans-latin-normal.woff2") format("woff2");
      }

      /* ─── TOKENS ──────────────────────────────── */
      :root {
        --navy:    #0a1d33;
        --blue-d:  #142d4c;
        --blue:    #1d6fa8;
        --blue-l:  #5aaee0;
        --blue-xl: #e8f4fd;
        --sky:     #f0f7fd;
        --yellow:  #f6c133;
        --yellow-d:#e0ab1d;
        --yellow-l:#fffbe6;
        --green:   #16a34a;
        --green-l: #e8f7ee;
        --grey:    #5e6a75;
        --grey-d:  #2d3748;
        --grey-l:  #e2e8f0;
        --white:   #ffffff;

        --border-subtle: rgba(29, 111, 168, 0.08);
        --border-hover:  rgba(29, 111, 168, 0.18);
        --shadow-sm:     0 2px 8px rgba(10, 29, 51, 0.02);
        --shadow-md:     0 8px 30px rgba(10, 29, 51, 0.04);
        --shadow-lg:     0 16px 48px rgba(10, 29, 51, 0.06);
        --shadow-premium:0 24px 60px rgba(10, 29, 51, 0.08);

        --font:  "Plus Jakarta Sans", system-ui, sans-serif;
        --r-s:   8px;
        --r:     12px;
        --r-l:   20px;
        --r-xl:  28px;
        --ease:  cubic-bezier(0.16, 1, 0.3, 1);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--grey-d);
        background: var(--white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }
      img { display: block; max-width: 100%; }

      /* ─── KEYFRAMES ───────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: none; }
      }
      @keyframes floatY {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-5px); }
      }

      /* ─── STAGGER SYSTEM ──────────────────────── */
      .si {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .si[data-d="l"] { transform: translateX(-24px); }
      .si[data-d="r"] { transform: translateX(24px); }
      .si.in { opacity: 1; transform: none; }

      /* ─── LAYOUT ──────────────────────────────── */
      .c6     { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; }
      .pad    { padding: 6.5rem 0; }
      .pad-sm { padding: 4.5rem 0; }
      #about-nav + #story { padding-top: 8rem; }

      /* ─── SHARED TYPOGRAPHY ───────────────────── */
      .eyebrow6 {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--blue); margin-bottom: 0.85rem;
      }
      .eyebrow6::before {
        content: ""; width: 16px; height: 2.5px;
        background: var(--yellow); border-radius: 2px; flex-shrink: 0;
      }
      h2.h6 {
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--navy); line-height: 1.15;
      }
      h2.h6 .ac { color: var(--blue); }
      .lead6 {
        font-size: 1.05rem; color: var(--grey);
        line-height: 1.75; max-width: 520px;
        margin-top: 0.75rem;
      }
      .sec-header6 {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 4rem; align-items: end; margin-bottom: 4rem;
      }

      /* ─── BUTTONS ─────────────────────────────── */
      .btn6-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.95rem;
        padding: 0.95rem 2rem; border-radius: 100px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: var(--font); white-space: nowrap;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(246, 193, 51, 0.2);
      }
      .btn6-primary:hover { background: var(--yellow-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(246, 193, 51, 0.4); }
      .btn6-outline {
        display: inline-flex; align-items: center; gap: 0.45rem;
        color: var(--navy); font-weight: 600; font-size: 0.9rem;
        padding: 0.9rem 1.75rem; border-radius: 100px;
        border: 1px solid var(--grey-l); background: transparent;
        text-decoration: none; cursor: pointer; font-family: var(--font); white-space: nowrap;
        transition: border-color 0.25s, background 0.25s, color 0.25s;
      }
      .btn6-outline:hover { border-color: var(--navy); background: var(--sky); }
      .btn6-ghost-dark {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: rgba(255,255,255,0.6);
        font-weight: 500; font-size: 0.9rem; border-radius: 100px;
        border: 1px solid rgba(255,255,255,0.15);
        padding: 0.9rem 1.75rem; text-decoration: none;
        font-family: var(--font); white-space: nowrap;
        transition: color 0.25s, border-color 0.25s, background 0.25s;
      }
      .btn6-ghost-dark:hover { color: var(--white); border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.06); }

      /* ─── HEADER ──────────────────────────────── */
      #hd6 {
        position: fixed; inset: 0 0 auto; z-index: 200;
        height: 72px; display: flex; align-items: center; justify-content: space-between;
        padding: 0 4vw;
        transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), height 0.3s var(--ease);
      }
      #hd6.scrolled {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(10, 29, 51, 0.03);
        height: 64px; border-bottom: 1px solid rgba(10, 29, 51, 0.04);
      }
      .hd6-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .hd6-mark {
        width: 38px; height: 38px; border-radius: 12px; background: var(--blue);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: background 0.3s;
      }
      #hd6.scrolled .hd6-mark { background: var(--navy); }
      .hd6-name { font-size: 1.15rem; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
      .hd6-nav { display: flex; align-items: center; gap: 0.25rem; }
      .hd6-nav a {
        font-size: 0.9rem; font-weight: 500; color: var(--grey-d);
        text-decoration: none; padding: 0.5rem 1rem;
        border-radius: 8px; transition: color 0.2s, background 0.2s;
      }
      .hd6-nav a:hover, .hd6-nav a.active { color: var(--blue); background: var(--sky); }
      .hd6-cta {
        display: inline-flex; align-items: center; gap: 0.45rem;
        background: var(--yellow); color: var(--navy);
        font-weight: 700; font-size: 0.9rem; padding: 0.55rem 1.35rem; border-radius: 100px;
        text-decoration: none; margin-left: 0.75rem;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s; white-space: nowrap;
      }
      .hd6-cta:hover { background: var(--yellow-d); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(246,193,51,.35); }
      .hd6-toggle { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 201; }
      .hd6-toggle span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.3s var(--ease); }
      
      #hd6.menu-open { background: var(--white) !important; box-shadow: none !important; border-bottom: 1px solid rgba(10, 29, 51, 0.04) !important; }
      #hd6.menu-open .hd6-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #hd6.menu-open .hd6-toggle span:nth-child(2) { opacity: 0; }
      #hd6.menu-open .hd6-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      #hd6-mob {
        display: none; position: fixed; inset: 0; z-index: 199;
        background: var(--white); flex-direction: column; padding: 6rem 2rem 2rem; gap: 0.5rem;
      ; overflow-y: auto;}
      /* Mobile Dropdown Accordion Styling */
      .mob6-dropdown-item {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      #hd6-mob a, .mob6-dropdown-label {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        padding: 0.95rem 0;
        flex: 1;
      }
      .mob6-dropdown-label {
        cursor: default;
        user-select: none;
      }
      .mob6-dropdown-toggle {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        transition: transform 0.25s var(--ease);
      }
      .mob6-dropdown-toggle.open {
        transform: rotate(180deg);
        color: var(--blue);
      }
      .mob6-dropdown-item .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
        max-height: 500px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.35s var(--ease), opacity 0.35s var(--ease), margin 0.35s var(--ease);
      }
      .mob6-dropdown-item .mob6-sub-menu.collapsed {
        max-height: 0;
        opacity: 0;
        margin: 0;
        padding-top: 0;
        padding-bottom: 0;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .mob6-dropdown-item {
        border-bottom: 1px solid var(--grey-l);
      }
      .mob6-dropdown-item a, .mob6-dropdown-item .mob6-dropdown-label {
        border-bottom: none !important;
      }

      #hd6-mob.open { display: flex; }
      #hd6-mob a { font-size: 1.2rem; font-weight: 600; color: var(--navy); text-decoration: none; padding: 0.95rem 0; border-bottom: 1px solid var(--grey-l); }
      .mob6-cta { background: var(--yellow); color: var(--navy); text-align: center; border-radius: var(--r); padding: 1.1rem; margin-top: 1rem; font-size: 1rem; font-weight: 700; text-decoration: none; display: block; }

      /* ─── PAGE HERO ───────────────────────────── */
      #about-hero { background: var(--sky); padding-top: 72px; position: relative; overflow: hidden; }
      .about-hero-sun {
        position: absolute; top: -120px; right: -100px;
        width: 560px; height: 560px; border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(246, 193, 51, 0.14) 0%, rgba(246, 193, 51, 0.03) 60%, transparent 80%);
        pointer-events: none;
      }
      .about-hero-body {
        max-width: 1180px; margin: 0 auto; padding: 4rem 2.5rem 5rem;
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 5rem; align-items: start; position: relative; z-index: 2;
      }
      .about-hero-pill {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.75rem; font-weight: 700; color: var(--blue); letter-spacing: 0.05em;
        margin-bottom: 1.75rem; width: fit-content;
        background: var(--white); padding: 0.4rem 0.9rem; border-radius: 100px;
        box-shadow: var(--shadow-sm); animation: fadeUp 0.5s var(--ease) 0s both;
      }
      .about-hero-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--yellow); flex-shrink: 0; }
      .about-hero-h1 {
        font-size: clamp(2.8rem, 5vw, 4rem); font-weight: 800; letter-spacing: -0.04em;
        line-height: 1.08; color: var(--navy); margin-bottom: 1.5rem;
        animation: fadeUp 0.65s var(--ease) 0.1s both;
      }
      .about-hero-h1 .ac { color: var(--blue); }
      .about-hero-sub {
        font-size: 1.1rem; color: var(--grey); line-height: 1.75; max-width: 500px;
        margin-bottom: 2.25rem; animation: fadeUp 0.65s var(--ease) 0.25s both;
      }
      .about-hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; animation: fadeUp 0.65s var(--ease) 0.4s both; }
      .about-hero-right { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; animation: fadeUp 0.8s var(--ease) 0.2s both; }
      .about-hero-img { border-radius: var(--r-xl); overflow: hidden; box-shadow: var(--shadow-lg); border: 1px solid var(--border-subtle); }
      .about-hero-img:first-child { grid-row: span 2; }
      .about-hero-img img { width: 100%; height: 100%; object-fit: cover; }
      .about-hero-img.tall { height: 380px; }
      .about-hero-img.short { height: 185px; }

      /* ─── SECTION ANCHOR NAV ──────────────────── */
      #about-nav {
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky;
        top: 72px;
        z-index: 150;
        transition: top 0.3s var(--ease);
      }
      #hd6.scrolled ~ #about-nav {
        top: 64px;
      }
      .pnav-inner { max-width: 1180px; margin: 0 auto; padding: 0 2.5rem; display: flex; align-items: center; gap: 0.5rem; overflow-x: auto; scrollbar-width: none; }
      .pnav-inner::-webkit-scrollbar { display: none; }
      .pnav-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--grey); padding: 1.1rem 1.15rem; text-decoration: none; white-space: nowrap; border-bottom: 3px solid transparent; margin-bottom: -1px; transition: color 0.25s, border-color 0.25s; }
      .pnav-link:hover { color: var(--blue); }
      .pnav-link.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 700; }

      /* ─── 1. STORY ────────────────────────────── */
      #story { background: var(--white); }
      .story-layout { display: grid; grid-template-columns: 5fr 7fr; gap: 6rem; align-items: start; }

      /* Timeline */
      .story-timeline { display: flex; flex-direction: column; position: relative; padding-top: 0.25rem; }
      .story-timeline::before {
        content: ""; position: absolute; left: 19px; top: 10px; bottom: 10px;
        width: 2px; background: var(--grey-l); border-radius: 2px;
      }
      .tl-item { display: flex; gap: 1.5rem; position: relative; padding-bottom: 2.5rem; }
      .tl-item:last-child { padding-bottom: 0; }
      .tl-dot-wrap { flex-shrink: 0; width: 40px; display: flex; flex-direction: column; align-items: center; }
      .tl-dot {
        width: 14px; height: 14px; border-radius: 50%;
        border: 2px solid var(--grey-l); background: var(--white); margin-top: 3px; flex-shrink: 0;
        transition: border-color 0.3s, background 0.3s;
      }
      .tl-item.hi .tl-dot { background: var(--yellow); border-color: var(--yellow); box-shadow: 0 0 0 4px rgba(246, 193, 51, 0.15); }
      .tl-item.ms .tl-dot { background: var(--blue); border-color: var(--blue); box-shadow: 0 0 0 4px rgba(29, 111, 168, 0.12); }
      .tl-content { flex: 1; }
      .tl-year { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--grey); margin-bottom: 0.3rem; }
      .tl-item.hi .tl-year { color: var(--yellow-d); }
      .tl-item.ms .tl-year { color: var(--blue); }
      .tl-title { font-size: 0.95rem; font-weight: 700; color: var(--navy); margin-bottom: 0.3rem; letter-spacing: -0.01em; }
      .tl-text { font-size: 0.84rem; color: var(--grey); line-height: 1.65; }

      /* Story copy */
      .story-copy h2.h6 { margin-bottom: 1.5rem; }
      .story-copy p { font-size: 0.97rem; color: var(--grey); line-height: 1.8; margin-bottom: 1.25rem; }
      .story-copy p:last-of-type { margin-bottom: 0; }
      .story-pull {
        margin: 2rem 0;
        border-left: 3px solid var(--yellow);
        padding: 0.5rem 0 0.5rem 1.5rem;
      }
      .story-pull p { font-size: 1.08rem; font-weight: 600; color: var(--navy); line-height: 1.6; font-style: italic; margin: 0; }

      /* ─── 2. FOUNDERS ─────────────────────────── */
      #founders {
        background: var(--white);
        border-top: 1px solid var(--border-subtle);
        position: relative; overflow: hidden;
      }
      .founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; position: relative; z-index: 1; }

      .founder-card {
        background: var(--sky);
        border: 1px solid var(--border-subtle);
        border-radius: var(--r-xl); overflow: hidden;
        transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
      }
      .founder-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
      }

      .founder-img {
        width: 100%; height: 320px; overflow: hidden;
        border-bottom: 1px solid var(--border-subtle);
      }
      .founder-img img { width: 100%; height: 100%; object-fit: cover; }
      .founder-body { padding: 1.75rem 2rem 2rem; }
      .founder-name { font-size: 1.35rem; font-weight: 800; color: var(--navy); letter-spacing: -0.03em; margin-bottom: 0.2rem; }
      .founder-role { font-size: 0.8rem; font-weight: 600; color: var(--blue); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.25rem; }
      .founder-bio { font-size: 0.88rem; color: var(--grey); line-height: 1.75; margin-bottom: 1.25rem; }
      .founder-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.25rem; }
      .founder-tag {
        font-size: 0.72rem; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 100px;
        background: var(--blue-xl); border: 1px solid var(--border-subtle);
        color: var(--blue);
      }
      .founder-details { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 1.25rem; border-top: 1px solid var(--border-subtle); }
      .fdr { display: flex; align-items: center; gap: 0.6rem; font-size: 0.82rem; color: var(--grey); }
      .fdr-ico { font-size: 0.9rem; flex-shrink: 0; }
      .founder-quote {
        background: var(--yellow-l);
        border: 1px solid rgba(246, 193, 51, 0.35);
        border-radius: var(--r); padding: 1rem 1.1rem; margin-top: 1.25rem;
      }
      .founder-quote p { font-size: 0.84rem; color: var(--grey-d); line-height: 1.65; font-style: italic; }
      .founder-quote p::before { content: '"'; color: var(--yellow-d); font-weight: 800; margin-right: 2px; }
      .founder-quote p::after  { content: '"'; color: var(--yellow-d); font-weight: 800; margin-left: 2px; }

      /* Founders sec-header */
      .founders-header { position: relative; z-index: 1; margin-bottom: 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; }
      .founders-header h2.h6 { color: var(--navy); }
      .founders-header .lead6 { color: var(--grey); }

      /* ─── 3. MISSION & VALUES ─────────────────── */
      #mission { background: var(--sky); }
      .mission-layout { display: grid; grid-template-columns: 5fr 7fr; gap: 6rem; align-items: start; }
      .mission-copy p { font-size: 0.95rem; color: var(--grey); line-height: 1.8; margin-bottom: 1.1rem; margin-top: 1.25rem; }
      .mission-statement {
        background: var(--navy); border-radius: var(--r-xl);
        padding: 2.25rem; margin-top: 2rem; position: relative; overflow: hidden;
      }
      .mission-statement::before {
        content: ""; position: absolute; inset: 0;
        background: radial-gradient(ellipse 70% 70% at 100% 100%, rgba(29, 111, 168, 0.25) 0%, transparent 70%);
        pointer-events: none;
      }
      .mission-statement blockquote {
        position: relative; z-index: 1;
        font-size: 1.05rem; font-weight: 600; color: var(--white); line-height: 1.7; font-style: italic;
      }
      .mission-statement blockquote::before {
        content: '"'; font-size: 3rem; color: var(--yellow); font-weight: 800;
        line-height: 0.5; display: block; margin-bottom: 0.75rem; font-style: normal;
      }
      .mission-statement cite { display: block; font-size: 0.78rem; color: rgba(255, 255, 255, 0.35); font-style: normal; margin-top: 1rem; }

      /* Values list */
      .values-grid {
        display: flex; flex-direction: column; gap: 1px;
        background: var(--grey-l);
        border: 1px solid var(--grey-l); border-radius: var(--r-xl); overflow: hidden;
      }
      .value-item {
        background: var(--white); padding: 1.75rem 2rem;
        display: flex; gap: 1.25rem; align-items: flex-start;
        transition: background 0.25s; cursor: default;
      }
      .value-item:hover { background: var(--blue-xl); }
      .value-num {
        width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
        background: var(--sky); border: 1px solid var(--border-subtle);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 800; color: var(--blue);
        transition: background 0.25s, border-color 0.25s;
      }
      .value-item:hover .value-num { background: var(--blue-xl); border-color: rgba(29, 111, 168, 0.25); }
      .value-body h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.35rem; letter-spacing: -0.01em; }
      .value-body p { font-size: 0.85rem; color: var(--grey); line-height: 1.65; }

      /* ─── 4. HOW WE HIRE ──────────────────────── */
      #hiring { background: var(--sky); }
      .hiring-layout { display: grid; grid-template-columns: 5fr 7fr; gap: 6rem; align-items: start; }
      .hiring-copy p { font-size: 0.95rem; color: var(--grey); line-height: 1.8; margin-bottom: 1.1rem; margin-top: 1.25rem; }
      .hiring-promise {
        background: var(--white); border: 1px solid var(--border-subtle);
        border-radius: var(--r-l); padding: 1.75rem; margin-top: 1.5rem;
        box-shadow: var(--shadow-sm);
      }
      .hp-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.875rem; }
      .hp-ico { font-size: 1.25rem; }
      .hp-title { font-size: 0.95rem; font-weight: 700; color: var(--navy); }
      .hp-list { display: flex; flex-direction: column; gap: 0.6rem; list-style: none; padding: 0; }
      .hp-item { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.86rem; color: var(--grey-d); line-height: 1.5; }
      .hp-item::before { content: "✓"; color: var(--yellow-d); font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }

      .hiring-steps { display: flex; flex-direction: column; gap: 0; }
      .hiring-step {
        display: flex; gap: 1.25rem;
        padding: 1.5rem 0; border-bottom: 1px solid var(--grey-l);
      }
      .hiring-step:last-child { border-bottom: none; }
      .hs-num {
        width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
        background: var(--navy);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.82rem; font-weight: 800; color: var(--white); margin-top: 2px;
      }
      .hs-body h3 { font-size: 0.95rem; font-weight: 700; color: var(--navy); margin-bottom: 0.3rem; letter-spacing: -0.01em; }
      .hs-body p { font-size: 0.84rem; color: var(--grey); line-height: 1.65; }

      /* ─── FAQ ─────────────────────────────────── */
      #faq6 { background: var(--white); border-top: 1px solid var(--border-subtle); }
      .faq6-layout { display: grid; grid-template-columns: 4fr 8fr; gap: 5rem; align-items: start; }
      .compact-contact-card {
        padding: 2rem 2.25rem;
        background: var(--sky);
        border-radius: 20px;
        border: 1px solid var(--border-subtle);
        width: fit-content;
        max-width: 100%;
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        box-shadow: var(--shadow-sm);
      }
      .compact-card-line {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.88rem;
        line-height: 1.2;
        color: var(--blue);
        font-weight: 700;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .compact-card-line span:last-child {
        font-size: 0.88rem;
        line-height: 1.2;
      }
      .compact-card-line:hover {
        opacity: 0.85;
      }
      .compact-card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .faq6-list { border-top: 1px solid var(--border-subtle); }
      .faq6-item { border-bottom: 1px solid var(--border-subtle); }
      .faq6-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.35rem 0; cursor: pointer; background: none; border: none; width: 100%; font-family: var(--font); font-size: 0.95rem; font-weight: 700; color: var(--navy); text-align: left; transition: color 0.2s; }
      .faq6-q:hover { color: var(--blue); }
      .faq6-ico { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--grey-l); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: var(--grey); font-weight: 400; flex-shrink: 0; transition: all 0.3s var(--ease); line-height: 1; }
      .faq6-item.open .faq6-ico { background: var(--yellow); border-color: var(--yellow); color: var(--navy); transform: rotate(45deg); }
      .faq6-a { font-size: 0.9rem; color: var(--grey); line-height: 1.75; max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease), padding 0.3s; }
      .faq6-item.open .faq6-a { max-height: 280px; padding-bottom: 1.35rem; }

      /* ─── FINAL CTA ────────────────────────────── */
      #cta6.cta-sky {
        background: var(--sky);
        padding: 6.5rem 0;
        border-top: 1px solid var(--border-subtle);
        border-bottom: 1px solid var(--border-subtle);
      }
      .cta6-grid {
        display: grid;
        grid-template-columns: 1.25fr 0.75fr;
        gap: 4.5rem;
        align-items: center;
      }
      .cta6-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .cta6-sub {
        font-size: 1.05rem;
        color: var(--grey);
        line-height: 1.7;
        max-width: 500px;
        margin: 1rem 0 2.25rem;
      }
      .cta6-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.25rem;
      }
      .cta6-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        border-top: 1px solid var(--grey-l);
        padding-top: 1.5rem;
      }
      .cta6-trust-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.83rem;
        font-weight: 600;
        color: var(--grey-d);
      }
      .cta6-trust-item::before {
        content: "✓";
        color: var(--green);
        font-weight: 800;
      }
      .cta6-right {
        position: relative;
        overflow: hidden;
        height: 380px;
        border-radius: var(--r-xl);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
      }
      .cta6-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* ─── FOOTER ──────────────────────────────── */
      #ft6 { background: var(--navy); padding: 4.5rem 2.5rem 2.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
      .ft6-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3.5rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .ft6-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.7; margin-top: 0.85rem; max-width: 280px; }
      .ft6-logo { font-size: 1.2rem; font-weight: 800; color: rgba(255,255,255,0.85); letter-spacing: -0.02em; }
      .ft6-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
      .ft6-col a { display: block; font-size: 0.88rem; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.2s; }
      .ft6-col a:hover { color: rgba(255,255,255,0.85); }
      .ft6-bottom { max-width: 1180px; margin: 1.75rem auto 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      .ft6-bottom span, .ft6-bottom a { font-size: 0.78rem; color: rgba(255,255,255,0.25); text-decoration: none; transition: color 0.2s; }
      .ft6-bottom a:hover { color: rgba(255,255,255,0.6); }

      /* ─── RESPONSIVE ──────────────────────────── */
      @media (max-width: 1024px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .about-hero-body { grid-template-columns: 1fr; gap: 3rem; }
        .about-hero-right { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .cta6-grid { grid-template-columns: 1fr; gap: 3rem; }
        .cta6-right { height: 320px; }
        .story-layout, .mission-layout, .hiring-layout, .faq6-layout { grid-template-columns: 1fr; gap: 4rem; }
        .founders-grid { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto; width: 100%; }
        .founders-header { grid-template-columns: 1fr; gap: 0.75rem; }
        .sec-header6 { grid-template-columns: 1fr; gap: 1.5rem; }
        .ft6-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      }
      @media (max-width: 768px) {
        .about-hero-body { padding: 4rem 1.5rem 3rem; }
        .cta6-left { padding: 2.5rem 1.5rem; }
        .c6 { padding: 0 1.5rem; }
        .pad { padding: 4.5rem 0; }
        .ft6-inner { grid-template-columns: 1fr; gap: 2rem; }
      }
      /* Dropdown style system */
      .hd6-nav-item-dropdown {
        position: relative;
        display: inline-block;
      }
      .hd6-nav-dropdown-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
      }
      .hd6-nav-dropdown-toggle svg {
        transition: transform 0.2s var(--ease);
      }
      .hd6-nav-item-dropdown:hover .hd6-nav-dropdown-toggle svg {
        transform: rotate(180deg);
      }
      .hd6-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: var(--white);
        min-width: 220px;
        border-radius: var(--r);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-lg);
        padding: 0.65rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
        z-index: 250;
        display: flex;
        flex-direction: column;
      }
      .hd6-nav-item-dropdown:hover .hd6-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .hd6-dropdown-menu a {
        display: block !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        color: var(--grey-d) !important;
        padding: 0.6rem 1.25rem !important;
        border-radius: 0 !important;
        transition: background 0.2s, color 0.2s !important;
        text-align: left;
      }
      .hd6-dropdown-menu a:hover {
        background: var(--sky) !important;
        color: var(--blue) !important;
      }

      /* Mobile sub-menu styling */
      .mob6-sub-menu {
        display: flex;
        flex-direction: column;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-subtle);
        margin: 0.25rem 0 0.75rem;
        gap: 0.35rem;
      }
      .mob6-sub-menu a {
        font-size: 0.95rem !important;
        color: var(--grey) !important;
        padding: 0.5rem 0 !important;
        border-bottom: none !important;
      }
      .mob6-sub-menu a:hover {
        color: var(--blue) !important;
      }
      .hd6-mob-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--grey);
        letter-spacing: 0.08em;
        margin-top: 0.75rem;
        margin-bottom: 0.25rem;
      }

      @media (max-width: 640px) {
        .hd6-nav { display: none; }
        .hd6-toggle { display: flex; }
        .about-hero-h1 { font-size: 2.4rem; }
        .founders-header { gap: 0.5rem; margin-bottom: 2.5rem; }
      }
      @media (max-width: 768px) {
        #about-nav + #story { padding-top: 5.5rem; }
      }
      /* Keep every non-hero section aligned with the landing services section. */
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
        padding-top: 6.5rem !important;
        padding-bottom: 6.5rem !important;
      }
      section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
        max-width: 1180px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 2.5rem !important;
        padding-right: 2.5rem !important;
      }
      @media (max-width: 768px) {
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) {
          padding-top: 4.5rem !important;
          padding-bottom: 4.5rem !important;
        }
        section:not([id*="hero"]):not([id*="trust"]):not([id*="strip"]) > :is(.c6, .container, .article-layout, .related-header, .related-grid, .trust-inner) {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
      @media (max-width: 768px), (hover: none), (pointer: coarse) {
        #hd6.scrolled,
        nav[id$="-nav"]:not(#hd6-mob),
        .eol6-strip-img span {
          backdrop-filter: none;
          -webkit-backdrop-filter: none;
        }
        .srv6-card-blur {
          display: none;
        }
      }
    </style>
  </head>

  <body>
